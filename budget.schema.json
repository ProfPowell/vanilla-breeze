{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Performance Budget",
  "description": "Vanilla Breeze performance budget constraints",
  "type": "object",
  "required": ["targets", "framework", "per_component"],
  "properties": {
    "$schema": { "type": "string" },
    "description": { "type": "string" },
    "version": { "type": "string" },
    "targets": {
      "type": "object",
      "required": ["carbon_a_plus_kb", "carbon_a_kb"],
      "properties": {
        "carbon_a_plus_kb": { "type": "number", "description": "A+ carbon rating page budget in KB" },
        "carbon_a_kb": { "type": "number", "description": "A carbon rating page budget in KB" }
      }
    },
    "framework": {
      "type": "object",
      "required": ["css_kb", "js_kb"],
      "properties": {
        "description": { "type": "string" },
        "css_kb": { "type": "number" },
        "js_kb": { "type": "number" },
        "note": { "type": "string" }
      }
    },
    "per_component": {
      "type": "object",
      "required": ["max_kb"],
      "properties": {
        "description": { "type": "string" },
        "max_kb": { "type": "number" },
        "warn_kb": { "type": "number" },
        "note": { "type": "string" }
      }
    },
    "fonts": {
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "max_kb": { "type": "number" },
        "warn_kb": { "type": "number" },
        "note": { "type": "string" }
      }
    },
    "images": {
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "max_kb": { "type": "number" },
        "warn_kb": { "type": "number" },
        "note": { "type": "string" }
      }
    },
    "theme": {
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "max_kb": { "type": "number" },
        "warn_kb": { "type": "number" }
      }
    },
    "demo_site": {
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "max_kb": { "type": "number" },
        "warn_kb": { "type": "number" },
        "note": { "type": "string" }
      }
    }
  }
}
