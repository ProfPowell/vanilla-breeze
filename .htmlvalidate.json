{
  "$schema": "https://html-validate.org/schemas/config.json",
  "root": true,
  "extends": [
    "html-validate:recommended",
    "html-validate:document"
  ],
  "elements": [
    "html5",
    "./src/htmlvalidate/elements.cjs",
    "./src/htmlvalidate/elements-overrides.cjs"
  ],
  "rules": {
    "no-unknown-elements": "error",
    "element-permitted-content": "error",
    "element-required-attributes": "error",
    "attribute-allowed-values": "error",
    "wcag/h37": "error",
    "wcag/h67": "error",
    "wcag/h71": "error",
    "prefer-native-element": "error",
    "no-inline-style": "warn",
    "no-raw-characters": ["error", { "relaxed": true }],
    "form-dup-name": ["error", { "shared": ["radio", "submit", "button", "reset", "checkbox"] }],
    "require-sri": "off",
    "doctype-style": ["error", { "style": "lowercase" }],
    "void-style": ["error", { "style": "selfclose" }]
  }
}
