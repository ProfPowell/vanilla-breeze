{
  "$schema": "../../../schemas/api.schema.json",
  "element": "compare-surface",
  "type": "web-component",
  "description": "Before/after image comparison slider",
  "htmlvalidate": {
    "flow": true,
    "permittedContent": [
      "@flow"
    ]
  },
  "attributes": [
    {
      "name": "position",
      "kind": "host-api",
      "purpose": "config",
      "type": "number",
      "description": "Slider position (0-100), default 50. Reflected on change."
    },
    {
      "name": "role",
      "kind": "native",
      "purpose": "config"
    },
    {
      "name": "aria-valuemin",
      "kind": "aria",
      "purpose": "config"
    },
    {
      "name": "aria-valuemax",
      "kind": "aria",
      "purpose": "config"
    },
    {
      "name": "aria-valuenow",
      "kind": "aria",
      "purpose": "config"
    }
  ],
  "events": [
    {
      "name": "compare-surface:change"
    }
  ],
  "childAttributes": [],
  "structure": []
}
