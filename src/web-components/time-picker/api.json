{
  "$schema": "../../../schemas/api.schema.json",
  "element": "time-picker",
  "type": "web-component",
  "description": "Form-associated time input with combobox text entry",
  "htmlvalidate": {
    "flow": true,
    "permittedContent": [
      "@flow"
    ]
  },
  "attributes": [
    {
      "name": "name",
      "kind": "native",
      "purpose": "config",
      "type": "string",
      "description": "Form field name"
    },
    {
      "name": "data-format",
      "kind": "data",
      "purpose": "config",
      "type": "string",
      "description": "\"12h\" or \"24h\" (default: locale-detected)"
    },
    {
      "name": "disabled",
      "kind": "native",
      "purpose": "config",
      "type": "boolean",
      "description": "Disables the picker"
    },
    {
      "name": "required",
      "kind": "native",
      "purpose": "config",
      "type": "boolean",
      "description": "Makes selection required"
    },
    {
      "name": "step",
      "kind": "native",
      "purpose": "config"
    },
    {
      "name": "min",
      "kind": "native",
      "purpose": "config"
    },
    {
      "name": "max",
      "kind": "native",
      "purpose": "config"
    },
    {
      "name": "data-disabled",
      "kind": "data",
      "purpose": "config"
    },
    {
      "name": "role",
      "kind": "native",
      "purpose": "config"
    },
    {
      "name": "aria-haspopup",
      "kind": "aria",
      "purpose": "config"
    },
    {
      "name": "autocomplete",
      "kind": "native",
      "purpose": "config"
    },
    {
      "name": "placeholder",
      "kind": "native",
      "purpose": "config"
    },
    {
      "name": "size",
      "kind": "host-api",
      "purpose": "config"
    },
    {
      "name": "aria-valuemin",
      "kind": "aria",
      "purpose": "config"
    },
    {
      "name": "aria-valuemax",
      "kind": "aria",
      "purpose": "config"
    },
    {
      "name": "data-open",
      "kind": "data",
      "purpose": "config"
    },
    {
      "name": "aria-valuenow",
      "kind": "aria",
      "purpose": "config"
    },
    {
      "name": "aria-valuetext",
      "kind": "aria",
      "purpose": "config"
    }
  ],
  "events": [
    {
      "name": "time-picker:change"
    }
  ],
  "childAttributes": [],
  "structure": []
}
