{
  "$schema": "../../../schemas/api.schema.json",
  "element": "heading-links",
  "type": "web-component",
  "description": "Add anchor links to headings",
  "attributes": [
    {
      "name": "levels",
      "kind": "host-api",
      "purpose": "config",
      "type": "string",
      "description": "Heading levels to process (default: 'h2,h3')"
    },
    {
      "name": "data-toc-ignore",
      "kind": "data",
      "purpose": "config"
    },
    {
      "name": "role",
      "kind": "native",
      "purpose": "config"
    }
  ],
  "events": [
    {
      "name": "heading-links:navigate"
    }
  ],
  "childAttributes": [],
  "structure": [],
  "htmlvalidate": {
    "flow": true,
    "permittedContent": [
      "@flow"
    ]
  }
}
