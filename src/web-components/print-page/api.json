{
  "$schema": "../../../schemas/api.schema.json",
  "element": "print-page",
  "type": "web-component",
  "description": "Print button with optional raw-mode toggle",
  "htmlvalidate": {
    "flow": true,
    "permittedContent": [
      "@flow"
    ]
  },
  "attributes": [
    {
      "name": "raw-toggle",
      "kind": "host-api",
      "purpose": "config",
      "type": "boolean",
      "description": "If present, shows a checkbox to disable VB print styles"
    },
    {
      "name": "label",
      "kind": "host-api",
      "purpose": "config",
      "type": "string",
      "description": "Custom button label (default: \"Print this page\")"
    },
    {
      "name": "role",
      "kind": "native",
      "purpose": "config"
    },
    {
      "name": "data-print-raw",
      "kind": "data",
      "purpose": "config"
    }
  ],
  "childAttributes": [],
  "structure": []
}
