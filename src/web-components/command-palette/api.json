{
  "$schema": "../../../schemas/api.schema.json",
  "element": "command-palette",
  "type": "web-component",
  "description": "Command palette / Cmd+K launcher",
  "htmlvalidate": {
    "flow": true,
    "permittedContent": [
      "@flow"
    ]
  },
  "attributes": [
    {
      "name": "hotkey",
      "kind": "host-api",
      "purpose": "config",
      "type": "string",
      "description": "Global keyboard shortcut to open (default: \"meta+k\")"
    },
    {
      "name": "placeholder",
      "kind": "native",
      "purpose": "config",
      "type": "string",
      "description": "Search input placeholder text"
    },
    {
      "name": "discover",
      "kind": "host-api",
      "purpose": "config",
      "type": "boolean",
      "description": "When present, auto-populate from [data-command] registry"
    },
    {
      "name": "role",
      "kind": "native",
      "purpose": "config"
    },
    {
      "name": "label",
      "kind": "host-api",
      "purpose": "config"
    },
    {
      "name": "value",
      "kind": "native",
      "purpose": "config"
    },
    {
      "name": "data-hotkey",
      "kind": "data",
      "purpose": "config"
    },
    {
      "name": "name",
      "kind": "native",
      "purpose": "config"
    }
  ],
  "events": [
    {
      "name": "command-palette:select"
    },
    {
      "name": "command-palette:open"
    },
    {
      "name": "command-palette:close"
    }
  ],
  "childAttributes": [],
  "structure": []
}
