{
  "$schema": "../../../schemas/api.schema.json",
  "element": "page-toc",
  "type": "web-component",
  "description": "Table of contents with scroll-spy",
  "attributes": [
    {
      "name": "levels",
      "kind": "host-api",
      "purpose": "config",
      "type": "string",
      "description": "Heading levels to include (default: 'h2,h3')"
    },
    {
      "name": "title",
      "kind": "native",
      "purpose": "config",
      "type": "string",
      "description": "ToC title (default: 'On this page')"
    },
    {
      "name": "href",
      "kind": "native",
      "purpose": "config"
    },
    {
      "name": "data-toc-ignore",
      "kind": "data",
      "purpose": "config"
    }
  ],
  "events": [
    {
      "name": "page-toc:navigate"
    }
  ],
  "childAttributes": [],
  "structure": [],
  "htmlvalidate": {
    "flow": true,
    "permittedContent": [
      "@flow"
    ]
  }
}
