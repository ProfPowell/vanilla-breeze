<h1>Icons Pack</h1>
<p class="lead">Material Symbols Outlined variable icon font. Context-aware weight and optical size. Attractor animations via <code>data-vb-attract</code>.</p>

<table>
  <tbody>
    <tr><th>Type</th><td>Full (theme + effects + JS)</td></tr>
    <tr><th>Theme CSS</th><td><code>packs/icons.theme.css</code></td></tr>
    <tr><th>Effects CSS</th><td><code>packs/icons.effects.css</code></td></tr>
    <tr><th>Effects JS</th><td><code>packs/icons.effects.js</code></td></tr>
    <tr><th>Full bundle</th><td><code>packs/icons.full.css</code> + <code>packs/icons.full.js</code></td></tr>
    <tr><th>Font weight</th><td>~3.8MB (full set) &mdash; subset for production</td></tr>
  </tbody>
</table>

<section>
  <h2>Coexistence with icon-wc</h2>
  <p>This pack <strong>coexists</strong> with the existing <a href="/docs/elements/web-components/icon-wc/"><code>&lt;icon-wc&gt;</code></a> SVG icon system. Use whichever fits your needs:</p>
  <ul>
    <li><code>&lt;icon-wc name="menu"&gt;</code> &mdash; SVG icons (lucide etc.), unchanged</li>
    <li><code>&lt;span class="vb-icon"&gt;menu&lt;/span&gt;</code> &mdash; Material Symbols font icons (when pack loaded)</li>
  </ul>
</section>

<section>
  <h2>Loading</h2>

{% set fullCode %}<link rel="stylesheet" href="/cdn/packs/icons.full.css">
<script type="module" src="/cdn/packs/icons.full.js"></script>{% endset %}

  <code-block language="html" label="Full pack">{{ fullCode | escape }}</code-block>

{% set themeOnlyCode %}<!-- Icons without attractor animations -->
<link rel="stylesheet" href="/cdn/packs/icons.theme.css">{% endset %}

  <code-block language="html" label="Theme only (no animations)">{{ themeOnlyCode | escape }}</code-block>
</section>

<section>
  <h2>Basic Usage</h2>

{% set basicCode %}<!-- Inline with text -->
<p>Upload your files <span class="vb-icon">upload</span> to get started.</p>

<!-- Button with fill-on-hover -->
<button data-vb-icon-fill="hover">
  <span class="vb-icon">favorite</span> Save
</button>

<!-- Standalone large icon -->
<span class="vb-icon" data-size="xl">notifications</span>

<!-- Always filled -->
<span class="vb-icon filled">star</span>{% endset %}

  <code-block language="html" label="Basic usage">{{ basicCode | escape }}</code-block>
</section>

<section>
  <h2>Context-Aware Sizing</h2>
  <p>Icons automatically adjust weight and optical size based on their context:</p>

  <table>
    <thead>
      <tr><th>Context</th><th>Weight</th><th>Optical Size</th></tr>
    </thead>
    <tbody>
      <tr><td><code>h1</code>, <code>h2</code></td><td>600</td><td>48</td></tr>
      <tr><td><code>h3</code>, <code>h4</code></td><td>500</td><td>40</td></tr>
      <tr><td><code>button</code></td><td>Inherits text weight</td><td>24</td></tr>
      <tr><td><code>small</code>, <code>caption</code></td><td>400</td><td>20</td></tr>
    </tbody>
  </table>
</section>

<section>
  <h2>Icon Axes (Custom Properties)</h2>

  <table>
    <thead>
      <tr><th>Property</th><th>Range</th><th>Default</th><th>Effect</th></tr>
    </thead>
    <tbody>
      <tr><td><code>--vb-icon-fill</code></td><td>0&ndash;1</td><td>0</td><td>Outline to filled</td></tr>
      <tr><td><code>--vb-icon-weight</code></td><td>100&ndash;700</td><td>400</td><td>Stroke weight</td></tr>
      <tr><td><code>--vb-icon-grad</code></td><td>&minus;50&ndash;200</td><td>0</td><td>Grade (weight without spacing shift)</td></tr>
      <tr><td><code>--vb-icon-opsz</code></td><td>20&ndash;48</td><td>24</td><td>Optical size</td></tr>
    </tbody>
  </table>
</section>

<section>
  <h2>Attractor Animations</h2>
  <p>Add <code>data-vb-attract</code> to animate an icon. Animations respect <code>prefers-reduced-motion</code>.</p>

{% set attractCode %}<!-- Pulse: fill breathes 0 → 1 → 0 -->
<span class="vb-icon" data-vb-attract="pulse">notifications</span>

<!-- Beat: weight surges like a heartbeat -->
<span class="vb-icon" data-vb-attract="beat">favorite</span>

<!-- Bounce: vertical nudge, 3 times -->
<span class="vb-icon" data-vb-attract="bounce">arrow_downward</span>

<!-- Wiggle: rotation shake, suggests error -->
<span class="vb-icon" data-vb-attract="wiggle">warning</span>

<!-- Breathe: slow continuous fill oscillation -->
<span class="vb-icon" data-vb-attract="breathe">mic</span>{% endset %}

  <code-block language="html" label="Attractor patterns">{{ attractCode | escape }}</code-block>

  <table>
    <thead>
      <tr><th>Type</th><th>Meaning</th><th>Iterations</th></tr>
    </thead>
    <tbody>
      <tr><td><code>pulse</code></td><td>Something happened here</td><td>3</td></tr>
      <tr><td><code>beat</code></td><td>New/unread content</td><td>3</td></tr>
      <tr><td><code>bounce</code></td><td>Call to action</td><td>3</td></tr>
      <tr><td><code>wiggle</code></td><td>Error/warning</td><td>3</td></tr>
      <tr><td><code>breathe</code></td><td>Active/live signal</td><td>Infinite</td></tr>
    </tbody>
  </table>
</section>

<section>
  <h2>Declarative Triggers</h2>
  <p>Use <code>data-vb-attract-on</code> for event-driven attractors without JS:</p>

{% set triggerCode %}<!-- Animate when scrolled into view -->
<span class="vb-icon" data-vb-attract="pulse"
      data-vb-attract-on="visible">star</span>

<!-- Animate on hover -->
<span class="vb-icon" data-vb-attract="beat"
      data-vb-attract-on="hover">favorite</span>{% endset %}

  <code-block language="html" label="Declarative triggers">{{ triggerCode | escape }}</code-block>
</section>

<section>
  <h2>JS API</h2>

{% set jsApiCode %}import { attract, attractRandom, enableWhimsy } from 'vanilla-breeze/icons-js';

// Trigger a specific attractor
attract(document.querySelector('.vb-icon'), 'pulse');

// Random weighted attractor
attractRandom(iconElement);

// Idle whimsy mode (opt-in)
const { stop } = enableWhimsy(45000);{% endset %}

  <code-block language="js" label="JS API">{{ jsApiCode | escape }}</code-block>

  <p>Whimsy can also be enabled declaratively: <code>&lt;body data-vb-whimsy&gt;</code></p>
</section>

