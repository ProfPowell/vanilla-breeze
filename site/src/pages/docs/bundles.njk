{% set packInstallCdn %}<!-- Load core Vanilla Breeze first -->
<link rel="stylesheet" href="/cdn/vanilla-breeze.css">
<script type="module" src="/cdn/vanilla-breeze.js"></script>

<!-- Load a pack (all-in-one) -->
<link rel="stylesheet" href="/cdn/packs/retro.full.css">
<script type="module" src="/cdn/packs/retro.full.js"></script>{% endset %}

{% set packGranular %}<!-- Theme tokens only (smallest payload) -->
<link rel="stylesheet" href="/cdn/packs/retro.theme.css">

<!-- Effects only (CSS data-* animations) -->
<link rel="stylesheet" href="/cdn/packs/retro.effects.css">
<script type="module" src="/cdn/packs/retro.effects.js"></script>

<!-- Components only (web components) -->
<script type="module" src="/cdn/packs/retro.components.js"></script>{% endset %}

{% set packActivate %}import { activateBundle } from '/cdn/vanilla-breeze.js'

// Load a pack at runtime (returns a Promise)
await activateBundle('retro')

// Custom CDN path
await activateBundle('retro', { basePath: '/assets/packs' }){% endset %}

{% set layerOrder %}@layer tokens, reset, native-elements, custom-elements,
       web-components, utils,
       bundle-theme, bundle-effects, bundle-components;{% endset %}

{% set themeSelector %}/* Pack theme tokens scope to a data-theme selector */
@layer bundle-theme {
  [data-theme~="retro"] {
    --color-primary: oklch(70% 0.28 145);
    --radius-m: 2px;
    --font-mono: 'Cartridge', 'VT323', monospace;
    --ease-out: steps(4);
  }
}{% endset %}

{% set effectCss %}/* Effects use data-* attribute selectors in the effects layer */
@layer bundle-effects {
  [data-neon] {
    --vb-neon-color: var(--color-primary);
    color: var(--vb-neon-color);
    animation: vb-neon-pulse 2.5s ease-in-out infinite alternate;
  }

  [data-neon="pink"] { --vb-neon-color: oklch(68% 0.3 340); }
  [data-neon="cyan"] { --vb-neon-color: oklch(72% 0.2 200); }
}{% endset %}

{% set effectJs %}import { registerEffect } from '/cdn/vanilla-breeze.js'

registerEffect('flipboard', {
  selector: '[data-flipboard]',
  init(el)    { /* set up split-flap animation */ },
  destroy(el) { /* clean up timers and DOM */ },
  reducedMotionFallback(el) { /* static display */ },
}){% endset %}

{% set componentRegister %}import { registerComponent } from '/cdn/vanilla-breeze.js'
import { AudioPlayer } from './components/audio-player/audio-player.js'

registerComponent('audio-player', AudioPlayer, {
  bundle: 'retro',
  contract: 'audio-player',
  priority: 10,
}){% endset %}

{% set componentTokens %}/* Components consume system tokens and expose their own */
class AudioPlayer extends HTMLElement {
  static consumesTokens = ['--color-primary', '--color-surface-sunken']
  static exposesTokens  = ['--audioplayer-screen-color', '--audioplayer-bg']
}{% endset %}

{% set componentUsage %}<!-- Default tokens from active theme -->
<audio-player src="track.mp3" data-title="Demo"></audio-player>

<!-- Override tokens inline -->
<audio-player src="track.mp3"
  style="--audioplayer-screen-color: oklch(72% 0.3 340);">
</audio-player>

<!-- Mini form factor -->
<audio-player src="track.mp3" data-size="mini" data-title="Compact">
</audio-player>{% endset %}

{% set directoryStructure %}src/packs/retro/
  retro.theme.css          # Token overrides (@layer bundle-theme)
  retro.effects.css        # CSS data-* effects (@layer bundle-effects)
  retro.effects.js         # JS effects (registerEffect calls)
  retro.components.js      # Component registration (registerComponent calls)
  retro.bundle.js          # Pack manifest metadata
  fonts/                   # Pack-specific assets
    Cartridge-Regular.woff2
    Cartridge-Bold.woff2
  components/
    audio-player/
      audio-player.js      # Web component class
      audio-player.contract.md{% endset %}

{% set buildOutput %}dist/cdn/packs/
  manifest.json            # Registry of all built packs
  retro.theme.css          # Theme tokens only
  retro.effects.css        # Effects CSS only
  retro.effects.js         # Effects JS only
  retro.components.js      # Components JS only
  retro.full.css           # Theme + effects CSS combined
  retro.full.js            # Effects + components JS combined
  retro.bundle.js          # Pack manifest
  retro/fonts/             # Copied assets{% endset %}

<h1>Packs</h1>
<p class="lead">A pack is a self-contained extension package that adds features or a coherent aesthetic identity to Vanilla Breeze. Packs come in two flavours: <strong>functional packs</strong> (ui, effects, prototype) that group related features, and <strong>aesthetic packs</strong> (retro, kawaii) that bundle themed tokens, CSS effects, and web components sharing one design language.</p>

