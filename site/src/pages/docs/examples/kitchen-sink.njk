        <map-area shape="rect" coords="5 8 40 44" label="Conference Hall">
          <strong>Conference Hall</strong>
          <p>Seats 120 people. AV equipment available.</p>
        </map-area>
        <map-area shape="circle" coords="62.5 32 10" label="Server Room">
          <strong>Server Room</strong>
          <p>24 racks, climate controlled.</p>
        </map-area>
        <map-area shape="rect" coords="60 56 95 92" label="Open Office">
          <strong>Open Office</strong>
          <p>Hot-desking area with 80 workstations.</p>
