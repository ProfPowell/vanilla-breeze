        </layout-stack>
        <layout-stack data-layout-gap="m">
          <strong>Bordered + Single-open</strong>
          <accordion-wc bordered single>
            <details name="ks-bordered-faq" open>
              <summary>Bordered Style</summary>
              <div><p>The bordered variant adds a container border and dividers between items.</p></div>
            </details>
            <details name="ks-bordered-faq">
              <summary>Single Open Mode</summary>
              <div><p>Only one panel can be open at a time.</p></div>
            </details>
          </accordion-wc>
        </layout-stack>
      </layout-grid>
    </layout-stack>

    {# --- dialog (trimmed to 2 dialogs) --- #}
