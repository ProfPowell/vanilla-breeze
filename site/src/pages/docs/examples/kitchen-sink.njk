<script type="module" src="https://unpkg.com/invokers-polyfill"></script>

<script type="module">
  // Toast demos
  const mainToast = document.getElementById('ks-main-toast');

  document.getElementById('ks-toast-info')?.addEventListener('click', () => {
    mainToast.show({ message: 'This is an informational message.', variant: 'info' });
  });

  document.getElementById('ks-toast-success')?.addEventListener('click', () => {
    mainToast.show({ message: 'Operation completed successfully!', variant: 'success' });
  });

  document.getElementById('ks-toast-warning')?.addEventListener('click', () => {
    mainToast.show({ message: 'Please review before continuing.', variant: 'warning' });
  });

  document.getElementById('ks-toast-error')?.addEventListener('click', () => {
    mainToast.show({ message: 'Something went wrong. Please try again.', variant: 'error' });
  });

  // Canvas demo
  const canvas = document.getElementById('ks-canvas-1');
  if (canvas) {
    const ctx = canvas.getContext('2d');
    ctx.fillStyle = '#4a90d9';
    ctx.fillRect(20, 20, 160, 110);
    ctx.fillStyle = 'white';
    ctx.font = '14px system-ui';
    ctx.textAlign = 'center';
    ctx.fillText('Canvas Demo', 100, 80);
  }

  // Command palette trigger
  document.getElementById('ks-cmd-trigger')?.addEventListener('click', () => {
    const palette = document.getElementById('ks-cmd-palette');
    if (palette?.open) palette.open();
  });
</script>

