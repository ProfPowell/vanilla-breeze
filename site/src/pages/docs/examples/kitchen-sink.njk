            <p>The default dialog with Invokers API for declarative open/close.</p>
            <ul>
              <li>Press ESC to close</li>
              <li>Animated transitions</li>
              <li>Automatic focus management</li>
            </ul>
          </layout-stack>
        </section>
        <footer>
          <button type="button" class="secondary" commandfor="ks-dialog-m" command="close">Cancel</button>
          <button type="button" commandfor="ks-dialog-m" command="close">Confirm</button>
        </footer>
      </dialog>

      <dialog id="ks-dialog-form" data-no-backdrop-close>
