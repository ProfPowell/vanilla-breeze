              <p class="demo-box">Item 1</p>
              <p class="demo-box">Item 2</p>
              <p class="demo-box">Item 3</p>
            </layout-stack>
          </layout-stack>
        </layout-card>
        <layout-card data-variant="outlined">
          <layout-stack data-layout-gap="xs">
            <strong>gap="m"</strong>
            <layout-stack data-layout-gap="m">
              <p class="demo-box">Item 1</p>
              <p class="demo-box">Item 2</p>
              <p class="demo-box">Item 3</p>
            </layout-stack>
          </layout-stack>
        </layout-card>
        <layout-card data-variant="outlined">
          <layout-stack data-layout-gap="xs">
            <strong>gap="xl"</strong>
            <layout-stack data-layout-gap="xl">
              <p class="demo-box">Item 1</p>
              <p class="demo-box">Item 2</p>
              <p class="demo-box">Item 3</p>
            </layout-stack>
          </layout-stack>
        </layout-card>
      </layout-grid>
    </layout-stack>

    {# --- layout-cluster --- #}
    <layout-stack data-layout-gap="l">
      <h3 id="cluster">layout-cluster</h3>
      <p>Horizontal flex layout with wrapping.</p>
      <layout-cluster data-layout-gap="m">
        <p class="demo-box">Item 1</p>
        <p class="demo-box">Item 2</p>
        <p class="demo-box">Item 3</p>
        <p class="demo-box">Item 4</p>
        <p class="demo-box">Item 5</p>
      </layout-cluster>
      <layout-cluster data-layout-gap="m" data-layout-justify="between">
        <p class="demo-box">Start</p>
