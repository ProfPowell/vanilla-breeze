<section id="forms" class="demo-section">
  <layout-stack data-layout-gap="xl">
    <h2>Form Controls</h2>

    <layout-stack data-layout-gap="l" style="max-inline-size: 30rem;">
      <h3>Text Inputs</h3>
      <form-field>
        <label for="ks-text">Text Input</label>
        <input type="text" id="ks-text" placeholder="Enter some text..." />
      </form-field>

      <form-field>
        <label for="ks-email">Email Input</label>
        <input type="email" id="ks-email" placeholder="you@example.com" />
      </form-field>

      <form-field>
        <label for="ks-select">Select</label>
        <select id="ks-select">
          <option>Option 1</option>
          <option>Option 2</option>
          <option>Option 3</option>
        </select>
      </form-field>

      <form-field>
        <label for="ks-textarea">Textarea</label>
        <textarea id="ks-textarea" placeholder="Enter a longer message..."></textarea>
      </form-field>
    </layout-stack>

    <layout-stack data-layout-gap="l">
      <h3>Checkbox &amp; Radio</h3>
      <layout-grid data-layout-min="15rem" data-layout-gap="l">
        <layout-stack data-layout-gap="s">
          <strong>Checkboxes</strong>
          <label><input type="checkbox" name="ks-cb" value="a"/> Unchecked</label>
          <label><input type="checkbox" name="ks-cb" value="b" checked/> Checked</label>
          <label><input type="checkbox" name="ks-cb" value="c" disabled/> Disabled</label>
          <label><input type="checkbox" name="ks-cb" value="d" checked disabled/> Checked + Disabled</label>
        </layout-stack>

        <fieldset>
          <legend>Radio Buttons</legend>
          <layout-stack data-layout-gap="s">
            <label><input type="radio" name="ks-radio" value="a" checked/> Option A</label>
            <label><input type="radio" name="ks-radio" value="b"/> Option B</label>
            <label><input type="radio" name="ks-radio" value="c"/> Option C</label>
            <label><input type="radio" name="ks-radio" value="d" disabled/> Disabled</label>
          </layout-stack>
        </fieldset>
      </layout-grid>
    </layout-stack>

    <layout-stack data-layout-gap="l">
      <h3>data-switch</h3>
      <p>Toggle switches in three sizes.</p>
      <layout-stack data-layout-gap="s">
        <label><input type="checkbox" data-switch="sm" name="ks-sw1"/> Small switch</label>
        <label><input type="checkbox" data-switch name="ks-sw2" checked/> Default switch</label>
        <label><input type="checkbox" data-switch="lg" name="ks-sw3"/> Large switch</label>
      </layout-stack>
    </layout-stack>

    <layout-stack data-layout-gap="l" style="max-inline-size: 30rem;">
      <h3>data-range</h3>
      <p>Enhanced range slider with value bubble.</p>
      <form-field>
        <label for="ks-range">Volume</label>
        <input type="range" id="ks-range" min="0" max="100" value="50" data-range data-bubble data-suffix="%">
      </form-field>
    </layout-stack>

    <layout-stack data-layout-gap="l" style="max-inline-size: 30rem;">
      <h3>data-stepper</h3>
      <p>Number input with increment/decrement buttons.</p>
      <form-field>
        <label for="ks-stepper">Quantity</label>
        <input type="number" id="ks-stepper" min="0" max="50" step="1" value="1" data-stepper>
      </form-field>
    </layout-stack>

    <layout-stack data-layout-gap="l" style="max-inline-size: 30rem;">
      <h3>data-color</h3>
      <p>Enhanced color picker with swatch and hex display.</p>
      <form-field>
        <label for="ks-color">Brand Color</label>
        <input type="color" id="ks-color" name="brand" value="#6366f1" data-color>
      </form-field>
    </layout-stack>

    <layout-stack data-layout-gap="l" style="max-inline-size: 30rem;">
      <h3>data-upload</h3>
      <p>File upload with drag-and-drop zone.</p>
      <form-field>
        <label for="ks-upload">Attachments</label>
        <input type="file" id="ks-upload" name="files" data-upload accept=".pdf,.doc,.docx,image/*" multiple>
      </form-field>
    </layout-stack>

    <layout-stack data-layout-gap="l">
      <h3>data-toggle-tags</h3>
      <p>Pill-style tag selection.</p>
      <fieldset data-toggle-tags>
        <legend>Favorite Topics</legend>
        <label><input type="checkbox" name="ks-topics" value="html"/> HTML</label>
        <label><input type="checkbox" name="ks-topics" value="css" checked/> CSS</label>
        <label><input type="checkbox" name="ks-topics" value="js"/> JavaScript</label>
        <label><input type="checkbox" name="ks-topics" value="a11y"/> Accessibility</label>
        <label><input type="checkbox" name="ks-topics" value="perf"/> Performance</label>
      </fieldset>
    </layout-stack>

    <layout-stack data-layout-gap="l" style="max-inline-size: 30rem;">
      <h3>data-accept &amp; data-mask</h3>
      <layout-grid data-layout-min="14rem" data-layout-gap="m">
        <form-field>
          <label for="ks-accept-phone">Phone (accept)</label>
          <input type="text" id="ks-accept-phone" data-accept="phone" placeholder="+1 (555) 123-4567">
        </form-field>
        <form-field>
          <label for="ks-mask-date">Date (mask)</label>
          <input type="text" id="ks-mask-date" data-mask="date" placeholder="MM/DD/YYYY">
        </form-field>
      </layout-grid>
    </layout-stack>

    <layout-stack data-layout-gap="l" style="max-inline-size: 30rem;">
      <h3>Customizable Select</h3>
      <p>Uses <code>appearance: base-select</code> in supporting browsers (Chrome 135+).</p>
      <form-field>
        <label for="ks-custom-select">Choose a fruit</label>
        <select id="ks-custom-select">
          <option value="">Select...</option>
          <option value="apple">Apple</option>
          <option value="banana">Banana</option>
          <option value="cherry">Cherry</option>
          <option value="mango">Mango</option>
        </select>
      </form-field>
    </layout-stack>

    <layout-stack data-layout-gap="l">
      <h3>star-rating</h3>
      <p>Interactive star rating. Falls back to radio buttons.</p>
      <star-rating>
        <fieldset>
          <legend>Rating</legend>
          <label><input type="radio" name="ks-rating" value="1"> 1 star</label>
          <label><input type="radio" name="ks-rating" value="2"> 2 stars</label>
          <label><input type="radio" name="ks-rating" value="3" checked> 3 stars</label>
          <label><input type="radio" name="ks-rating" value="4"> 4 stars</label>
          <label><input type="radio" name="ks-rating" value="5"> 5 stars</label>
        </fieldset>
      </star-rating>
    </layout-stack>

    <layout-stack data-layout-gap="l" style="max-inline-size: 30rem;">
      <h3>combo-box</h3>
      <p>Enhanced autocomplete. Falls back to native datalist.</p>
      <combo-box>
        <label for="ks-combo">Country</label>
        <input type="text" id="ks-combo" list="ks-combo-list" placeholder="Start typing...">
        <datalist id="ks-combo-list">
          <option value="Australia"></option>
          <option value="Brazil"></option>
          <option value="Canada"></option>
          <option value="France"></option>
          <option value="Germany"></option>
          <option value="Japan"></option>
          <option value="United Kingdom"></option>
          <option value="United States"></option>
        </datalist>
      </combo-box>
    </layout-stack>

    <layout-stack data-layout-gap="l">
      <h3>Form Layouts</h3>
      <layout-grid data-layout-min="20rem" data-layout-gap="xl">
        <layout-card data-variant="outlined">
          <layout-stack data-layout-gap="s">
            <strong>.stacked</strong>
            <form class="stacked">
              <form-field>
                <label for="ks-stacked-name">Name</label>
                <input type="text" id="ks-stacked-name" placeholder="Your name" />
              </form-field>
              <form-field>
                <label for="ks-stacked-email">Email</label>
                <input type="email" id="ks-stacked-email" placeholder="you@example.com" />
              </form-field>
              <div class="actions actions-end">
                <button type="button" class="secondary">Cancel</button>
                <button type="submit">Submit</button>
              </div>
            </form>
          </layout-stack>
        </layout-card>

        <layout-card data-variant="outlined">
          <layout-stack data-layout-gap="s">
            <strong>.inline</strong>
            <form class="inline">
              <form-field>
                <label for="ks-inline-search">Search</label>
                <input type="search" id="ks-inline-search" placeholder="Search..." />
              </form-field>
              <button type="submit">Go</button>
            </form>
          </layout-stack>
        </layout-card>
      </layout-grid>
    </layout-stack>

    <layout-stack data-layout-gap="l">
      <h3>Fieldset</h3>
      <fieldset style="max-inline-size: 30rem;">
        <legend>Account Details</legend>
        <layout-stack data-layout-gap="s">
          <form-field>
            <label for="ks-field-1">Username</label>
            <input type="text" id="ks-field-1" />
          </form-field>
          <form-field>
            <label for="ks-field-2">Password</label>
            <input type="password" id="ks-field-2" />
          </form-field>
        </layout-stack>
      </fieldset>
    </layout-stack>
  </layout-stack>
</section>

