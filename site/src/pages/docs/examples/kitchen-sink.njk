      <h3>Gray Scale</h3>
      <color-palette
        colors="oklch(10% 0 0),oklch(15% 0 0),oklch(25% 0 0),oklch(35% 0 0),oklch(45% 0 0),oklch(55% 0 0),oklch(70% 0 0),oklch(80% 0 0),oklch(90% 0 0),oklch(96% 0 0),oklch(98% 0 0)"
