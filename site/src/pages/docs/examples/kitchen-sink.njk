   4. Buttons & Actions
   ================================================================ #}

<section id="buttons" class="demo-section">
  <layout-stack data-layout-gap="xl">
    <h2>Buttons &amp; Actions</h2>

    <layout-stack data-layout-gap="l">
      <layout-stack data-layout-gap="s">
        <h3>Variants</h3>
        <layout-cluster data-layout-gap="m">
          <button type="button">Primary</button>
          <button type="button" class="secondary">Secondary</button>
          <button type="button" class="ghost">Ghost</button>
          <button type="button" disabled>Disabled</button>
        </layout-cluster>
      </layout-stack>

      <layout-stack data-layout-gap="s">
        <h3>Sizes</h3>
        <layout-cluster data-layout-gap="m" data-layout-align="center">
          <button type="button" class="small">Small</button>
          <button type="button">Default</button>
          <button type="button" class="large">Large</button>
        </layout-cluster>
      </layout-stack>

      <layout-stack data-layout-gap="s">
        <h3>slide-accept</h3>
        <p>Slide-to-confirm interaction. Falls back to checkbox without JS.</p>
        <slide-accept style="max-inline-size: 24rem;">
          <fieldset>
            <label>
              <input type="checkbox" name="ks-confirm" required>
              I confirm this action
            </label>
          </fieldset>
        </slide-accept>
      </layout-stack>

      <layout-stack data-layout-gap="s">
        <h3>share-wc</h3>
        <p>Share buttons with Web Share API integration.</p>
        <share-wc>
          <nav aria-label="Share this page">
            <ul>
              <li><a href="https://x.com/intent/post?url={url}&amp;text={text}" target="_blank" rel="noopener noreferrer">Share on X</a></li>
              <li><a href="https://www.linkedin.com/sharing/share-offsite/?url={url}" target="_blank" rel="noopener noreferrer">Share on LinkedIn</a></li>
              <li><a href="mailto:?subject={title}&amp;body={url}">Share via Email</a></li>
            </ul>
          </nav>
        </share-wc>
      </layout-stack>
    </layout-stack>
  </layout-stack>
</section>

