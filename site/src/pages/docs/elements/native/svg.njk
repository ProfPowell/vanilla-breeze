    <h3>currentColor Pattern</h3>
    <p>Use <code>currentColor</code> in your SVG to inherit the CSS color property. This allows icons to match surrounding text.</p>
    <code-block language="html" label="currentColor pattern">{{ currentColorPatternCode | escape }}</code-block>
  </section>

  <section>
