{% set basicSvgCode %}<svg class="m currentcolor" viewBox="0 0 24 24">
  <!-- SVG content -->
</svg>{% endset %}

{% set colorExamplesCode %}<!-- Inherit text color -->
<svg class="m currentcolor">...</svg>

<!-- Interactive/primary color -->
<svg class="m interactive">...</svg>

<!-- Muted/secondary color -->
<svg class="m muted">...</svg>{% endset %}

{% set currentColorPatternCode %}<!-- SVG uses currentColor for stroke -->
<svg viewBox="0 0 24 24" class="m">
  <path stroke="currentColor" fill="none" d="..." />
</svg>

<!-- Or use the .currentcolor class for fill -->
<svg viewBox="0 0 24 24" class="m currentcolor">
  <path d="..." />
</svg>{% endset %}

{% set spinAnimationCode %}<!-- Spinning loader -->
<svg class="m spin currentcolor" viewBox="0 0 24 24">
  <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor"
          stroke-width="2" stroke-dasharray="30 60" />
</svg>

<!-- Pulsing indicator -->
<svg class="m pulse currentcolor" viewBox="0 0 24 24">
  <circle cx="12" cy="12" r="10" fill="currentColor" />
</svg>{% endset %}

{% set reducedMotionCode %}@media (prefers-reduced-motion: reduce) {
  svg.spin,
  svg.pulse {
    animation: none;
  }
}{% endset %}

{% set responsiveSvgCode %}<!-- Full-width responsive SVG -->
<svg class="full" viewBox="0 0 400 100" preserveAspectRatio="xMidYMid meet">
  <!-- SVG content scales to container -->
</svg>

<!-- Responsive SVG maintaining aspect ratio -->
<svg class="responsive" viewBox="0 0 800 600">
  <!-- Content -->
</svg>{% endset %}

{% set decorativeIconCode %}<svg aria-hidden="true" class="m currentcolor" viewBox="0 0 24 24">
  <!-- Icon content -->
</svg>{% endset %}

{% set informativeIconCode %}<!-- Method 1: title element -->
<svg role="img" class="m" viewBox="0 0 24 24">
  <title>Warning</title>
  <path d="..." />
</svg>

<!-- Method 2: aria-label -->
<svg aria-label="Error" role="img" class="m" viewBox="0 0 24 24">
  <path d="..." />
</svg>{% endset %}

{% set interactiveIconCode %}<!-- Button with icon -->
<button type="button" aria-label="Close dialog">
  <svg aria-hidden="true" class="m" viewBox="0 0 24 24">
    <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
  </svg>
</button>

<!-- Link with icon and text -->
<a href="/settings">
  <svg aria-hidden="true" class="s" viewBox="0 0 24 24">...</svg>
  Settings
</a>{% endset %}

<section>
    <h2>Description</h2>
    <p>The <code>&lt;svg&gt;</code> element embeds Scalable Vector Graphics directly in HTML. SVG is resolution-independent, accessible, and styleable with CSS. Vanilla Breeze provides size classes, color variants, and animation utilities for inline SVG.</p>
    <p>Unlike raster images, SVG scales to any size without quality loss, making it ideal for icons, logos, and illustrations.</p>
  </section>

  <section>
    <h2>When to Use</h2>
    <ul>
      <li><strong>Icons</strong> - UI icons that need to scale and change color</li>
      <li><strong>Logos</strong> - Brand marks that must be crisp at any size</li>
      <li><strong>Illustrations</strong> - Vector artwork and diagrams</li>
      <li><strong>Charts</strong> - Accessible data visualizations</li>
      <li><strong>Animations</strong> - Animated graphics via CSS or SMIL</li>
    </ul>

    <h3>When to Use Other Elements</h3>
    <ul>
      <li>Use <a href="/docs/elements/native/img/"><code>&lt;img&gt;</code></a> for photographs and complex raster images</li>
      <li>Use <a href="/docs/elements/native/picture/"><code>&lt;picture&gt;</code></a> for responsive raster images with multiple sources</li>
      <li>Use <a href="/docs/elements/native/canvas/"><code>&lt;canvas&gt;</code></a> for dynamic, pixel-based graphics</li>
      <li>Use <a href="/docs/elements/web-components/icons/"><code>&lt;icon-wc&gt;</code></a> for the icon component with sprite support</li>
    </ul>
  </section>

  <section>
