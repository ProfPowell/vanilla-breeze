    <p>Vanilla Breeze applies these styles to rows within tbody:</p>

    <code-block language="css" label="VB tbody CSS">{{ tbodyCss | escape }}</code-block>

    <table class="props-table">
      <thead>
        <tr>
          <th scope="col">Selector</th>
          <th scope="col">Property</th>
          <th scope="col">Purpose</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>tbody tr:hover</code></td>
