    srclang="en"
    label="English captions"
    default />

  <!-- Subtitles (spoken content only) -->
  <track
    kind="subtitles"
    src="subtitles-es.vtt"
    srclang="es"
    label="Spanish subtitles" />
</video>{% endset %}

