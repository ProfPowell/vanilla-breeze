{% set defaultMenuCode %}<menu>
  <li><button type="button">Action 1</button></li>
  <li><button type="button">Action 2</button></li>
  <li><button type="button">Action 3</button></li>
</menu>{% endset %}

{% set toolbarMenuCode %}<menu class="toolbar">
  <li><button type="button" class="ghost">Bold</button></li>
  <li><button type="button" class="ghost">Italic</button></li>
  <li><button type="button" class="ghost">Underline</button></li>
  <li><button type="button" class="ghost">Link</button></li>
</menu>{% endset %}

{% set contextMenuCode %}<menu class="context">
  <li><button type="button">Cut</button></li>
  <li><button type="button">Copy</button></li>
  <li><button type="button">Paste</button></li>
  <li role="separator"></li>
  <li><button type="button">Select All</button></li>
</menu>{% endset %}

{% set verticalMenuCode %}<menu class="vertical">
  <li><button type="button" class="ghost">Dashboard</button></li>
  <li><button type="button" class="ghost">Projects</button></li>
  <li><button type="button" class="ghost">Tasks</button></li>
  <li><button type="button" class="ghost">Settings</button></li>
</menu>{% endset %}

{% set iconToolbarCode %}<menu class="toolbar icons">
  <li>
    <button type="button" class="ghost" aria-label="Bold">
      <svg ...>...</svg>
    </button>
  </li>
  ...
</menu>{% endset %}

{% set pillsMenuCode %}<menu class="toolbar pills">
  <li><button type="button" class="ghost">All</button></li>
  <li><button type="button">Active</button></li>
  <li><button type="button" class="ghost">Completed</button></li>
</menu>{% endset %}

{% set menuCssCode %}menu {
  display: flex;
  flex-wrap: wrap;
  gap: var(--size-xs);
  margin: 0;
  padding: 0;
  list-style: none;

  & > li {
    margin: 0;
  }
}

/* Toolbar variant */
menu.toolbar {
  display: flex;
  align-items: center;
  gap: var(--size-2xs);
  padding: var(--size-2xs);
  background: var(--color-surface-raised);
  border-radius: var(--radius-m);
}

/* Context menu variant */
menu.context {
  flex-direction: column;
  gap: 0;
  padding: var(--size-2xs);
  background: var(--color-surface);
  border: var(--border-width-thin) solid var(--color-border);
  border-radius: var(--radius-m);
  box-shadow: 0 4px 12px oklch(0% 0 0 / 0.15);
  min-inline-size: 160px;
}{% endset %}

{% set iconButtonCode %}<button type="button" class="ghost" aria-label="Bold">
  <svg ...>...</svg>
</button>{% endset %}

<section>
    <h2>Description</h2>
    <p>The <code>&lt;menu&gt;</code> element represents a group of commands or options. It is semantically equivalent to <code>&lt;ul&gt;</code> but signals to assistive technologies that the items represent commands rather than list content.</p>

    <p>In Vanilla Breeze, <code>&lt;menu&gt;</code> is styled as a flexible container with variants for toolbars, context menus, vertical menus, and icon button groups.</p>
  </section>

  <section>
    <h2>When to Use</h2>
    <ul>
      <li><strong>Toolbars:</strong> Groups of action buttons in editors or applications</li>
      <li><strong>Context menus:</strong> Dropdown menus with actions</li>
      <li><strong>Action lists:</strong> Vertical lists of commands</li>
      <li><strong>Button groups:</strong> Related buttons that function as a unit</li>
      <li><strong>Filter controls:</strong> Pill-style toggles for filtering content</li>
    </ul>

    <h3>When Not to Use</h3>
    <ul>
      <li>For navigation links &mdash; use <a href="/docs/elements/native/nav/"><code>&lt;nav&gt;</code></a></li>
      <li>For content lists &mdash; use <a href="/docs/elements/native/ul/"><code>&lt;ul&gt;</code></a> or <a href="/docs/elements/native/ol/"><code>&lt;ol&gt;</code></a></li>
      <li>For dropdown selection &mdash; use <code>&lt;select&gt;</code></li>
      <li>For full dropdown components &mdash; use <a href="/docs/elements/custom-elements/drop-down/"><code>&lt;drop-down&gt;</code></a></li>
    </ul>
  </section>

