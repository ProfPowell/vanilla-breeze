  <!-- Accessibility Section -->
  <section>
    <h2 id="accessibility">Accessibility</h2>
    <ul>
      <li><strong>Screen readers</strong> read the visible text content (the human-readable part)</li>
      <li><strong>Machine parsing</strong> — the <code>datetime</code> attribute enables assistive technologies to parse dates accurately</li>
      <li><strong>Timezone clarity</strong> — include timezone information when relevant to avoid ambiguity</li>
      <li><strong>Relative times</strong> — update dynamically via JavaScript or provide the actual date as fallback</li>
    </ul>
  </section>

