  <!-- datetime Attribute Formats Section -->
  <section>
    <h2 id="datetime-formats">datetime Attribute Formats</h2>
    <p>The <code>datetime</code> attribute uses ISO 8601 format:</p>

    <table class="props-table">
      <thead>
        <tr>
          <th>Format</th>
          <th>Example</th>
          <th>Represents</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>YYYY</code></td>
          <td><code>2026</code></td>
          <td>Year</td>
        </tr>
        <tr>
          <td><code>YYYY-MM</code></td>
          <td><code>2026-01</code></td>
          <td>Month</td>
        </tr>
        <tr>
          <td><code>YYYY-MM-DD</code></td>
          <td><code>2026-01-15</code></td>
          <td>Date</td>
        </tr>
        <tr>
          <td><code>HH:MM</code></td>
          <td><code>14:30</code></td>
          <td>Time</td>
        </tr>
        <tr>
          <td><code>YYYY-MM-DDTHH:MM</code></td>
          <td><code>2026-01-15T14:30</code></td>
          <td>Date and time</td>
        </tr>
        <tr>
          <td><code>YYYY-MM-DDTHH:MM:SS</code></td>
          <td><code>2026-01-15T14:30:00</code></td>
          <td>With seconds</td>
        </tr>
        <tr>
          <td><code>...Z</code></td>
          <td><code>2026-01-15T14:30:00Z</code></td>
          <td>UTC timezone</td>
        </tr>
        <tr>
          <td><code>...+HH:MM</code></td>
          <td><code>2026-01-15T14:30:00+05:30</code></td>
          <td>With timezone offset</td>
        </tr>
        <tr>
          <td><code>PTXHXMXS</code></td>
          <td><code>PT2H30M</code></td>
          <td>Duration</td>
        </tr>
      </tbody>
    </table>
  </section>

