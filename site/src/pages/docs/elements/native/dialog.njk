{% set invokersApiCode %}<!-- Trigger button -->
<button commandfor="my-dialog" command="show-modal">Open Dialog</button>

<!-- Dialog -->
<dialog id="my-dialog">
  <header>
    <h3>Dialog Title</h3>
  </header>
  <p>Content goes here.</p>
  <footer>
    <button commandfor="my-dialog" command="close">Close</button>
  </footer>
</dialog>{% endset %}

{% set polyfillCode %}<script type="module" src="https://unpkg.com/invokers-polyfill"></script>{% endset %}

{% set jsApiCode %}// Open as modal
document.getElementById('my-dialog').showModal();

// Close
document.getElementById('my-dialog').close();{% endset %}

{% set formMethodDialogCode %}<dialog id="choice-dialog">
  <form method="dialog">
    <header><h3>Choose</h3></header>
    <p>Select your preference:</p>
    <footer>
      <button type="submit" value="cancel">Cancel</button>
      <button type="submit" value="confirm">Confirm</button>
    </footer>
  </form>
</dialog>

<script>
const dialog = document.getElementById('choice-dialog');
dialog.addEventListener('close', () => {
  console.log('User chose:', dialog.returnValue);
  // "cancel" or "confirm"
});
</script>{% endset %}

{% set dialogStructureCode %}<dialog>
  <header>
    <h3>Dialog Title</h3>
  </header>

  <!-- Main content -->
  <p>Dialog content goes here.</p>

  <footer>
    <button type="button" class="secondary">Cancel</button>
    <button type="button">Confirm</button>
  </footer>
</dialog>{% endset %}

{% set dialogCssCode %}dialog {
  max-inline-size: min(90vw, 32rem);
  max-block-size: 85dvh;
  border: none;
  border-radius: var(--radius-l);
  background: var(--color-surface);
  color: var(--color-text);
  box-shadow: /* multi-layer elevation shadow */;
  overflow: hidden;
}

dialog > header {
  padding: var(--size-m) var(--size-l);
  border-block-end: 1px solid var(--color-border);
}

dialog > :is(p, section, form) {
  padding: var(--size-l);
}

dialog > footer {
  padding: var(--size-m) var(--size-l);
  border-block-start: 1px solid var(--color-border);
  display: flex;
  flex-wrap: wrap;
  gap: var(--size-s);
  justify-content: flex-end;
}{% endset %}

{% set backdropStylingCode %}dialog::backdrop {
  background: oklch(0% 0 0 / 0.5);
  backdrop-filter: blur(2px);
}{% endset %}

{% set dialogAnimationCode %}/* Entry animation with @starting-style */
dialog[open] {
  opacity: 1;
  transform: scale(1);
  transition:
    opacity var(--motion-enter-duration) var(--ease-out),
    transform var(--motion-enter-duration) var(--ease-out),
    display var(--motion-enter-duration) allow-discrete,
    overlay var(--motion-enter-duration) allow-discrete;
}

@starting-style {
  dialog[open] {
    opacity: 0;
    transform: scale(0.9);
  }
}

/* Fallback keyframe animation */
dialog[open] {
  animation: vb-scale-in var(--motion-enter-duration) var(--ease-out);
}

@media (prefers-reduced-motion: reduce) {
  dialog[open] { animation: none; transition: none; }
}{% endset %}

{% set dialogJsApiCode %}const dialog = document.querySelector('dialog');

// Open as modal
dialog.showModal();

// Listen for close
dialog.addEventListener('close', () => {
  console.log('Closed with:', dialog.returnValue);
});

// Prevent ESC from closing
dialog.addEventListener('cancel', (event) => {
  event.preventDefault();
});{% endset %}

{% set backdropCloseCode %}// Optional: close on backdrop click
document.querySelectorAll('dialog').forEach(dialog => {
  dialog.addEventListener('click', e => {
    if (e.target === dialog) dialog.close();
  });
});{% endset %}

{% set drawerCode %}<!-- Right drawer -->
<button commandfor="nav-drawer" command="show-modal">Menu</button>

<dialog id="nav-drawer" data-position="end">
  <header><h3>Navigation</h3></header>
  <section>
    <nav>...</nav>
  </section>
  <footer>
    <button commandfor="nav-drawer" command="close">Close</button>
  </footer>
</dialog>{% endset %}

{% set drawerAnimationCode %}/* Drawers use directional slide-in animations */
@keyframes vb-slide-in-end {
  from { transform: translateX(100%); opacity: 0; }
  to   { transform: translateX(0);    opacity: 1; }
}

@keyframes vb-slide-in-bottom {
  from { transform: translateY(100%); opacity: 0; }
  to   { transform: translateY(0);    opacity: 1; }
}

/* Reduced motion: fade instead of slide */
@media (prefers-reduced-motion: reduce) {
  dialog[data-position][open] {
    animation: vb-fade-in var(--motion-enter-duration) var(--ease-out);
  }
}{% endset %}

{% set printCode %}/* Print: dialogs are hidden entirely */
@media print {
  dialog { display: none; }
}{% endset %}

<section>
    <h2>Description</h2>
    <p>The <code>&lt;dialog&gt;</code> element provides a native way to create modal dialogs, confirmation prompts, and slide-in drawer panels. It handles complex accessibility requirements automatically: focus trapping, ESC to close, <code>role="dialog"</code>, and inert background.</p>

    <p>There are two ways to open a dialog:</p>
    <ul>
      <li><strong>HTML Invokers API</strong> (recommended) &mdash; <code>command="show-modal"</code> / <code>command="close"</code></li>
      <li><strong>JavaScript</strong> &mdash; <code>showModal()</code> / <code>show()</code> / <code>close()</code></li>
    </ul>

    <p>In Vanilla Breeze, dialogs also serve as drawer panels via <code>data-position</code>, and are used internally by web components like <a href="/docs/elements/custom-elements/command-palette/"><code>&lt;command-palette&gt;</code></a>, <a href="/docs/elements/custom-elements/short-cuts/"><code>&lt;short-cuts&gt;</code></a>, and <a href="/docs/elements/custom-elements/settings-panel/"><code>&lt;settings-panel&gt;</code></a>.</p>
  </section>

  <section>
    <h2>When to Use</h2>
    <ul>
      <li><strong>Confirmation dialogs:</strong> Confirm destructive actions before proceeding</li>
      <li><strong>Form dialogs:</strong> Collect user input in an overlay</li>
      <li><strong>Alert messages:</strong> Important information requiring acknowledgment</li>
      <li><strong>Media lightboxes:</strong> Images or videos in a focused overlay</li>
      <li><strong>Drawer panels:</strong> Slide-in navigation, settings, or filters (via <code>data-position</code>)</li>
    </ul>

    <h3>When Not to Use</h3>
    <ul>
      <li>For inline expandable content &mdash; use <a href="/docs/elements/native/details/"><code>&lt;details&gt;</code></a></li>
      <li>For tooltips or popovers &mdash; use <a href="/docs/elements/custom-elements/tool-tip/"><code>&lt;tool-tip&gt;</code></a></li>
      <li>For toast notifications &mdash; use <a href="/docs/elements/custom-elements/toast-msg/"><code>&lt;toast-msg&gt;</code></a></li>
      <li>For dropdown menus &mdash; use <a href="/docs/elements/custom-elements/drop-down/"><code>&lt;drop-down&gt;</code></a> or <a href="/docs/elements/custom-elements/context-menu/"><code>&lt;context-menu&gt;</code></a></li>
      <li>For non-blocking information &mdash; avoid interrupting user flow</li>
    </ul>
  </section>

  <section>
    <h2>Invokers API (Declarative)</h2>
    <p>The <a href="https://developer.mozilla.org/en-US/docs/Web/API/Invoker_Commands_API">Invokers API</a> lets you open and close dialogs with HTML attributes alone &mdash; no JavaScript required.</p>

    <browser-window src="/docs/snippets/demos/dialog-invokers.html" url="dialog-invokers.html" title="Invokers API" shadow></browser-window>

    <code-block language="html" show-lines label="Invokers API markup">{{ invokersApiCode | escape }}</code-block>

    <h3>Available Commands</h3>
    <table class="props-table">
      <thead>
        <tr>
          <th>Command</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>show-modal</code></td>
          <td>Opens dialog as modal (equivalent to <code>showModal()</code>)</td>
        </tr>
        <tr>
          <td><code>close</code></td>
          <td>Closes the dialog (equivalent to <code>close()</code>)</td>
        </tr>
        <tr>
          <td><code>request-close</code></td>
          <td>Requests closure (can be cancelled with <code>cancel</code> event)</td>
        </tr>
      </tbody>
    </table>

    <h3>Browser Support</h3>
    <p>Invokers API is supported in Chrome 135+, Edge 135+, Safari TP, and Firefox Nightly. Include the polyfill for broader support:</p>

    <code-block language="html" show-lines label="Including polyfill">{{ polyfillCode | escape }}</code-block>
  </section>

