    <browser-window src="/docs/snippets/demos/hgroup-byline.html" url="https://vanilla-breeze.dev/hgroup/byline" title="Byline hgroup" shadow></browser-window>
    <code-block language="html" label="Byline hgroup">{{ bylineCode | escape }}</code-block>

    <h3>.section-header</h3>
