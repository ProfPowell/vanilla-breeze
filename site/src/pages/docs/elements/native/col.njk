layout: layouts/element.njk
title: "col"
description: "Defines properties for a single column or a span of columns within a colgroup. Use it to set column widths, apply background colors, or highlight specific columns in a table."
elementName: col
category: native
nativeGroup: Tables
currentPath: /docs/elements/native/col/
