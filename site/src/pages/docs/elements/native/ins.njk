    <code-block language="html" show-lines label="Default ins element">{{ basicInsCode | escape }}</code-block>

    <h3>.diff</h3>
    <p>Enhanced styling for diff displays with padding and rounded corners, ideal for code comparisons.</p>
    <code-block language="html" show-lines label="Diff variant">{{ diffVariantCode | escape }}</code-block>

    <h3>Document Revision</h3>
    <p>Pair <code>&lt;ins&gt;</code> with <a href="/docs/elements/native/del/"><code>&lt;del&gt;</code></a> to show before-and-after edits in running text.</p>
    <code-block language="html" show-lines label="Revision with del + ins">{{ revisionCode | escape }}</code-block>

    <h3>Code Diff Display</h3>
    <p>Use the <code>.diff</code> class on both <code>&lt;ins&gt;</code> and <code>&lt;del&gt;</code> for compact, pill-shaped diff lines.</p>
    <code-block language="html" show-lines label="Code diff with .diff class">{{ codeDiffCode | escape }}</code-block>

    <h3>Block-Level Insertion</h3>
    <p>The <code>&lt;ins&gt;</code> element can wrap block content for multi-paragraph insertions.</p>
    <code-block language="html" show-lines label="Block-level ins">{{ blockInsCode | escape }}</code-block>
  </section>

