{% set defaultCode %}<nav aria-label="Example navigation">
  <ul>
    <li><a href="#">Home</a></li>
    <li><a href="#">Products</a></li>
    <li><a href="#">About</a></li>
    <li><a href="#">Contact</a></li>
  </ul>
</nav>{% endset %}

{% set horizontalCode %}<nav class="horizontal" aria-label="Horizontal navigation">
