    <browser-window src="/docs/snippets/demos/nav-tabs.html" url="https://vanilla-breeze.dev/nav/tabs" title="Tab nav" shadow></browser-window>
    <code-block language="html" label="Tab nav">{{ tabsCode | escape }}</code-block>

    <h3>.breadcrumb</h3>
