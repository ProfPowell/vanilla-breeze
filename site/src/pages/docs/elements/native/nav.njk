    <browser-window src="/docs/snippets/demos/nav-vertical.html" url="https://vanilla-breeze.dev/nav/vertical" title="Vertical nav" shadow></browser-window>
    <code-block language="html" label="Vertical nav">{{ verticalCode | escape }}</code-block>

