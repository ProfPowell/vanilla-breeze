    <li><a href="#">Products</a></li>
    <li><a href="#" aria-current="page">About</a></li>
    <li><a href="#">Contact</a></li>
  </ul>
</nav>{% endset %}

{% set verticalCode %}<nav class="vertical" aria-label="Sidebar navigation">
