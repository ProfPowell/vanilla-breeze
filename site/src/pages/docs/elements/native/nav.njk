    <browser-window src="/docs/snippets/demos/nav-pills.html" url="https://vanilla-breeze.dev/nav/pills" title="Pill nav" shadow></browser-window>
    <code-block language="html" label="Pill nav">{{ pillsCode | escape }}</code-block>

    <h3>.tabs</h3>
