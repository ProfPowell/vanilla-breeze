    <code-block language="html" show-lines label="Number stepper">{{ stepperCode | escape }}</code-block>

    <table class="props-table">
      <thead>
        <tr>
          <th>Attribute</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>data-stepper</code></td>
