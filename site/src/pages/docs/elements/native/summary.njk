        <tr>
          <td>Touch target</td>
          <td><code>min-block-size: var(--size-touch-min)</code></td>
          <td>44px minimum for accessibility</td>
        </tr>
        <tr>
          <td>Focus ring</td>
          <td><code>:focus-visible</code></td>
          <td>Keyboard navigation visibility</td>
        </tr>
        <tr>
          <td>Animation</td>
          <td><code>transition</code> on transform</td>
          <td>Smooth chevron rotation on open/close</td>
        </tr>
        <tr>
          <td>Marker hiding</td>
          <td><code>list-style: none</code> + <code>::-webkit-details-marker</code></td>
          <td>Cross-browser removal of native triangle</td>
        </tr>
      </tbody>
    </table>

    <h3>Context-Specific Overrides</h3>
    <p>Summary styling changes in different parent contexts:</p>
    <table class="props-table">
      <thead>
        <tr>
          <th>Context</th>
          <th>Indicator</th>
          <th>Other Changes</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>nav.tree</code></td>
          <td>+/&minus; text indicator via <code>::before</code></td>
