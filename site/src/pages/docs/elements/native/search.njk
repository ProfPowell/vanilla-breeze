    <code-block language="html" label="Simple search">{{ simpleSearchCode | escape }}</code-block>

    <h3>Search with Form</h3>
    <p>Wrap a form inside <code>&lt;search&gt;</code> for server-side search functionality.</p>
    <code-block language="html" label="Search with form">{{ searchWithFormCode | escape }}</code-block>
  </section>

