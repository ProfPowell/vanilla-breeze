<html lang="en" data-theme="ocean" data-fluid>
  <head>...</head>
  <body data-page-layout="sidebar-start">
    <header>...</header>
    <nav>...</nav>
    <main>...</main>
  </body>
</html>{% endset %}

{% set pageTypeExample %}<html lang="en" data-page="docs">{% endset %}

{% set darkModeExample %}<html lang="en" data-mode="dark">{% endset %}

{% set oceanThemeExample %}<html lang="en" data-theme="ocean">{% endset %}

{% set multiThemeExample %}<html lang="en" data-theme="ocean a11y-large-text">{% endset %}

{% set fluidExample %}<html lang="en" data-fluid>
<!-- or with a preset -->
<html lang="en" data-fluid="compact">{% endset %}

{% set combinedExample %}<html lang="en" data-page="docs" data-theme="forest" data-mode="dark" data-fluid>{% endset %}

