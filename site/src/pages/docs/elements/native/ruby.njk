      <tbody>
        <tr>
          <td><code>show</code></td>
          <td>Always visible</td>
        </tr>
        <tr>
          <td><code>hide</code></td>
          <td>Visually hidden, kept in DOM for screen readers</td>
        </tr>
        <tr>
          <td><code>auto</code></td>
          <td>Visible for CJK languages (<code>ja</code>, <code>zh</code>, <code>ko</code>), hidden otherwise</td>
        </tr>
        <tr>
