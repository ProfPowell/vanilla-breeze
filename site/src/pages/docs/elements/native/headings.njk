{% set ornamentCode %}/* Theme file — add decorative glyphs before headings */
:root {
  --heading-ornament-before: "§ ";
}

/* Per-level overrides */
:root {
  --h1-ornament-before: "❧ ";
  --h2-ornament-before: "§ ";
  --h3-ornament-before: "› ";
}{% endset %}

{% set cssCode %}h1, h2, h3, h4, h5, h6 {
  font-weight: 600;
  line-height: var(--line-height-tight);
  text-wrap: balance;
  font-variant-numeric: lining-nums;
  hyphens: none;
}

h1 {
  font-size: var(--font-size-4xl);
  letter-spacing: var(--letter-spacing-tight);
}
h2 {
  font-size: var(--font-size-3xl);
