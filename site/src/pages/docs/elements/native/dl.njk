{% set cssPropertiesCode %}dl {
  display: block;
}

dt {
  font-weight: 600;
}

dd {
  margin-inline-start: var(--size-l);
}

dd + dt {
  margin-block-start: var(--size-m);
}

/* Striped variant */
dl[data-striped] dt,
dl[data-striped] dd {
  padding-inline: var(--size-s);
  padding-block: var(--size-2xs);
}

dl[data-striped] dt:nth-of-type(odd),
dl[data-striped] dt:nth-of-type(odd) + dd {
  background: var(--color-surface-raised);
}{% endset %}

<!-- Description Section -->
  <section>
    <h2 id="description">Description</h2>
    <p>The <code>&lt;dl&gt;</code> element (description list, formerly "definition list") contains groups of terms (<a href="/docs/elements/native/dt/"><code>&lt;dt&gt;</code></a>) and their descriptions (<a href="/docs/elements/native/dd/"><code>&lt;dd&gt;</code></a>). It represents an association list of name-value pairs.</p>
    <p>Unlike <code>&lt;ul&gt;</code> and <code>&lt;ol&gt;</code>, which use <code>&lt;li&gt;</code> elements, definition lists use the <code>&lt;dt&gt;</code> and <code>&lt;dd&gt;</code> pair structure.</p>
  </section>

  <!-- When to Use Section -->
  <section>
    <h2 id="when-to-use">When to Use</h2>
    <ul>
      <li><strong>Glossaries</strong> — Terms and definitions</li>
      <li><strong>Metadata</strong> — Author, date, category displays</li>
      <li><strong>FAQ sections</strong> — Question-answer pairs</li>
      <li><strong>Product specifications</strong> — Specs and details</li>
      <li><strong>Contact information</strong> — Label-value pairs</li>
    </ul>

    <h3>When Not to Use</h3>
    <ul>
      <li>For simple sequential items — use <a href="/docs/elements/native/ol/"><code>&lt;ol&gt;</code></a></li>
      <li>For unordered collections — use <a href="/docs/elements/native/ul/"><code>&lt;ul&gt;</code></a></li>
      <li>For tabular data with multiple columns — use <code>&lt;table&gt;</code></li>
    </ul>
  </section>

  <!-- Basic Usage Section -->
  <section>
    <h2 id="basic-usage">Basic Usage</h2>
    <p>A basic definition list with single term-description pairs.</p>

    <browser-window src="/docs/snippets/demos/dl-basic.html" url="https://vanilla-breeze.dev/dl/basic" title="Basic definition list" shadow></browser-window>
    <code-block language="html" label="Basic definition list">{{ basicListCode | escape }}</code-block>
  </section>

  <!-- Multiple Descriptions Section -->
  <section>
    <h2 id="multiple-descriptions">Multiple Descriptions</h2>
    <p>A single term can have multiple descriptions. Useful for words with multiple meanings or items with several explanations.</p>

    <browser-window src="/docs/snippets/demos/dl-multiple-descriptions.html" url="https://vanilla-breeze.dev/dl/multiple-descriptions" title="Multiple descriptions" shadow></browser-window>
    <code-block language="html" label="Multiple descriptions for one term">{{ multipleDescriptionsCode | escape }}</code-block>
  </section>

  <!-- Multiple Terms Section -->
  <section>
    <h2 id="multiple-terms">Multiple Terms</h2>
    <p>Multiple terms can share a single description. Useful for synonyms, abbreviations, or alternate names.</p>

    <browser-window src="/docs/snippets/demos/dl-multiple-terms.html" url="https://vanilla-breeze.dev/dl/multiple-terms" title="Multiple terms" shadow></browser-window>
    <code-block language="html" label="Multiple terms sharing description">{{ multipleTermsCode | escape }}</code-block>
  </section>

  <!-- Metadata Display Section -->
  <section>
    <h2 id="metadata">Metadata Display</h2>
    <p>Definition lists are excellent for displaying metadata or properties in a structured way.</p>

    <browser-window src="/docs/snippets/demos/dl-metadata.html" url="https://vanilla-breeze.dev/dl/metadata" title="Metadata display" shadow></browser-window>
    <code-block language="html" label="Metadata display pattern">{{ metadataCode | escape }}</code-block>
  </section>

  <!-- Product Specs Section -->
  <section>
    <h2 id="product-specs">Product Specifications</h2>
    <p>Definition lists work well for product specs and technical details.</p>

    <browser-window src="/docs/snippets/demos/dl-specs.html" url="https://vanilla-breeze.dev/dl/specs" title="Product specifications" shadow></browser-window>
  </section>

  <!-- Striped Variant Section -->
  <section>
    <h2 id="striped">Striped Variant</h2>
    <p>Add the <code>data-striped</code> attribute for alternating row backgrounds, making it easier to scan long definition lists. This mirrors the <code>table.striped</code> pattern.</p>

    <browser-window src="/docs/snippets/demos/dl-striped.html" url="https://vanilla-breeze.dev/dl/striped" title="Striped definition list" shadow></browser-window>
    <code-block language="html" label="Striped definition list">{{ stripedCode | escape }}</code-block>
  </section>

  <!-- Comparison Section -->
  <section>
    <h2 id="comparison">Comparison: dl vs ul/ol</h2>

    <table class="props-table">
      <thead>
        <tr>
          <th>Feature</th>
          <th><code>&lt;dl&gt;</code></th>
          <th><code>&lt;ul&gt;</code>/<code>&lt;ol&gt;</code></th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Structure</td>
          <td>Term-description pairs</td>
          <td>Single items</td>
        </tr>
        <tr>
          <td>Child elements</td>
          <td><code>&lt;dt&gt;</code>, <code>&lt;dd&gt;</code></td>
          <td><code>&lt;li&gt;</code></td>
        </tr>
        <tr>
          <td>Best for</td>
          <td>Key-value data, glossaries</td>
          <td>Lists of items</td>
        </tr>
        <tr>
          <td>Markers</td>
          <td>None (styled with indentation)</td>
          <td>Bullets or numbers</td>
        </tr>
        <tr>
          <td>Order significance</td>
          <td>No</td>
          <td><code>&lt;ol&gt;</code>: yes, <code>&lt;ul&gt;</code>: no</td>
        </tr>
      </tbody>
    </table>
  </section>

  <!-- CSS Properties Section -->
  <section>
    <h2 id="css-properties">CSS Properties</h2>

    <code-block language="css" label="Definition list CSS styling">{{ cssPropertiesCode | escape }}</code-block>
  </section>

  <!-- Accessibility Section -->
  <section>
    <h2 id="accessibility">Accessibility</h2>

    <h3>Screen Reader Behavior</h3>
    <ul>
      <li>Announced as "description list" with item count</li>
      <li>Terms (<code>&lt;dt&gt;</code>) announced as labels or keys</li>
      <li>Descriptions (<code>&lt;dd&gt;</code>) announced as associated values</li>
      <li>Users can navigate between term-description groups</li>
    </ul>

    <h3>Grouping with div</h3>
    <p>HTML5 allows wrapping <code>&lt;dt&gt;</code>/<code>&lt;dd&gt;</code> pairs in <code>&lt;div&gt;</code> for styling purposes. This is especially useful with the striped variant when terms have multiple descriptions.</p>

    <code-block language="html" label="Grouping dt/dd pairs with div">{{ divGroupingCode | escape }}</code-block>
  </section>

  <!-- Related Elements Section -->
  <section>
    <h2 id="related">Related Elements</h2>
    <ul>
      <li><a href="/docs/elements/native/dt/"><code>&lt;dt&gt;</code></a> — Definition term (the key/name)</li>
      <li><a href="/docs/elements/native/dd/"><code>&lt;dd&gt;</code></a> — Definition description (the value)</li>
      <li><a href="/docs/elements/native/ul/"><code>&lt;ul&gt;</code></a> — Unordered list (for simple item collections)</li>
      <li><a href="/docs/elements/native/ol/"><code>&lt;ol&gt;</code></a> — Ordered list (for sequential items)</li>
    </ul>
  </section>
