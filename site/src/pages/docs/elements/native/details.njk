    <summary>Tab One</summary>
    <p>Panel content for the first tab.</p>
  </details>
  <details>
    <summary>Tab Two</summary>
    <p>Panel content for the second tab.</p>
  </details>
</tab-set>{% endset %}

{% set navTreeCode %}<nav class="tree" aria-label="File browser">
