{% set basicDetailsCode %}<details>
  <summary>Click to expand</summary>
  <p>This content is revealed when the details element is opened.</p>
</details>{% endset %}

{% set openDetailsCode %}<details open>
  <summary>Already expanded</summary>
  <p>This details element starts in the open state.</p>
</details>{% endset %}

{% set stackedDetailsCode %}<details>
  <summary>First item</summary>
  <p>Content for the first panel.</p>
</details>
<details>
  <summary>Second item</summary>
  <p>Content for the second panel.</p>
</details>
<details>
  <summary>Third item</summary>
  <p>Content for the third panel.</p>
</details>{% endset %}

{% set exclusiveAccordionCode %}<details name="faq-exclusive" open>
  <summary>First Question</summary>
  <p>Only one panel can be open at a time...</p>
</details>
<details name="faq-exclusive">
  <summary>Second Question</summary>
  <p>Opening this will automatically close the first panel.</p>
</details>{% endset %}

{% set accordionWcCode %}<accordion-wc>
  <details open>
    <summary>Section One</summary>
    <p>Content for the first section.</p>
  </details>
  <details>
    <summary>Section Two</summary>
    <p>Content for the second section.</p>
  </details>
</accordion-wc>{% endset %}

{% set tabSetCode %}<tab-set>
