    <code-block language="html" show-lines label="Rounded image">{{ roundedImageCode | escape }}</code-block>
    <code-block language="html" show-lines label="Circle avatar image">{{ circleAvatarCode | escape }}</code-block>
    <code-block language="html" show-lines label="Thumbnail image">{{ thumbnailImageCode | escape }}</code-block>
