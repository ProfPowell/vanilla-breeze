        </tr>
        <tr>
          <td>§</td>
          <td>Section sign</td>
          <td><code>&lt;hr data-ornament="§" /&gt;</code></td>
        </tr>
        <tr>
          <td>✦ ✦ ✦</td>
          <td>Stars</td>
          <td><code>&lt;hr data-ornament="✦ ✦ ✦" /&gt;</code></td>
        </tr>
        <tr>
