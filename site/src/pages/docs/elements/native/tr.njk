{% set basicRowCode %}<table>
  <caption>Team Members</caption>
  <thead>
    <tr>
      <th scope="col">Name</th>
      <th scope="col">Role</th>
      <th scope="col">Location</th>
    </tr>
  </thead>
  <tbody>
    <tr>
      <td>Alice Johnson</td>
      <td>Developer</td>
      <td>New York</td>
    </tr>
    <tr>
      <td>Bob Smith</td>
      <td>Designer</td>
      <td>San Francisco</td>
    </tr>
  </tbody>
</table>{% endset %}

{% set rowStatesCode %}<tbody>
  <!-- Selected row -->
  <tr data-selected>
    <td>Alice Johnson</td>
    <td>Developer</td>
    <td>New York</td>
  </tr>

  <!-- Highlighted row -->
  <tr data-highlight>
    <td>Bob Smith</td>
    <td>Designer</td>
    <td>San Francisco</td>
  </tr>

  <!-- Disabled row -->
  <tr data-disabled>
    <td>Carol Williams</td>
    <td>Manager</td>
    <td>Chicago</td>
  </tr>
</tbody>{% endset %}

{% set selectableCode %}<tbody>
  <tr data-selectable>
    <td>Row 1 — click to select</td>
    <td data-numeric>$49.99</td>
  </tr>
  <tr data-selectable data-selected>
    <td>Row 2 — already selected</td>
    <td data-numeric>$29.99</td>
  </tr>
</tbody>{% endset %}

{% set expandableCode %}<tbody>
  <tr data-expandable>
    <td>Order #1024</td>
    <td data-numeric>$149.99</td>
    <td>Shipped</td>
  </tr>
  <tr data-state-expanded>
    <td colspan="3">
      Tracking: 1Z999AA10123456784
    </td>
  </tr>

  <tr data-expandable>
    <td>Order #1025</td>
    <td data-numeric>$89.50</td>
    <td>Processing</td>
  </tr>
  <tr data-state-hidden>
    <td colspan="3">
      Estimated delivery: March 15, 2026
    </td>
  </tr>
</tbody>{% endset %}

{% set hoverCss %}/* Vanilla Breeze default — applied automatically */
tbody tr:hover {
  background: var(--color-surface-raised);
}{% endset %}

{% set rowStateCss %}/* Row state styling */
tr[data-selected] {
  background: var(--color-primary-subtle);
  outline: var(--border-width-thin) solid var(--color-primary);
}

tr[data-highlight] {
  background: var(--color-warning-subtle);
}

tr[data-disabled] {
  opacity: 0.5;
  pointer-events: none;
}

tr[data-state-hidden] {
  display: none;
}

tr[data-state-expanded] {
  background: var(--color-surface-sunken);
}{% endset %}

<section>
    <h2>Description</h2>
    <p>The <code>&lt;tr&gt;</code> (table row) element is a container for a horizontal group of cells. Each row must contain at least one <a href="/docs/elements/native/th/"><code>&lt;th&gt;</code></a> or <a href="/docs/elements/native/td/"><code>&lt;td&gt;</code></a> element, and all rows in a table should have the same number of cells (accounting for <code>colspan</code>).</p>
    <p>Vanilla Breeze applies hover effects to rows within <a href="/docs/elements/native/tbody/"><code>&lt;tbody&gt;</code></a> and provides data attributes for common row states: selection, highlighting, disabling, and expandable detail rows.</p>
  </section>

  <section>
    <h2>When to Use</h2>
    <ul>
      <li><strong>Every table row:</strong> All rows of data, headers, and footers require tr elements</li>
      <li><strong>Grouping cells:</strong> Each horizontal set of related data goes in one row</li>
      <li><strong>Header rows:</strong> In <a href="/docs/elements/native/thead/"><code>&lt;thead&gt;</code></a>, rows typically contain <a href="/docs/elements/native/th/"><code>&lt;th&gt;</code></a> elements</li>
      <li><strong>Data rows:</strong> In <a href="/docs/elements/native/tbody/"><code>&lt;tbody&gt;</code></a>, rows typically contain <a href="/docs/elements/native/td/"><code>&lt;td&gt;</code></a> elements (with optional <code>&lt;th scope="row"&gt;</code>)</li>
    </ul>
  </section>

  <section>
    <h2>Examples</h2>

    <h3>Basic Table Rows</h3>
    <p>Rows contain cells that align with the table's column structure. Hover over rows to see the built-in highlight effect.</p>
    <browser-window src="/docs/snippets/demos/table-basic.html" url="https://vanilla-breeze.dev/table/basic" title="Basic table with rows" shadow></browser-window>
    <code-block language="html" show-lines label="Basic table row structure">{{ basicRowCode | escape }}</code-block>

    <h3>Row States</h3>
    <p>Vanilla Breeze provides data attributes for common row states. These work with both static tables and the <a href="/docs/elements/components/data-table/"><code>&lt;data-table&gt;</code></a> component.</p>
    <browser-window src="/docs/snippets/demos/table-row-states.html" url="https://vanilla-breeze.dev/table/row-states" title="Table row states" shadow></browser-window>
    <code-block language="html" show-lines label="Row state attributes">{{ rowStatesCode | escape }}</code-block>
  </section>

  <section>
    <h2>Row Hover Effect</h2>
    <p>Rows in <code>&lt;tbody&gt;</code> receive a hover effect automatically to help users track data across columns. This is applied by default in Vanilla Breeze and requires no additional attributes.</p>
    <code-block language="css" label="Row hover effect (built-in)">{{ hoverCss | escape }}</code-block>
  </section>

  <section>
    <h2>Selectable Rows</h2>
    <p>Add <code>data-selectable</code> to indicate a row can be selected. Combine with <code>data-selected</code> to mark the current selection. The <a href="/docs/elements/components/data-table/"><code>&lt;data-table&gt;</code></a> component manages selection state automatically.</p>
    <code-block language="html" show-lines label="Selectable rows">{{ selectableCode | escape }}</code-block>
  </section>

  <section>
    <h2>Expandable Rows</h2>
    <p>Use <code>data-expandable</code> on the trigger row and <code>data-state-expanded</code> or <code>data-state-hidden</code> on the detail row. Detail rows are typically full-width with <code>colspan</code>.</p>
    <code-block language="html" show-lines label="Expandable detail rows">{{ expandableCode | escape }}</code-block>
  </section>

  <section>
    <h2>VB Data Attributes</h2>

    <table class="props-table">
      <thead>
        <tr>
          <th scope="col">Attribute</th>
          <th scope="col">Purpose</th>
          <th scope="col">Applied To</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>data-selected</code></td>
          <td>Marks a row as selected (primary subtle background + outline)</td>
          <td><code>&lt;tr&gt;</code> in <code>&lt;tbody&gt;</code></td>
        </tr>
        <tr>
          <td><code>data-disabled</code></td>
          <td>Reduces opacity and disables pointer events</td>
          <td><code>&lt;tr&gt;</code> in <code>&lt;tbody&gt;</code></td>
        </tr>
        <tr>
          <td><code>data-highlight</code></td>
          <td>Applies a warning-subtle background highlight</td>
          <td><code>&lt;tr&gt;</code> in <code>&lt;tbody&gt;</code></td>
        </tr>
        <tr>
          <td><code>data-selectable</code></td>
          <td>Indicates the row is interactive and can be selected</td>
          <td><code>&lt;tr&gt;</code> in <code>&lt;tbody&gt;</code></td>
        </tr>
        <tr>
          <td><code>data-expandable</code></td>
          <td>Marks a row as having an expandable detail row</td>
          <td><code>&lt;tr&gt;</code> in <code>&lt;tbody&gt;</code></td>
        </tr>
        <tr>
          <td><code>data-state-hidden</code></td>
          <td>Hides a detail row (<code>display: none</code>)</td>
          <td><code>&lt;tr&gt;</code> detail row</td>
        </tr>
        <tr>
          <td><code>data-state-expanded</code></td>
          <td>Shows a detail row with a sunken background</td>
          <td><code>&lt;tr&gt;</code> detail row</td>
        </tr>
      </tbody>
    </table>
  </section>

  <section>
    <h2>CSS Reference</h2>
    <code-block language="css" show-lines label="Row state CSS">{{ rowStateCss | escape }}</code-block>
  </section>

  <section>
    <h2>Valid Parent Elements</h2>
    <p>The <code>&lt;tr&gt;</code> element must be a child of one of these elements:</p>

    <table class="props-table">
      <thead>
        <tr>
          <th scope="col">Parent</th>
          <th scope="col">Purpose</th>
          <th scope="col">Typical Content</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><a href="/docs/elements/native/thead/"><code>&lt;thead&gt;</code></a></td>
          <td>Header rows</td>
          <td><code>&lt;th scope="col"&gt;</code> cells</td>
        </tr>
        <tr>
          <td><a href="/docs/elements/native/tbody/"><code>&lt;tbody&gt;</code></a></td>
          <td>Data rows</td>
          <td><code>&lt;td&gt;</code> and optional <code>&lt;th scope="row"&gt;</code></td>
        </tr>
        <tr>
          <td><a href="/docs/elements/native/tfoot/"><code>&lt;tfoot&gt;</code></a></td>
          <td>Footer/summary rows</td>
          <td><code>&lt;td&gt;</code> cells with totals/summaries</td>
        </tr>
      </tbody>
    </table>
  </section>

  <section>
    <h2>Accessibility</h2>
    <ul>
      <li><strong>Consistent cell count:</strong> All rows should have the same number of cells (accounting for <code>colspan</code>)</li>
      <li><strong>Row headers:</strong> Use <a href="/docs/elements/native/th/"><code>&lt;th scope="row"&gt;</code></a> when the first cell identifies the row</li>
      <li><strong>Screen reader navigation:</strong> Users can navigate row by row through table data</li>
      <li><strong>Implicit role:</strong> <code>&lt;tr&gt;</code> has an implicit ARIA role of <code>row</code></li>
      <li><strong>Disabled rows:</strong> When using <code>data-disabled</code>, also add <code>aria-disabled="true"</code> for assistive technology</li>
      <li><strong>Selected rows:</strong> When using <code>data-selected</code>, also add <code>aria-selected="true"</code> for assistive technology</li>
    </ul>
  </section>

