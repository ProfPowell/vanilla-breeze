---
layout: layouts/element.njk
title: "layout-grid"
description: "Auto-fit responsive grid layout. Creates equal-width columns that automatically reflow based on available space."
elementName: layout-grid
category: custom
currentPath: /docs/elements/custom-elements/grid/
permalink: /docs/elements/custom-elements/grid/
---

{% set basicUsageCode %}<layout-grid data-layout-min="10rem" data-layout-gap="m">
  <layout-card>Card 1</layout-card>
  <layout-card>Card 2</layout-card>
  <layout-card>Card 3</layout-card>
</layout-grid>

<layout-grid data-layout-min="20rem" data-layout-gap="m">
  <!-- Wider minimum columns -->
</layout-grid>{% endset %}

{% set productGridCode %}<layout-grid data-layout-min="15rem" data-layout-gap="l">
  <layout-card data-variant="outlined">
    <layout-stack data-layout-gap="s">
      <div data-media data-layout-ratio="4:3" data-radius="s">
        <img src="product.jpg" alt="Product" loading="lazy" />
      </div>
      <h4>Product Name</h4>
      <p>$29.99</p>
    </layout-stack>
  </layout-card>
  <!-- More products... -->
</layout-grid>{% endset %}

{% set featureCardsCode %}<layout-grid data-layout-min="18rem" data-layout-gap="m">
  <layout-card>
    <layout-stack data-layout-gap="s">
      <strong>Fast Performance</strong>
      <p>Optimized for speed with minimal overhead.</p>
    </layout-stack>
  </layout-card>
  <layout-card>
    <layout-stack data-layout-gap="s">
      <strong>Accessible</strong>
      <p>Built with WCAG guidelines in mind.</p>
    </layout-stack>
  </layout-card>
  <layout-card>
    <layout-stack data-layout-gap="s">
      <strong>Progressive</strong>
      <p>Works without JavaScript, enhances with it.</p>
    </layout-stack>
  </layout-card>
</layout-grid>{% endset %}

<browser-window
    src="/docs/examples/demos/grid-responsive.html"
    url="https://vanilla-breeze.dev/grid"
    title="Responsive Grid"
    shadow>
  </browser-window>

  <section>
    <h2>Attributes</h2>
    <table class="props-table">
      <thead>
        <tr>
          <th>Attribute</th>
          <th>Values</th>
          <th>Default</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>data-layout-min</code></td>
          <td><code>10rem</code>, <code>12rem</code>, <code>15rem</code>, <code>18rem</code>, <code>20rem</code>, <code>25rem</code></td>
          <td><code>15rem</code></td>
          <td>Minimum column width before wrapping</td>
        </tr>
        <tr>
          <td><code>data-layout-gap</code></td>
          <td><code>none</code>, <code>xs</code>, <code>s</code>, <code>m</code>, <code>l</code>, <code>xl</code></td>
          <td><code>m</code></td>
          <td>Gap between grid items</td>
        </tr>
      </tbody>
    </table>
  </section>

  <section>
    <h2>Minimum Width Variants</h2>
    <p>The <code>data-layout-min</code> attribute sets the minimum width each column can shrink to before the grid reflows.</p>

    <browser-window
      src="/docs/snippets/demos/grid-min-width.html"
      url="https://vanilla-breeze.dev/grid/min-width"
      title="Minimum width variants"
      shadow>
    </browser-window>

    <code-block language="html" show-lines label="Minimum width variants example">{{ basicUsageCode | escape }}</code-block>
  </section>

  <section>
    <h2>Gap Variants</h2>
    <p>The <code>data-layout-gap</code> attribute controls spacing between grid items.</p>

    <browser-window
      src="/docs/snippets/demos/grid-gap.html"
      url="https://vanilla-breeze.dev/grid/gap"
      title="Gap variants"
      shadow>
    </browser-window>
  </section>

  <section>
    <h2>Usage Examples</h2>

    <h3>Product Grid</h3>

    <browser-window
      src="/docs/snippets/demos/grid-product.html"
      url="https://vanilla-breeze.dev/grid/product"
      title="Product grid"
      shadow>
    </browser-window>

    <code-block language="html" show-lines label="Product grid example">{{ productGridCode | escape }}</code-block>

    <h3>Feature Cards</h3>

    <browser-window
      src="/docs/snippets/demos/grid-feature-cards.html"
      url="https://vanilla-breeze.dev/grid/feature-cards"
      title="Feature cards"
      shadow>
    </browser-window>

    <code-block language="html" show-lines label="Feature cards example">{{ featureCardsCode | escape }}</code-block>

    <h3>Stats Grid</h3>

    <browser-window
      src="/docs/snippets/demos/grid-stats.html"
      url="https://vanilla-breeze.dev/grid/stats"
      title="Stats grid"
      shadow>
    </browser-window>
  </section>

