{% set basicUsageCode %}<layout-columns>
  <article>
    <h2>Article Title</h2>
    <p>Single-column content with measure constraint
    and vertical rhythm applied automatically.</p>
    <p>Line length stays readable at any viewport width.</p>
  </article>
</layout-columns>{% endset %}

{% set autoColumnsCode %}<layout-columns data-layout-column-count="auto"
               data-layout-align="justify">
  <article data-prose>
    <h2>Responsive Columns</h2>
    <p>Browser determines column count from available width.
    Single column on mobile, multi-column on wider screens.</p>
  </article>
</layout-columns>{% endset %}

{% set twoColumnCode %}<layout-columns data-layout-column-count="2">
  <article>
    <h2>Two Columns</h2>
    <p>Explicit two-column layout. Use when the column count
    must be fixed regardless of viewport width.</p>
  </article>
</layout-columns>{% endset %}

{% set narrowMeasureCode %}<layout-columns data-layout-measure="narrow">
  <article>
    <h2>Narrow Reading</h2>
    <p>45ch measure. Appropriate for short articles,
    captions, or sidebar content.</p>
  </article>
</layout-columns>{% endset %}

{% set attributeFormCode %}<!-- Same layout, no wrapper element -->
<article data-layout="columns"
         data-layout-column-count="2"
         data-layout-align="justify"
         data-prose>
  <h2>Two Columns via Attribute</h2>
  <p>The data-layout attribute form applies the same
  styles directly to a semantic element.</p>
</article>{% endset %}

{% set readerViewCode %}<reader-view mode="pages" columns="2">
  <layout-columns data-layout-align="justify">
    <article data-prose>
      <h1>Article Title</h1>
      <p>Content inside reader-view gets paged reading mode
      with column controls and page navigation.</p>
    </article>
  </layout-columns>
</reader-view>{% endset %}

