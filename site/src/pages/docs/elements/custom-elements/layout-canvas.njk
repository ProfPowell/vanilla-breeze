{% set attrBasicCode %}<article data-canvas>
  <h2>My Article</h2>
  <p>Content with elevated surface styling.</p>
</article>{% endset %}

{% set elementBasicCode %}<layout-canvas>
  <header>Page Header</header>
  <main>
    <p>Main content area wrapped in a canvas surface.</p>
  </main>
</layout-canvas>{% endset %}

{% set flushCode %}<section data-canvas="flush">
  <h2>Flush Canvas</h2>
  <p>No border radius or shadow. Edge-to-edge surface.</p>
</section>{% endset %}

{% set elevatedCode %}<section data-canvas="elevated">
  <h2>Elevated Canvas</h2>
  <p>Larger radius and dramatic shadow for emphasis.</p>
</section>{% endset %}

{% set widthCode %}<article data-canvas data-layout-max="narrow">
  <h2>Narrow Canvas</h2>
  <p>Constrained to 45rem max width, centered on the page.</p>
</article>

<article data-canvas data-layout-max="content">
  <h2>Content Width</h2>
  <p>Constrained to 60rem max width.</p>
</article>{% endset %}

{% set nestedCode %}<article data-canvas>
  <h2>Outer Canvas</h2>
  <p>Primary surface background.</p>

  <aside data-canvas>
    <h3>Nested Canvas</h3>
    <p>Automatically uses raised surface color for hierarchy.</p>
  </aside>
</article>{% endset %}

{% set depthCode %}<article data-canvas data-canvas-depth="1">
  <h2>Single Ghost Card</h2>
  <p>One stacked paper shadow beneath the canvas.</p>
</article>

<article data-canvas data-canvas-depth="2">
  <h2>Double Ghost Cards</h2>
  <p>Two stacked paper shadows for extra depth.</p>
</article>{% endset %}

{% set multiCode %}<section data-layout="grid" data-layout-min="20rem">
  <article data-canvas>
    <h3>Canvas A</h3>
    <p>Independent canvas region.</p>
  </article>
  <aside data-canvas="elevated">
    <h3>Canvas B</h3>
    <p>Elevated variant alongside.</p>
  </aside>
</section>{% endset %}

