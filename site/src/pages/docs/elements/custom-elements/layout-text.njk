      title="Centered article layout"
      shadow>
    </browser-window>

    <code-block language="html" show-lines label="Centered article layout">{{ withCenterCode | escape }}</code-block>
  </section>

  <section>
    <h2>Best Practices</h2>
    <ul>
      <li><strong>Use for long-form content only</strong> - layout-text is designed for articles, documentation, and similar content. Don't use it for UI layouts.</li>
      <li><strong>Combine with layout-center</strong> - For page layouts, wrap layout-text in a layout-center to constrain width.</li>
      <li><strong>Semantic HTML</strong> - The spacing rules work best with proper semantic markup (h2 before h3, etc.).</li>
      <li><strong>Avoid nesting layout elements</strong> - layout-stack, layout-grid, and similar elements inside prose may have unexpected spacing.</li>
    </ul>
  </section>

