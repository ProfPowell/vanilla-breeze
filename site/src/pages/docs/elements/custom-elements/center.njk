---
layout: layouts/element.njk
title: "layout-center"
description: "Horizontally centered content container with configurable max-width. Essential for constraining content width on wide screens."
elementName: layout-center
category: custom
currentPath: /docs/elements/custom-elements/center/
permalink: /docs/elements/custom-elements/center/
---

{% set maxWidthCode %}<layout-center data-layout-max="narrow">
  <article>Long-form reading content...</article>
</layout-center>

<layout-center data-layout-max="normal">
  <!-- Default width for most layouts -->
</layout-center>

<layout-center data-layout-max="wide">
  <!-- Dashboard or data table -->
</layout-center>{% endset %}

{% set intrinsicCode %}<layout-center data-layout-intrinsic>
  <button type="button">Centered Button</button>
</layout-center>

<layout-center data-layout-intrinsic>
  <layout-card style="max-inline-size: 20rem;">
    Intrinsically centered card
  </layout-card>
</layout-center>{% endset %}

{% set textCenteringCode %}<layout-center data-layout-text>
  <h2>Centered Heading</h2>
  <p>Centered paragraph text.</p>
</layout-center>

<layout-center data-layout-intrinsic data-layout-text>
  <!-- Both container and text centered -->
</layout-center>{% endset %}

{% set pageLayoutCode %}<layout-center data-layout-max="normal">
  <layout-stack data-layout-gap="xl">
    <header>
      <layout-cluster data-layout-justify="between">
        <strong>Logo</strong>
        <nav>...</nav>
      </layout-cluster>
    </header>
    <main>
      <p>Main page content</p>
    </main>
  </layout-stack>
</layout-center>{% endset %}

{% set heroCode %}<layout-center data-layout-max="narrow" data-layout-text data-layout-intrinsic>
  <layout-stack data-layout-gap="l" data-layout-align="center">
    <h1>Welcome to Our Platform</h1>
    <p>Build amazing products with our toolkit.</p>
    <layout-cluster data-layout-gap="m">
      <button type="button">Get Started</button>
      <button type="button" class="secondary">Learn More</button>
    </layout-cluster>
  </layout-stack>
</layout-center>{% endset %}

{% set articleCode %}<layout-center data-layout-max="narrow">
  <layout-text>
    <h2>Article Title</h2>
    <p>Narrow max-width ensures optimal line length.</p>
    <p>45-75 characters per line is ideal.</p>
  </layout-text>
</layout-center>{% endset %}

{% set formContainerCode %}<layout-center data-layout-max="narrow" data-layout-intrinsic>
  <layout-card data-variant="outlined">
    <layout-stack data-layout-gap="m">
      <h3>Sign In</h3>
      <layout-stack data-layout-gap="xs">
        <label for="email">Email</label>
        <input type="email" id="email" />
      </layout-stack>
      <layout-stack data-layout-gap="xs">
        <label for="password">Password</label>
        <input type="password" id="password" />
      </layout-stack>
      <button type="submit">Sign In</button>
    </layout-stack>
  </layout-card>
</layout-center>{% endset %}

<browser-window
    src="/docs/examples/demos/center-basic.html"
    url="https://vanilla-breeze.dev/center"
    title="Center Layout Demo"
    shadow>
  </browser-window>

  <section>
    <h2>Attributes</h2>
    <table class="props-table">
      <thead>
        <tr>
          <th>Attribute</th>
          <th>Values</th>
          <th>Default</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>data-layout-max</code></td>
          <td><code>narrow</code>, <code>normal</code>, <code>wide</code></td>
          <td><code>normal</code></td>
          <td>Maximum width (45rem, 60rem, 80rem)</td>
        </tr>
        <tr>
          <td><code>data-layout-intrinsic</code></td>
          <td>boolean</td>
          <td>-</td>
          <td>Centers content that is narrower than max-width</td>
        </tr>
        <tr>
          <td><code>data-layout-text</code></td>
          <td>boolean</td>
          <td>-</td>
          <td>Centers text alignment</td>
        </tr>
        <tr>
          <td><code>data-layout-gutter</code></td>
          <td><code>none</code>, <code>s</code>, <code>l</code></td>
          <td><code>m</code></td>
          <td>Horizontal padding (gutter)</td>
        </tr>
      </tbody>
    </table>
  </section>

  <section>
    <h2>Max Width Variants</h2>
    <p>The <code>data-layout-max</code> attribute controls the maximum width of the container.</p>

    <browser-window
      src="/docs/snippets/demos/center-max-width.html"
      url="https://vanilla-breeze.dev/center/max-width"
      title="Max width variants"
      shadow>
    </browser-window>

    <code-block language="html" show-lines label="Max width variants usage">{{ maxWidthCode | escape }}</code-block>
  </section>

  <section>
    <h2>Intrinsic Centering</h2>
    <p>The <code>data-layout-intrinsic</code> attribute centers content that is narrower than the max-width.</p>

    <browser-window
      src="/docs/snippets/demos/center-intrinsic.html"
      url="https://vanilla-breeze.dev/center/intrinsic"
      title="Intrinsic centering"
      shadow>
    </browser-window>

    <code-block language="html" show-lines label="Intrinsic centering examples">{{ intrinsicCode | escape }}</code-block>
  </section>

  <section>
    <h2>Text Centering</h2>
    <p>The <code>data-layout-text</code> attribute adds <code>text-align: center</code> for centered text content.</p>

    <browser-window
      src="/docs/snippets/demos/center-text.html"
      url="https://vanilla-breeze.dev/center/text"
      title="Text centering"
      shadow>
    </browser-window>

    <code-block language="html" show-lines label="Text centering examples">{{ textCenteringCode | escape }}</code-block>
  </section>

  <section>
    <h2>Gutter Variants</h2>
    <p>The <code>data-layout-gutter</code> attribute controls horizontal padding (useful for nested centers).</p>

    <browser-window
      src="/docs/snippets/demos/center-gutter.html"
      url="https://vanilla-breeze.dev/center/gutter"
      title="Gutter variants"
      shadow>
    </browser-window>
  </section>

  <section>
    <h2>Usage Examples</h2>

    <h3>Page Layout</h3>

    <browser-window
      src="/docs/snippets/demos/center-page-layout.html"
      url="https://vanilla-breeze.dev/center/page-layout"
      title="Centered page layout"
      shadow>
    </browser-window>

    <code-block language="html" show-lines label="Centered page layout">{{ pageLayoutCode | escape }}</code-block>

    <h3>Hero Section</h3>

    <browser-window
      src="/docs/snippets/demos/center-hero.html"
      url="https://vanilla-breeze.dev/center/hero"
      title="Centered hero section"
      shadow>
    </browser-window>

    <code-block language="html" show-lines label="Centered hero with text alignment">{{ heroCode | escape }}</code-block>

    <h3>Article Content</h3>

    <browser-window
      src="/docs/snippets/demos/center-article.html"
      url="https://vanilla-breeze.dev/center/article"
      title="Article with narrow max-width"
      shadow>
    </browser-window>

    <code-block language="html" show-lines label="Article with narrow max-width">{{ articleCode | escape }}</code-block>

    <h3>Form Container</h3>

    <browser-window
      src="/docs/snippets/demos/center-form.html"
      url="https://vanilla-breeze.dev/center/form"
      title="Centered form container"
      shadow>
    </browser-window>

    <code-block language="html" show-lines label="Centered form with intrinsic sizing">{{ formContainerCode | escape }}</code-block>
  </section>

