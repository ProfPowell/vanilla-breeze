---
layout: layouts/element.njk
title: "status-message"
description: "Inline notification banners for important messages. Use for success confirmations, warnings, errors, and informational notices."
elementName: status-message
category: custom
currentPath: /docs/elements/custom-elements/status-message/
permalink: /docs/elements/custom-elements/status-message/
---

{% set basicVariantCode %}<status-message data-variant="success">
  <div data-content>
    <div data-title>Success</div>
    <div data-description>Your changes have been saved.</div>
  </div>
</status-message>{% endset %}

{% set withIconCode %}<status-message data-variant="success">
  <icon-wc name="circle-check" data-icon></icon-wc>
  <div data-content>
    <div data-title>Success</div>
    <div data-description>Your changes have been saved.</div>
  </div>
</status-message>{% endset %}

{% set filledCode %}<status-message data-variant="error" data-filled>
  <div data-content>
    <div data-title>Critical Error</div>
    <div data-description>Immediate action required.</div>
  </div>
</status-message>{% endset %}

{% set compactCode %}<status-message data-variant="success" data-compact>
  <div data-content>File uploaded successfully!</div>
</status-message>{% endset %}

{% set dismissCode %}<status-message data-variant="info">
  <div data-content>
    <div data-title>Dismissable Alert</div>
    <div data-description>Click the X to dismiss.</div>
  </div>
  <button data-dismiss type="button" aria-label="Dismiss">&#x2715;</button>
</status-message>{% endset %}

{% set accessibilityCode %}<!-- For error messages -->
<status-message data-variant="error" role="alert">
  ...
</status-message>

<!-- For status updates -->
<status-message data-variant="success" role="status">
  ...
</status-message>{% endset %}

<browser-window
    src="/docs/examples/demos/status-message-basic.html"
    url="https://vanilla-breeze.dev/status-message"
    title="Status Message Demo"
    shadow>
  </browser-window>

  <section>
    <h2>Attributes</h2>
    <table class="props-table">
      <thead>
        <tr>
          <th>Attribute</th>
          <th>Values</th>
          <th>Default</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>data-variant</code></td>
          <td><code>info</code>, <code>success</code>, <code>warning</code>, <code>error</code>, <code>neutral</code></td>
          <td><code>info</code></td>
          <td>Alert type and color</td>
        </tr>
        <tr>
          <td><code>data-filled</code></td>
          <td>boolean</td>
          <td>-</td>
          <td>Use solid background color</td>
        </tr>
        <tr>
          <td><code>data-compact</code></td>
          <td>boolean</td>
          <td>-</td>
          <td>Reduce padding</td>
        </tr>
      </tbody>
    </table>
  </section>

  <section>
    <h2>Variants</h2>
    <p>Alerts come in five semantic variants for different message types.</p>

    <browser-window
      src="/docs/snippets/demos/status-message-variants.html"
      url="https://vanilla-breeze.dev/status-message/variants"
      title="Alert variants"
      shadow>
    </browser-window>

    <code-block language="html" show-lines label="Alert variants">{{ basicVariantCode | escape }}</code-block>
  </section>

  <section>
    <h2>With Icons</h2>
    <p>Add an <code>icon-wc</code> element with <code>data-icon</code> attribute for visual emphasis.</p>

    <browser-window
      src="/docs/snippets/demos/status-message-icons.html"
      url="https://vanilla-breeze.dev/status-message/icons"
      title="Alerts with icons"
      shadow>
    </browser-window>

    <code-block language="html" show-lines label="Alert with icon">{{ withIconCode | escape }}</code-block>
  </section>

  <section>
    <h2>Filled Style</h2>
    <p>Add <code>data-filled</code> for a solid background color.</p>

    <browser-window
      src="/docs/snippets/demos/status-message-filled.html"
      url="https://vanilla-breeze.dev/status-message/filled"
      title="Filled alerts"
      shadow>
    </browser-window>

    <code-block language="html" show-lines label="Filled alerts">{{ filledCode | escape }}</code-block>
  </section>

  <section>
    <h2>Simple Alerts</h2>
    <p>Alerts can be simple single-line messages without title.</p>

    <browser-window
      src="/docs/snippets/demos/status-message-compact.html"
      url="https://vanilla-breeze.dev/status-message/compact"
      title="Compact alerts"
      shadow>
    </browser-window>

    <code-block language="html" show-lines label="Simple compact alerts">{{ compactCode | escape }}</code-block>
  </section>

  <section>
    <h2>With Dismiss Button</h2>
    <p>Add a dismiss button for closable alerts.</p>

    <browser-window
      src="/docs/snippets/demos/status-message-dismiss.html"
      url="https://vanilla-breeze.dev/status-message/dismiss"
      title="Dismissable alert"
      shadow>
    </browser-window>

    <code-block language="html" show-lines label="Alert with dismiss button">{{ dismissCode | escape }}</code-block>
  </section>

  <section>
    <h2>Accessibility</h2>
    <p>For important alerts that need to be announced to screen readers, add the appropriate ARIA role.</p>

    <code-block language="html" show-lines label="Accessible alerts">{{ accessibilityCode | escape }}</code-block>
  </section>

