---
layout: layouts/element.njk
title: "chat-thread"
description: "Scrollable message container for chat conversations. Grows to fill available height with smooth scrolling and automatic scroll anchoring."
elementName: chat-thread
category: custom
currentPath: /docs/elements/custom-elements/chat-thread/
permalink: /docs/elements/custom-elements/chat-thread/
---

{% set basicCode %}<chat-thread role="log" aria-label="Support conversation" aria-live="polite">
  <chat-message data-role="agent" data-from-label="Bot">
    <chat-bubble><p>Welcome! How can I help?</p></chat-bubble>
  </chat-message>
  <chat-message data-role="user">
    <chat-bubble><p>I have a question.</p></chat-bubble>
  </chat-message>
</chat-thread>{% endset %}

<browser-window
    src="/docs/examples/demos/chat-message-basic.html"
    url="https://vanilla-breeze.dev/chat-thread"
    title="Chat Thread Demo"
    shadow>
  </browser-window>

  <section>
    <h2>Overview</h2>
    <p>A flex-column container that holds <code>&lt;chat-message&gt;</code> elements. Handles vertical overflow with smooth scrolling and keeps the view pinned to the latest message via <code>overflow-anchor</code>.</p>
  </section>

  <section>
    <h2>Attributes</h2>
    <table class="props-table">
      <thead>
        <tr>
          <th>Attribute</th>
          <th>Values</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>role</code></td>
          <td><code>log</code></td>
          <td>Required ARIA role — signals live region semantics</td>
        </tr>
        <tr>
          <td><code>aria-label</code></td>
          <td>string</td>
          <td>Describes the conversation context</td>
        </tr>
        <tr>
          <td><code>aria-live</code></td>
          <td><code>polite</code></td>
          <td>Announces new messages to screen readers</td>
        </tr>
      </tbody>
    </table>
  </section>

  <section>
    <h2>Usage</h2>
    <p>Place <code>&lt;chat-message&gt;</code> elements inside. The thread scrolls vertically when content overflows.</p>
    <code-block language="html" show-lines label="Basic chat thread">{{ basicCode | escape }}</code-block>
  </section>

  <section>
    <h2>CSS Variables</h2>
    <table class="props-table">
      <thead>
        <tr>
          <th>Variable</th>
          <th>Default</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>--chat-thread-gap</code></td>
          <td><code>var(--size-m)</code></td>
          <td>Gap between messages</td>
        </tr>
        <tr>
          <td><code>--chat-thread-padding</code></td>
          <td><code>var(--size-m)</code></td>
          <td>Internal padding</td>
        </tr>
      </tbody>
    </table>
  </section>

