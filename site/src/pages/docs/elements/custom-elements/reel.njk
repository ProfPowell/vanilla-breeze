      src="/docs/examples/demos/reel-scroll.html"
      url="https://vanilla-breeze.dev/reel"
      title="Horizontal Reel"
      shadow>
    </browser-window>

    <code-block language="html" show-lines label="Basic layout-reel usage">{{ basicUsageCode | escape }}</code-block>
