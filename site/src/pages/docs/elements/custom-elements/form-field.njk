---
layout: layouts/element.njk
title: "form-field"
description: "Accessible form field wrapper with label, input, and validation message. Enables CSS-only validation feedback using native HTML5 validation and the <output> element."
elementName: form-field
category: custom
currentPath: /docs/elements/custom-elements/form-field/
permalink: /docs/elements/custom-elements/form-field/
---

{% set basicCode %}<form-field>
  <label for="name">Full Name</label>
  <input type="text"
         id="name"
         name="name"
         required
         minlength="2"
         autocomplete="name"
         aria-describedby="name-msg" />
  <output id="name-msg" for="name" aria-live="polite">
    At least 2 characters required
  </output>
</form-field>{% endset %}

{% set selectCode %}<form-field>
  <label for="category">Category</label>
  <select id="category" name="category" required>
    <option value="" disabled selected>Select a category...</option>
    <option value="general">General Inquiry</option>
    <option value="support">Technical Support</option>
    <option value="sales">Sales Question</option>
  </select>
</form-field>{% endset %}

{% set outputClassesCode %}<form-field>
  <label for="username">Username</label>
  <input type="text" id="username" name="username" required
         minlength="3" maxlength="20"
         aria-describedby="username-hint username-error" />
  <output id="username-hint" class="hint" for="username">
    3-20 characters, letters and numbers only.
  </output>
  <output id="username-error" class="error" for="username" aria-live="polite">
    Please enter a valid username.
  </output>
</form-field>{% endset %}

{% set passwordToggleCode %}<form-field>
  <label for="password">Password</label>
  <input type="password" id="password" name="password"
         required minlength="8"
         autocomplete="current-password"
         aria-describedby="password-msg" />
  <output id="password-msg" class="error" for="password" aria-live="polite">
    At least 8 characters required.
  </output>
</form-field>
<!-- JS auto-adds show/hide toggle button -->{% endset %}

{% set validationIconsCode %}<!-- Default: validation icons appear -->
<form-field>
  <label for="email">Email</label>
  <input type="email" id="email" name="email" required />
</form-field>

<!-- Opt-out: no validation icons -->
<form-field data-no-icon>
  <label for="search">Search</label>
  <input type="search" id="search" name="q" />
</form-field>{% endset %}

{% set otpInputCode %}<form-field data-no-icon>
  <label for="code">Verification code</label>
  <input type="text" id="code" name="code"
         data-type="otp" data-length="6"
         inputmode="numeric" pattern="[0-9]{6}"
         autocomplete="one-time-code" required
         aria-describedby="code-msg" />
  <output id="code-msg" class="hint" for="code" aria-live="polite">
    Enter the 6-digit code from your authenticator app.
  </output>
</form-field>{% endset %}

{% set checkboxRadioCode %}<!-- Single Checkbox -->
<form-field data-type="checkbox">
  <label>
    <input type="checkbox" id="terms" name="terms" required />
    I agree to the Terms of Service
  </label>
</form-field>

<!-- Radio Group -->
<fieldset>
  <legend>Preferred Contact Method</legend>
  <layout-stack data-layout-gap="xs">
    <form-field data-type="radio">
      <label>
        <input type="radio" name="contact" value="email" required />
        Email
      </label>
    </form-field>
    <form-field data-type="radio">
      <label>
        <input type="radio" name="contact" value="phone" />
        Phone
      </label>
    </form-field>
  </layout-stack>
</fieldset>{% endset %}

{% set validationCssCode %}/* Valid state - green border after user interacts */
form-field:has(input:user-valid) {
  & input {
    border-color: var(--color-success);
  }
  & output {
    color: var(--color-success);
  }
}

/* Invalid state - red border after user interacts */
form-field:has(input:user-invalid) {
  & input {
    border-color: var(--color-error);
  }
  & output {
    color: var(--color-error);
  }
}{% endset %}

{% set customMessageCode %}<form data-validate>
  <form-field>
    <label for="email">Email</label>
    <input type="email" id="email" name="email"
           required minlength="5"
           data-message-required="Email is required"
           data-message-type="Please enter a valid email address"
           data-message-minlength="Email seems too short"
           aria-describedby="email-error" />
    <output id="email-error" class="error" for="email"
            aria-live="polite"></output>
  </form-field>
  <button type="submit">Submit</button>
</form>{% endset %}

{% set passwordMatchCode %}<form data-validate>
  <form-field>
    <label for="password">Password</label>
    <input type="password" id="password" name="password"
           required minlength="8"
           data-message-required="Password is required"
           data-message-minlength="At least 8 characters"
           autocomplete="new-password"
           aria-describedby="password-error" />
    <output id="password-error" class="error" for="password"
            aria-live="polite"></output>
  </form-field>

  <form-field>
    <label for="confirm">Confirm Password</label>
    <input type="password" id="confirm" name="confirm"
           required
           data-match="password"
           data-message-required="Please confirm your password"
           data-message-match="Passwords do not match"
           autocomplete="new-password"
           aria-describedby="confirm-error" />
    <output id="confirm-error" class="error" for="confirm"
            aria-live="polite"></output>
  </form-field>
  <button type="submit">Create Account</button>
</form>{% endset %}

{% set checkboxGroupCode %}<form data-validate>
  <fieldset data-min-checked="1" data-max-checked="3"
            data-message-min-checked="Select at least one"
            data-message-max-checked="Maximum 3 allowed">
    <legend>Interests</legend>
    <form-field data-type="checkbox">
      <label><input type="checkbox" name="interests" value="music" /> Music</label>
    </form-field>
    <form-field data-type="checkbox">
      <label><input type="checkbox" name="interests" value="sport" /> Sport</label>
    </form-field>
    <form-field data-type="checkbox">
      <label><input type="checkbox" name="interests" value="tech" /> Tech</label>
    </form-field>
    <output aria-live="polite"></output>
  </fieldset>
  <button type="submit">Save</button>
</form>{% endset %}

{% set errorSummaryCode %}<!-- Summary + field-level errors (both) -->
<form data-validate>
  <output class="error-summary" role="alert"
          aria-live="polite" tabindex="-1"></output>

  <form-field>
    <label for="name">Name</label>
    <input id="name" type="text" required
           data-message-required="Name is required"
           aria-describedby="name-error" />
    <output id="name-error" class="error" for="name"
            aria-live="polite"></output>
  </form-field>

  <button type="submit">Submit</button>
</form>

<!-- Summary only (field-level errors hidden) -->
<form data-validate="summary">
  <output class="error-summary" role="alert"
          aria-live="polite" tabindex="-1"></output>
  <!-- ... fields ... -->
</form>{% endset %}

{% set completeFormCode %}<form action="/api/contact" method="POST">
  <layout-stack data-layout-gap="m">
    <form-field>
      <label for="name">Name</label>
      <input type="text" id="name" name="name" required
             minlength="2" autocomplete="name"
             aria-describedby="name-msg" />
      <output id="name-msg" for="name" aria-live="polite">
        Please enter your name
      </output>
    </form-field>

    <form-field>
      <label for="email">Email</label>
      <input type="email" id="email" name="email" required
             autocomplete="email"
             aria-describedby="email-msg" />
      <output id="email-msg" for="email" aria-live="polite">
        Please enter a valid email
      </output>
    </form-field>

    <form-field>
      <label for="subject">Subject</label>
      <select id="subject" name="subject" required>
        <option value="" disabled selected>Select a subject...</option>
        <option value="general">General Inquiry</option>
        <option value="support">Technical Support</option>
        <option value="feedback">Feedback</option>
      </select>
    </form-field>

    <form-field>
      <label for="message">Message</label>
      <textarea id="message" name="message" required
                minlength="10" rows="5"
                aria-describedby="message-msg"></textarea>
      <output id="message-msg" for="message" aria-live="polite">
        At least 10 characters
      </output>
    </form-field>

    <button type="submit">Send Message</button>
  </layout-stack>
</form>{% endset %}

<browser-window
    src="/docs/examples/demos/form-field-basic.html"
    url="https://vanilla-breeze.dev/form-field"
    title="Form Field Demo"
    shadow>
  </browser-window>

  <section>
    <h2>Attributes</h2>
    <table class="props-table">
      <thead>
        <tr>
          <th>Attribute</th>
          <th>Values</th>
          <th>Default</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>data-type</code></td>
          <td><code>checkbox</code>, <code>radio</code>, <code>file</code></td>
          <td>-</td>
          <td>Special styling for non-text inputs</td>
        </tr>
        <tr>
          <td><code>data-no-icon</code></td>
          <td>boolean</td>
          <td>-</td>
          <td>Disable validation status icons</td>
        </tr>
        <tr>
          <td><code>data-required</code></td>
          <td>boolean</td>
          <td>-</td>
          <td>Visual indicator (auto-detected from input)</td>
        </tr>
        <tr>
          <td><code>data-valid</code></td>
          <td>boolean</td>
          <td>-</td>
          <td>Force valid state styling</td>
        </tr>
        <tr>
          <td><code>data-invalid</code></td>
          <td>boolean</td>
          <td>-</td>
          <td>Force invalid state styling</td>
        </tr>
      </tbody>
    </table>

    <h3>Input Attributes (for JS enhancements)</h3>
    <table class="props-table">
      <thead>
        <tr>
          <th>Attribute</th>
          <th>Values</th>
          <th>Default</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>data-type</code> (on input)</td>
          <td><code>otp</code>, <code>pin</code></td>
          <td>-</td>
          <td>Enable OTP/PIN multi-box enhancement</td>
        </tr>
        <tr>
          <td><code>data-length</code> (on input)</td>
          <td><code>4</code>, <code>6</code>, <code>8</code></td>
          <td><code>6</code></td>
          <td>Number of digits for OTP/PIN input</td>
        </tr>
      </tbody>
    </table>
  </section>

  <section>
    <h2>Element Structure</h2>
    <p>The form-field element groups a label, input control, and optional validation message.</p>

    <table class="props-table">
      <thead>
        <tr>
          <th>Child Element</th>
          <th>Purpose</th>
          <th>Key Attributes</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>&lt;label&gt;</code></td>
          <td>Accessible field label</td>
          <td><code>for</code> (matches input <code>id</code>)</td>
        </tr>
        <tr>
          <td><code>&lt;input&gt;</code> / <code>&lt;textarea&gt;</code> / <code>&lt;select&gt;</code></td>
          <td>Form control</td>
          <td><code>id</code>, <code>name</code>, validation attrs, <code>aria-describedby</code></td>
        </tr>
        <tr>
          <td><code>&lt;output&gt;</code></td>
          <td>Validation/help message</td>
          <td><code>id</code>, <code>for</code>, <code>aria-live="polite"</code></td>
        </tr>
      </tbody>
    </table>

    <code-block language="html" show-lines label="Basic text input">{{ basicCode | escape }}</code-block>
  </section>

  <section>
    <h2>Input Types</h2>
    <p>Works with all standard form controls: text, email, password, textarea, and select.</p>

    <browser-window
      src="/docs/snippets/demos/form-field-input-types.html"
      url="https://vanilla-breeze.dev/form-field/input-types"
      title="Input types"
      shadow>
    </browser-window>

    <code-block language="html" show-lines label="Select dropdown">{{ selectCode | escape }}</code-block>
  </section>

  <section>
    <h2>Password Toggle</h2>
    <p>Password inputs are automatically enhanced with a show/hide toggle button when JavaScript is available. No extra markup needed.</p>
    <ul>
      <li>Appears automatically when JavaScript loads</li>
      <li>Uses <code>aria-pressed</code> and <code>aria-label</code> for accessibility</li>
      <li>Positions adjust alongside validation icons</li>
    </ul>

    <code-block language="html" show-lines label="Password input with auto toggle">{{ passwordToggleCode | escape }}</code-block>
  </section>

  <section>
    <h2>Validation Status Icons</h2>
    <p>Form fields automatically display a checkmark (valid) or X (invalid) after user interaction. Icons are positioned inside the input's padding. Use <code>data-no-icon</code> to disable them.</p>

    <code-block language="html" show-lines label="Validation icons opt-out">{{ validationIconsCode | escape }}</code-block>
  </section>

  <section>
    <h2>OTP/PIN Input</h2>
    <p>Use <code>data-type="otp"</code> on the input for verification codes. Progressive enhancement: works as a standard text input without JS, enhances to multi-box with JS.</p>

    <browser-window
      src="/docs/snippets/demos/form-field-otp.html"
      url="https://vanilla-breeze.dev/form-field/otp"
      title="OTP and PIN inputs"
      shadow>
    </browser-window>

    <ul>
      <li>Auto-focus moves to the next box after entering a digit</li>
      <li>Backspace moves focus to the previous box</li>
      <li>Arrow keys navigate between boxes</li>
      <li>Paste support fills multiple boxes at once</li>
    </ul>

    <code-block language="html" show-lines label="OTP input progressive enhancement">{{ otpInputCode | escape }}</code-block>
  </section>

  <section>
    <h2>Output Message Classes</h2>
    <p>Use <code>class="hint"</code> and <code>class="error"</code> on output elements for different message types.</p>

    <table class="props-table">
      <thead>
        <tr>
          <th>Class</th>
          <th>Visibility</th>
          <th>Use Case</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>.hint</code></td>
          <td>Always visible (hides when valid)</td>
          <td>Format requirements, help text</td>
        </tr>
        <tr>
          <td><code>.error</code></td>
          <td>Only when invalid</td>
          <td>Error messages</td>
        </tr>
      </tbody>
    </table>

    <code-block language="html" show-lines label="Hint and error output messages">{{ outputClassesCode | escape }}</code-block>
  </section>

  <section>
    <h2>Checkbox and Radio</h2>
    <p>Use <code>data-type="checkbox"</code> or <code>data-type="radio"</code> for inline label+input layout. Wrap radio groups in a <code>&lt;fieldset&gt;</code> with a <code>&lt;legend&gt;</code>.</p>

    <browser-window
      src="/docs/snippets/demos/form-field-checkbox-radio.html"
      url="https://vanilla-breeze.dev/form-field/checkbox-radio"
      title="Checkbox and radio"
      shadow>
    </browser-window>

    <code-block language="html" show-lines label="Checkbox and radio examples">{{ checkboxRadioCode | escape }}</code-block>
  </section>

  <section>
    <h2>CSS-Only Validation</h2>
    <p>Uses <code>:user-valid</code> and <code>:user-invalid</code> pseudo-classes to show validation states only after user interaction, preventing premature error states on page load.</p>

    <browser-window
      src="/docs/snippets/demos/form-field-css-validation.html"
      url="https://vanilla-breeze.dev/form-field/validation"
      title="CSS-only validation"
      shadow>
    </browser-window>

    <code-block language="css" show-lines label="CSS-only validation states">{{ validationCssCode | escape }}</code-block>
  </section>

  <section>
    <h2>JS-Enhanced Validation</h2>
    <p>Add <code>data-validate</code> to a <code>&lt;form&gt;</code> to enable features CSS can't handle: custom error messages, cross-field validation, checkbox group constraints, and error summaries. Without it, everything works as pure CSS validation.</p>

    <browser-window
      src="/docs/snippets/demos/form-field-js-validation.html"
      url="https://vanilla-breeze.dev/form-field/js-validation"
      title="JS-enhanced validation"
      shadow>
    </browser-window>

    <h3>JS Validation Attributes</h3>
    <table class="props-table">
      <thead>
        <tr>
          <th>Attribute</th>
          <th>On</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>data-validate</code></td>
          <td><code>&lt;form&gt;</code></td>
          <td>Opt-in. No value = field-level errors (+ summary if present). <code>"summary"</code> = summary only.</td>
        </tr>
        <tr>
          <td><code>data-message-required</code></td>
          <td>input / textarea / select</td>
          <td>Custom "required" error text</td>
        </tr>
        <tr>
          <td><code>data-message-type</code></td>
          <td>input</td>
          <td>Custom "type mismatch" error text (email, url, etc.)</td>
        </tr>
        <tr>
          <td><code>data-message-minlength</code></td>
          <td>input / textarea</td>
          <td>Custom "too short" error text</td>
        </tr>
        <tr>
          <td><code>data-message-maxlength</code></td>
          <td>input / textarea</td>
          <td>Custom "too long" error text</td>
        </tr>
        <tr>
          <td><code>data-message-pattern</code></td>
          <td>input</td>
          <td>Custom "pattern mismatch" error text</td>
        </tr>
        <tr>
          <td><code>data-match</code></td>
          <td>input</td>
          <td>ID of field that must have the same value</td>
        </tr>
        <tr>
          <td><code>data-message-match</code></td>
          <td>input</td>
          <td>Custom message when <code>data-match</code> fails</td>
        </tr>
        <tr>
          <td><code>data-min-checked</code></td>
          <td>fieldset</td>
          <td>Minimum number of checked checkboxes</td>
        </tr>
        <tr>
          <td><code>data-max-checked</code></td>
          <td>fieldset</td>
          <td>Maximum number of checked checkboxes</td>
        </tr>
      </tbody>
    </table>

    <code-block language="html" show-lines label="Custom error messages">{{ customMessageCode | escape }}</code-block>
    <code-block language="html" show-lines label="Password confirmation with data-match">{{ passwordMatchCode | escape }}</code-block>
    <code-block language="html" show-lines label="Checkbox group constraints">{{ checkboxGroupCode | escape }}</code-block>
  </section>

  <section>
    <h2>Error Summary</h2>
    <p>Add an <code>&lt;output class="error-summary"&gt;</code> inside your form for a consolidated list of all errors on submit.</p>

    <table class="props-table">
      <thead>
        <tr>
          <th>Mode</th>
          <th>Attribute</th>
          <th>Behavior</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Field-level only</td>
          <td><code>data-validate</code> (no summary output)</td>
          <td>Errors appear inline next to each field</td>
        </tr>
        <tr>
          <td>Summary only</td>
          <td><code>data-validate="summary"</code></td>
          <td>Summary at top, field-level errors hidden</td>
        </tr>
        <tr>
          <td>Both</td>
          <td><code>data-validate</code> + summary output present</td>
          <td>Summary at top AND inline errors on each field</td>
        </tr>
      </tbody>
    </table>

    <code-block language="html" show-lines label="Error summary patterns">{{ errorSummaryCode | escape }}</code-block>
  </section>

  <section>
    <h2>Complete Contact Form</h2>

    <browser-window
      src="/docs/snippets/demos/form-field-contact-form.html"
      url="https://vanilla-breeze.dev/form-field/contact"
      title="Contact form"
      shadow>
    </browser-window>

    <code-block language="html" show-lines label="Complete contact form">{{ completeFormCode | escape }}</code-block>
  </section>

  <section>
    <h2>Why Use &lt;output&gt; for Messages?</h2>
    <ul>
      <li><strong>Purpose-built:</strong> Represents the result of a calculation or user action</li>
      <li><strong>Native association:</strong> Has <code>for</code> attribute to link to input(s)</li>
      <li><strong>Accessible:</strong> Works naturally with <code>aria-live</code> for screen readers</li>
      <li><strong>No JavaScript required:</strong> Can show different states via CSS</li>
    </ul>
  </section>

  <section>
    <h2>Accessibility Checklist</h2>
    <ul>
      <li>Every <code>&lt;input&gt;</code> has a <code>&lt;label&gt;</code> with matching <code>for</code>/<code>id</code></li>
      <li>Required fields use the <code>required</code> attribute</li>
      <li>Validation messages use <code>&lt;output&gt;</code> with <code>aria-live="polite"</code></li>
      <li>Inputs link to messages via <code>aria-describedby</code></li>
      <li>Form controls have appropriate <code>autocomplete</code> values</li>
      <li>Error states don't rely on color alone (include text)</li>
    </ul>
  </section>

