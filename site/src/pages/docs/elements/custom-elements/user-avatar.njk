---
layout: layouts/element.njk
title: "user-avatar"
description: "User profile images with fallback support and optional status indicators. Perfect for user interfaces and comment systems."
elementName: user-avatar
category: custom
currentPath: /docs/elements/custom-elements/user-avatar/
permalink: /docs/elements/custom-elements/user-avatar/
---

{% set sizesCode %}<user-avatar data-size="sm">
  <span data-fallback>SM</span>
</user-avatar>
<user-avatar data-size="lg">
  <span data-fallback>LG</span>
</user-avatar>{% endset %}

{% set withImageCode %}<user-avatar data-size="lg">
  <img src="user-photo.jpg" alt="Jane Doe" />
</user-avatar>{% endset %}

{% set fallbackCode %}<user-avatar data-size="lg">
  <span data-fallback>JD</span>
</user-avatar>{% endset %}

{% set shapesCode %}<user-avatar><span data-fallback>C</span></user-avatar>
<user-avatar data-shape="rounded"><span data-fallback>R</span></user-avatar>
<user-avatar data-shape="square"><span data-fallback>S</span></user-avatar>{% endset %}

{% set statusCode %}<user-avatar data-size="lg">
  <img src="user-photo.jpg" alt="User Name" />
  <span data-status="online"></span>
</user-avatar>{% endset %}

{% set groupCode %}<layout-cluster data-layout-overlap>
  <user-avatar><img src="user1.jpg" alt="User 1" /></user-avatar>
  <user-avatar><img src="user2.jpg" alt="User 2" /></user-avatar>
  <user-avatar><img src="user3.jpg" alt="User 3" /></user-avatar>
  <user-avatar><span data-fallback>+5</span></user-avatar>
</layout-cluster>{% endset %}

{% set ringCode %}<user-avatar data-size="lg" data-ring>
  <img src="user-photo.jpg" alt="User" />
</user-avatar>{% endset %}

<browser-window
    src="/docs/examples/demos/user-avatar-basic.html"
    url="https://vanilla-breeze.dev/user-avatar"
    title="User Avatar Demo"
    shadow>
  </browser-window>

  <section>
    <h2>Attributes</h2>
    <table class="props-table">
      <thead>
        <tr>
          <th>Attribute</th>
          <th>Values</th>
          <th>Default</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>data-size</code></td>
          <td><code>xs</code>, <code>sm</code>, <code>md</code>, <code>lg</code>, <code>xl</code>, <code>2xl</code></td>
          <td><code>md</code></td>
          <td>Avatar size</td>
        </tr>
        <tr>
          <td><code>data-shape</code></td>
          <td><code>square</code>, <code>rounded</code></td>
          <td>circle</td>
          <td>Border radius style</td>
        </tr>
        <tr>
          <td><code>data-ring</code></td>
          <td>boolean</td>
          <td>-</td>
          <td>Add border ring</td>
        </tr>
      </tbody>
    </table>
  </section>

  <section>
    <h2>Sizes</h2>
    <p>Avatars come in six sizes for different contexts.</p>

    <browser-window
      src="/docs/snippets/demos/user-avatar-sizes.html"
      url="https://vanilla-breeze.dev/user-avatar/sizes"
      title="Avatar sizes"
      shadow>
    </browser-window>

    <code-block language="html" show-lines label="Avatar sizes">{{ sizesCode | escape }}</code-block>
  </section>

  <section>
    <h2>With Image</h2>
    <p>Display a user's profile image.</p>

    <browser-window
      src="/docs/snippets/demos/user-avatar-images.html"
