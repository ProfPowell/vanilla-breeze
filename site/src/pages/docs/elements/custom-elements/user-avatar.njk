    <browser-window
      src="/docs/snippets/demos/user-avatar-fallback.html"
      url="https://vanilla-breeze.dev/user-avatar/fallback"
      title="Avatar with initials fallback"
      shadow>
    </browser-window>

    <code-block language="html" show-lines label="Avatar with initials fallback">{{ fallbackCode | escape }}</code-block>
