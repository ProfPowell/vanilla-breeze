---
layout: layouts/element.njk
title: "layout-cluster"
description: "Horizontal flex layout with wrapping. Ideal for groups of inline elements like buttons, tags, and navigation items."
elementName: layout-cluster
category: custom
currentPath: /docs/elements/custom-elements/cluster/
permalink: /docs/elements/custom-elements/cluster/
---

{% set gapVariantsCode %}<layout-cluster data-layout-gap="xs">
  <button type="button">Button</button>
  <button type="button">Button</button>
  <button type="button">Button</button>
</layout-cluster>{% endset %}

{% set justifyVariantsCode %}<!-- Items aligned to start (default) -->
<layout-cluster data-layout-justify="start">...</layout-cluster>

<!-- Items centered horizontally -->
<layout-cluster data-layout-justify="center">...</layout-cluster>

<!-- Items aligned to end -->
<layout-cluster data-layout-justify="end">...</layout-cluster>

<!-- Items spread with space between -->
<layout-cluster data-layout-justify="between">...</layout-cluster>{% endset %}

{% set alignVariantsCode %}<!-- Items aligned to top -->
<layout-cluster data-layout-align="start">...</layout-cluster>

<!-- Items centered vertically (default) -->
<layout-cluster data-layout-align="center">...</layout-cluster>

<!-- Items aligned to bottom -->
<layout-cluster data-layout-align="end">...</layout-cluster>

<!-- Items stretched to fill height -->
<layout-cluster data-layout-align="stretch">...</layout-cluster>

<!-- Items aligned by text baseline -->
<layout-cluster data-layout-align="baseline">...</layout-cluster>{% endset %}

{% set overlapCode %}<layout-cluster data-layout-overlap>
  <user-avatar><img src="user1.jpg" alt="User 1" /></user-avatar>
  <user-avatar><img src="user2.jpg" alt="User 2" /></user-avatar>
  <user-avatar><img src="user3.jpg" alt="User 3" /></user-avatar>
  <user-avatar><span data-fallback>+3</span></user-avatar>
</layout-cluster>{% endset %}

{% set buttonGroupCode %}<layout-cluster data-layout-gap="s">
  <button type="button">Save</button>
  <button type="button" class="secondary">Cancel</button>
  <button type="button" class="ghost">Reset</button>
</layout-cluster>{% endset %}

{% set tagCloudCode %}<layout-cluster data-layout-gap="xs">
  <span class="tag">HTML</span>
  <span class="tag">CSS</span>
  <span class="tag">JavaScript</span>
</layout-cluster>{% endset %}

{% set cardFooterCode %}<layout-cluster data-layout-gap="s" data-layout-justify="between">
  <layout-cluster data-layout-gap="xs">
    <button type="button">Edit</button>
    <button type="button">Delete</button>
  </layout-cluster>
  <button type="button">View Details</button>
</layout-cluster>{% endset %}

{% set navigationCode %}<layout-cluster data-layout-gap="l" data-layout-justify="between">
  <span class="logo">Logo</span>
  <layout-cluster data-layout-gap="m">
    <a href="#">Home</a>
    <a href="#">About</a>
    <a href="#">Services</a>
    <a href="#">Contact</a>
  </layout-cluster>
</layout-cluster>{% endset %}

<browser-window
    src="/docs/examples/demos/cluster-basic.html"
    url="https://vanilla-breeze.dev/cluster"
    title="Cluster Layout Demo"
    shadow>
  </browser-window>

  <section>
    <h2>Attributes</h2>
    <table class="props-table">
      <thead>
        <tr>
          <th>Attribute</th>
          <th>Values</th>
          <th>Default</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>data-layout-gap</code></td>
          <td><code>xs</code>, <code>s</code>, <code>m</code>, <code>l</code>, <code>xl</code></td>
          <td><code>s</code></td>
          <td>Controls the gap between items</td>
        </tr>
        <tr>
          <td><code>data-layout-justify</code></td>
          <td><code>start</code>, <code>end</code>, <code>center</code>, <code>between</code></td>
          <td><code>start</code></td>
          <td>Controls horizontal distribution of items</td>
        </tr>
        <tr>
          <td><code>data-layout-align</code></td>
          <td><code>start</code>, <code>end</code>, <code>center</code>, <code>stretch</code>, <code>baseline</code></td>
          <td><code>center</code></td>
          <td>Controls vertical alignment of items</td>
        </tr>
        <tr>
          <td><code>data-layout-nowrap</code></td>
          <td>boolean</td>
          <td>-</td>
          <td>Prevents items from wrapping to new lines</td>
        </tr>
        <tr>
          <td><code>data-layout-overlap</code></td>
          <td><code>xs</code>, <code>s</code>, <code>m</code>, <code>l</code>, or boolean</td>
          <td>-</td>
          <td>Creates overlapping items (for avatar groups, stacked cards)</td>
        </tr>
      </tbody>
    </table>
  </section>

  <section>
    <h2>Gap Variants</h2>
    <p>The <code>data-layout-gap</code> attribute controls spacing between items.</p>

    <browser-window
      src="/docs/snippets/demos/cluster-gap.html"
      url="https://vanilla-breeze.dev/cluster/gap"
      title="Cluster gap variants"
      shadow>
    </browser-window>

    <code-block language="html" show-lines label="Cluster with gap variant">{{ gapVariantsCode | escape }}</code-block>
  </section>

  <section>
    <h2>Justify Variants</h2>
