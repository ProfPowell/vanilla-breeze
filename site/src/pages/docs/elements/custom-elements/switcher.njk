    <code-block language="html" show-lines label="Threshold variants">{{ thresholdCode | escape }}</code-block>
  </section>

  <section>
    <h2>Item Limit</h2>
    <p>The <code>data-layout-limit</code> attribute forces vertical layout when there are more items than the limit.</p>

    <browser-window
      src="/docs/snippets/demos/switcher-limit.html"
