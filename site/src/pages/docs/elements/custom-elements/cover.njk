---
layout: layouts/element.njk
title: "layout-cover"
description: "Full-height container with vertically centered principal element. Perfect for hero sections, landing pages, and full-viewport layouts."
elementName: layout-cover
category: custom
currentPath: /docs/elements/custom-elements/cover/
permalink: /docs/elements/custom-elements/cover/
---

{% set basicUsageCode %}<layout-cover data-layout-min="100vh" data-layout-padding="m" data-layout-centered>
  <header>Header content</header>
  <div data-layout-principal>
    <h1>Principal Content</h1>
    <p>This is vertically centered</p>
  </div>
  <footer>Footer content</footer>
</layout-cover>{% endset %}

{% set heightVariantsCode %}<layout-cover data-layout-min="auto">...</layout-cover>
<layout-cover data-layout-min="50vh">...</layout-cover>
<layout-cover data-layout-min="75vh">...</layout-cover>
<layout-cover data-layout-min="100vh">...</layout-cover>
<layout-cover data-layout-min="100dvh">...</layout-cover>{% endset %}

{% set heroCode %}<layout-cover data-layout-min="100vh" data-layout-padding="xl" data-layout-centered>
  <header>
    <layout-cluster data-layout-gap="m" data-layout-justify="between">
      <strong>Brand</strong>
      <nav>...</nav>
    </layout-cluster>
  </header>
  <div data-layout-principal>
    <layout-stack data-layout-gap="l" data-layout-align="center">
      <h1>Welcome to Our Platform</h1>
      <p>Build amazing experiences with our tools.</p>
      <layout-cluster data-layout-gap="m">
        <button type="button">Get Started</button>
        <button type="button" class="secondary">Learn More</button>
      </layout-cluster>
    </layout-stack>
  </div>
  <footer>
    <small>Scroll down to explore</small>
  </footer>
</layout-cover>{% endset %}

{% set loginCode %}<layout-cover data-layout-min="100vh" data-layout-padding="l" data-layout-centered>
  <header>
    <strong>Brand Logo</strong>
  </header>
  <div data-layout-principal>
    <layout-card style="max-inline-size: 22rem;">
      <layout-stack data-layout-gap="m">
        <h2>Sign In</h2>
        <form>...</form>
      </layout-stack>
    </layout-card>
  </div>
  <footer>
    <small>Don't have an account? <a href="#">Sign up</a></small>
  </footer>
</layout-cover>{% endset %}

{% set customTopBottomCode %}<layout-cover data-layout-min="100vh" data-layout-padding="m" data-layout-gap="m">
  <nav class="breadcrumb" data-layout-cover-top aria-label="Breadcrumb">
    <ol>
      <li><a href="#">Home</a></li>
      <li><a href="#">Products</a></li>
      <li><span aria-current="page">Item</span></li>
    </ol>
  </nav>
  <div data-layout-principal>
    <layout-stack data-layout-gap="s">
      <strong>Product Details</strong>
      <p>Main content centered vertically.</p>
    </layout-stack>
  </div>
  <div data-layout-cover-bottom>
    <layout-cluster data-layout-gap="s" data-layout-justify="between">
      <span>Step 2 of 4</span>
      <layout-cluster data-layout-gap="s">
        <button type="button" class="secondary">Back</button>
        <button type="button">Next</button>
      </layout-cluster>
    </layout-cluster>
  </div>
</layout-cover>{% endset %}

<browser-window
    src="/docs/examples/demos/cover-basic.html"
    url="https://vanilla-breeze.dev/cover"
    title="Cover Layout Demo"
    shadow>
  </browser-window>

  <section>
    <h2>Attributes</h2>
    <table class="props-table">
      <thead>
        <tr>
          <th>Attribute</th>
          <th>Values</th>
          <th>Default</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>data-layout-min</code></td>
          <td><code>auto</code>, <code>50vh</code>, <code>75vh</code>, <code>100vh</code>, <code>100dvh</code></td>
          <td><code>100vh</code></td>
          <td>Minimum height of the cover</td>
        </tr>
        <tr>
          <td><code>data-layout-padding</code></td>
          <td><code>none</code>, <code>s</code>, <code>m</code>, <code>l</code>, <code>xl</code></td>
          <td><code>m</code></td>
          <td>Internal padding</td>
        </tr>
        <tr>
          <td><code>data-layout-gap</code></td>
          <td><code>s</code>, <code>m</code>, <code>l</code></td>
          <td>-</td>
          <td>Gap between non-centered elements</td>
        </tr>
        <tr>
          <td><code>data-layout-centered</code></td>
          <td>boolean</td>
          <td>-</td>
          <td>Centers content horizontally and adds text-align center</td>
        </tr>
        <tr>
          <td><code>data-layout-nospace</code></td>
          <td>boolean</td>
          <td>-</td>
          <td>Removes all padding</td>
        </tr>
      </tbody>
    </table>

    <h3>Child Attributes</h3>
    <table class="props-table">
      <thead>
        <tr>
          <th>Attribute</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>data-layout-principal</code></td>
          <td>Marks the element to be vertically centered</td>
        </tr>
        <tr>
          <td><code>data-layout-cover-top</code></td>
          <td>Pins element to the top (alternative to <code>&lt;header&gt;</code>)</td>
        </tr>
        <tr>
          <td><code>data-layout-cover-bottom</code></td>
          <td>Pins element to the bottom (alternative to <code>&lt;footer&gt;</code>)</td>
        </tr>
      </tbody>
    </table>
  </section>

  <section>
    <h2>Basic Usage</h2>
    <p>The cover layout vertically centers its principal element while header and footer stay at their respective edges.</p>

    <browser-window
      src="/docs/snippets/demos/cover-basic.html"
      url="https://vanilla-breeze.dev/cover/basic"
      title="Basic cover layout"
      shadow>
    </browser-window>

    <code-block language="html" show-lines label="Basic layout-cover with header, principal, and footer">{{ basicUsageCode | escape }}</code-block>
  </section>

