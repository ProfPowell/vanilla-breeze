{% set basicCode %}<text-reader for="my-article" speed="1"></text-reader>

<article id="my-article">
  <p>The web platform has evolved dramatically over the past decade.
     Modern browsers now support features that previously required
     complex JavaScript libraries or plugins.</p>
  <p>Progressive enhancement remains the most resilient approach
     to building for the web.</p>
</article>{% endset %}

{% set customIconCode %}<text-reader for="my-article">
  <icon-wc slot="icon-play" name="play" aria-hidden="true"></icon-wc>
  <icon-wc slot="icon-pause" name="pause" aria-hidden="true"></icon-wc>
  <icon-wc slot="icon-stop" name="square" aria-hidden="true"></icon-wc>
</text-reader>{% endset %}

{% set themingCode %}text-reader {
  --text-reader-bg: var(--color-surface-raised);
  --text-reader-gap: 0.75rem;
  --text-reader-button-size: 2.5rem;
  --text-reader-highlight: oklch(85% 0.15 90);
  --text-reader-highlight-text: oklch(20% 0 0);
}{% endset %}

{% set apiCode %}const reader = document.querySelector('text-reader');

reader.play();     // Begin or resume playback
reader.pause();    // Pause mid-sentence
reader.resume();   // Resume from pause
reader.stop();     // Cancel and reset

// Read-only properties
reader.speaking;   // boolean
reader.paused;     // boolean
reader.progress;   // 0–1 (charIndex / fullText.length)

// Get available voices
const voices = await reader.voices;{% endset %}

{% set eventCode %}const reader = document.querySelector('text-reader');

reader.addEventListener('text-reader:play', e => {
  console.log('Playing at speed:', e.detail.speed);
});

reader.addEventListener('text-reader:word', e => {
  console.log('Word:', e.detail.word);
});

reader.addEventListener('text-reader:end', e => {
  console.log('Finished in', e.detail.duration, 'ms');
});{% endset %}

  <section>
    <h2>Overview</h2>
    <p>The <code>&lt;text-reader&gt;</code> component attaches a text-to-speech control bar to any element. It uses the <strong>Web Speech API</strong> for synthesis and the <strong>CSS Custom Highlight API</strong> for real-time word tracking. Progressive enhancement &mdash; the component hides itself if the browser lacks <code>speechSynthesis</code>.</p>

    <browser-window
      src="/docs/examples/demos/text-reader-basic.html"
      url="https://vanilla-breeze.dev/text-reader"
      title="Text Reader Demo"
      shadow>
    </browser-window>

    <code-block language="html" show-lines label="Basic usage">{{ basicCode | escape }}</code-block>

    <aside class="note">
      <strong>Zero dependencies.</strong> Uses built-in browser APIs only &mdash; no external TTS service or library required.
    </aside>
  </section>

  <section>
    <h2>Attributes</h2>
    <table class="props-table">
      <thead>
        <tr><th>Attribute</th><th>Type</th><th>Default</th><th>Description</th></tr>
      </thead>
      <tbody>
        <tr><td><code>for</code></td><td>string</td><td>&mdash;</td><td>ID of the element to read. <strong>Required.</strong></td></tr>
        <tr><td><code>selectors</code></td><td>string</td><td><code>p,li</code></td><td>Comma-separated CSS selectors for text extraction within the target</td></tr>
        <tr><td><code>speed</code></td><td>number</td><td><code>1</code></td><td>Initial playback rate (0.5&ndash;2)</td></tr>
        <tr><td><code>voice</code></td><td>string</td><td>&mdash;</td><td><code>voiceURI</code> to pre-select on load</td></tr>
        <tr><td><code>highlight</code></td><td>string</td><td>&mdash;</td><td>Set to <code>"false"</code> to disable word highlighting</td></tr>
        <tr><td><code>scroll</code></td><td>string</td><td>&mdash;</td><td>Set to <code>"false"</code> to disable auto-scroll to active word</td></tr>
        <tr><td><code>label-play</code></td><td>string</td><td><code>Play</code></td><td>Accessible label for the play button</td></tr>
        <tr><td><code>label-pause</code></td><td>string</td><td><code>Pause</code></td><td>Accessible label for the pause button</td></tr>
        <tr><td><code>label-stop</code></td><td>string</td><td><code>Stop</code></td><td>Accessible label for the stop button</td></tr>
      </tbody>
    </table>
  </section>

  <section>
    <h2>Observed Attributes</h2>
    <p>These attributes are reactive &mdash; changing them at runtime triggers an update:</p>
    <table class="props-table">
      <thead>
        <tr><th>Attribute</th><th>Behavior on Change</th></tr>
      </thead>
      <tbody>
        <tr><td><code>speed</code></td><td>Restarts speech from the current word at the new rate</td></tr>
        <tr><td><code>voice</code></td><td>Restarts speech from the current word with the new voice</td></tr>
        <tr><td><code>for</code></td><td>Stops current speech, re-resolves target element</td></tr>
      </tbody>
    </table>
  </section>

