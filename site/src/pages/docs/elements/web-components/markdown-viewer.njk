  <section>
    <h2>Progressive Enhancement</h2>
    <p>The <code>&lt;pre&gt;</code> slot provides the best progressive enhancement:</p>
    <table class="props-table">
      <thead>
        <tr><th>Slot</th><th>JS disabled</th><th>Crawlable</th><th>Recommended for</th></tr>
      </thead>
      <tbody>
        <tr><td><code>src</code></td><td>Nothing visible</td><td>No</td><td>External files</td></tr>
        <tr><td><code>&lt;script&gt;</code></td><td>Nothing visible</td><td>No</td><td>Build-time content</td></tr>
        <tr><td><code>&lt;template&gt;</code></td><td>Nothing visible</td><td>No</td><td>Framework content</td></tr>
        <tr><td><strong><code>&lt;pre&gt;</code></strong></td><td>Raw text visible</td><td>Yes</td><td><strong>Progressive enhancement</strong></td></tr>
      </tbody>
    </table>
  </section>
