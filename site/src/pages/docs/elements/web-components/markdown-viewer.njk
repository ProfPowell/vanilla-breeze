  <section>
    <h2>JavaScript API</h2>
    <table class="props-table">
      <thead>
        <tr><th>Property / Method</th><th>Description</th></tr>
      </thead>
      <tbody>
        <tr><td><code>.parser</code></td><td>Get/set custom parser function (md &rarr; html string). Overrides the default marked parser.</td></tr>
        <tr><td><code>.render()</code></td><td>Force a re-render from the current content source. Returns a Promise.</td></tr>
        <tr><td><code>.reload()</code></td><td>Re-fetch the <code>src</code> URL and re-render. Returns a Promise.</td></tr>
      </tbody>
