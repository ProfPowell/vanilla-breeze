  <section>
    <h2>Overview</h2>
    <p>A single component for displaying any design token scale. The <code>type</code> attribute controls the visual rendering while sharing the same core API across all token categories.</p>
    <p>Part of the <a href="/docs/packs/design-system/">Design System Pack</a>.</p>
  </section>

  <section>
    <h2>Types</h2>

    <h3>Shadow</h3>
    <p>Cards with applied box-shadow at each elevation step.</p>
    <code-block language="html" show-lines label="Shadow specimen">{{ shadowCode | escape }}</code-block>

    <h3>Radius</h3>
    <p>Squares with applied border-radius at each scale step.</p>
    <code-block language="html" show-lines label="Radius specimen">{{ radiusCode | escape }}</code-block>

    <h3>Border</h3>
    <p>Lines at each border width.</p>
    <code-block language="html" show-lines label="Border specimen">{{ borderCode | escape }}</code-block>

    <h3>Color</h3>
    <p>Swatches for color tokens.</p>
    <code-block language="html" show-lines label="Color specimen">{{ colorCode | escape }}</code-block>

    <h3>Size</h3>
    <p>Horizontal bars showing spacing values (same visualization as <code>&lt;spacing-specimen&gt;</code>).</p>
    <code-block language="html" show-lines label="Size specimen">{{ sizeCode | escape }}</code-block>
  </section>

  <section>
    <h2>Custom Tokens</h2>
    <p>Override <code>tokens</code> and <code>prefix</code> to display any set of CSS custom properties.</p>
    <code-block language="html" show-lines label="Custom prefix">{{ customCode | escape }}</code-block>
  </section>

