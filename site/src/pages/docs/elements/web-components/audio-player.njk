{% set basicCode %}<audio-player src="track.mp3" data-title="Demo Track">
  <audio controls src="track.mp3">
    Your browser does not support the audio element.
  </audio>
</audio-player>{% endset %}

{% set barsCode %}<audio-player src="track.mp3" data-visualizer="bars"
  data-title="Spectrum Bars">
  <audio controls src="track.mp3"></audio>
</audio-player>{% endset %}

{% set circleCode %}<audio-player src="track.mp3" data-visualizer="circle"
  data-title="Radial Mode">
  <audio controls src="track.mp3"></audio>
</audio-player>{% endset %}

{% set miniCode %}<audio-player src="track.mp3" data-size="mini"
  data-title="Mini Player">
  <audio controls src="track.mp3"></audio>
</audio-player>{% endset %}

{% set customCode %}<audio-player src="track.mp3" data-title="Pink Signal"
  style="--audioplayer-screen-color: oklch(72% 0.3 340);
         --audioplayer-bg: oklch(12% 0.03 300);">
  <audio controls src="track.mp3"></audio>
</audio-player>{% endset %}

{% set loopCode %}<audio-player src="track.mp3" autoplay loop
  data-title="Looping Track">
  <audio controls src="track.mp3"></audio>
</audio-player>{% endset %}

{% set eventCode %}const player = document.querySelector('audio-player');

player.addEventListener('vb:audioplayer:play', (e) => {
  console.log('Playing:', e.detail.src);
});

player.addEventListener('vb:audioplayer:pause', (e) => {
  console.log('Paused at:', e.detail.currentTime);
});

player.addEventListener('vb:audioplayer:ended', (e) => {
  console.log('Track ended:', e.detail.src);
});

player.addEventListener('vb:audioplayer:timeupdate', (e) => {
  const { currentTime, duration, progress } = e.detail;
  console.log(`${progress.toFixed(1)}% complete`);
});{% endset %}

{% set partCode %}audio-player::part(bezel) {
  border-color: oklch(50% 0.2 290);
}

audio-player::part(screen) {
  border-radius: 8px;
}

audio-player::part(play-button):hover {
  box-shadow: 0 0 20px oklch(70% 0.3 290 / 0.6);
}{% endset %}

<section>
  <h2>Overview</h2>
  <p>A CRT-inspired audio player with three visualizer modes (waveform, spectrum bars, radial), an 8-bar VU meter, scan-line overlay, and beveled chrome. Ships as part of the <a href="/docs/packs/retro/">retro pack</a>.</p>
  <p>Progressive enhancement: slot an <code>&lt;audio&gt;</code> element inside for a native fallback when JS is unavailable.</p>
</section>

<section>
  <h2>Basic Usage</h2>
  <code-block language="html" label="Default (waveform)">{{ basicCode | escape }}</code-block>
</section>

<section>
  <h2>Visualizer Modes</h2>
  <p>Set <code>data-visualizer</code> to change the canvas rendering mode.</p>

  <table>
    <thead><tr><th>Value</th><th>Description</th></tr></thead>
    <tbody>
      <tr><td><code>wave</code> (default)</td><td>Time-domain oscilloscope waveform with phosphor glow</td></tr>
      <tr><td><code>bars</code></td><td>Frequency spectrum bar graph</td></tr>
      <tr><td><code>circle</code></td><td>Radial frequency visualization</td></tr>
    </tbody>
  </table>

  <code-block language="html" label="Spectrum bars">{{ barsCode | escape }}</code-block>
  <code-block language="html" label="Radial mode">{{ circleCode | escape }}</code-block>
</section>

<section>
  <h2>Mini Form Factor</h2>
  <p>Add <code>data-size="mini"</code> for a compact single-row player. The screen and VU meters are hidden; track title and time display are inlined in the controls row.</p>
  <code-block language="html" label="Mini player">{{ miniCode | escape }}</code-block>
</section>

<section>
  <h2>Custom Colors</h2>
  <p>Override component tokens inline or via a parent selector. The player inherits from the active theme but allows per-instance customization.</p>
  <code-block language="html" label="Custom screen and body colors">{{ customCode | escape }}</code-block>
</section>

<section>
  <h2>Autoplay and Loop</h2>
  <code-block language="html" label="Autoplay with loop">{{ loopCode | escape }}</code-block>
</section>

