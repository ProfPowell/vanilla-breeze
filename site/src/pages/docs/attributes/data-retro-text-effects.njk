<section id="rainbow">
  <h2>data-rainbow</h2>
  <p>Continuous hue-rotation filter that cycles through the full color spectrum.</p>

  <code-block language="html" show-lines label="Rainbow cycling">{{ rainbowCode | escape }}</code-block>

  <h3>Attributes</h3>
  <table class="props-table">
