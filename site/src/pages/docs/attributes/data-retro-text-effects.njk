    </thead>
    <tbody>
      <tr><td><code>data-rainbow</code></td><td><code>""</code> (4s), <code>"slow"</code> (8s), <code>"fast"</code> (1.5s)</td><td>Cycle speed preset.</td></tr>
    </tbody>
  </table>

  <h3>CSS Custom Properties</h3>
  <table class="props-table">
