<!-- Neon -->
<section id="neon">
  <h2>data-neon</h2>
  <p>Glowing neon text with a pulsing text-shadow halo that breathes in and out over 2.5 seconds. Choose from six color presets or use the theme primary.</p>

  <code-block language="html" show-lines label="Neon text">{{ neonCode | escape }}</code-block>

  <h3>Attributes</h3>
  <table class="props-table">
    <thead>
      <tr><th>Attribute</th><th>Values</th><th>Description</th></tr>
    </thead>
    <tbody>
      <tr><td><code>data-neon</code></td><td><code>""</code>, <code>"pink"</code>, <code>"cyan"</code>, <code>"green"</code>, <code>"amber"</code>, <code>"red"</code></td><td>Neon color preset. Empty uses theme primary.</td></tr>
    </tbody>
  </table>

  <h3>CSS Custom Properties</h3>
  <table class="props-table">
    <thead>
      <tr><th>Property</th><th>Default</th><th>Description</th></tr>
    </thead>
    <tbody>
      <tr><td><code>--vb-neon-color</code></td><td>Per preset</td><td>The glow color in OKLCH.</td></tr>
      <tr><td><code>--vb-neon-spread</code></td><td><code>0.04em</code></td><td>Glow blur radius for the text-shadow.</td></tr>
    </tbody>
  </table>
</section>

<!-- 3D Text -->
<section id="text-3d">
  <h2>data-text-3d</h2>
  <p>Bold text with layered drop-shadows creating a 3D extrusion effect. Stacked shadows at 1px increments build up visual depth. Sets <code>font-weight: 900</code> automatically.</p>

  <code-block language="html" show-lines label="3D text">{{ text3dCode | escape }}</code-block>

  <h3>Modifiers</h3>
  <p>Combine the color with space-separated modifiers:</p>
  <code-block language="html" show-lines label="3D modifiers">{{ text3dModCode | escape }}</code-block>

  <h3>Attributes</h3>
  <table class="props-table">
    <thead>
      <tr><th>Attribute</th><th>Values</th><th>Description</th></tr>
    </thead>
    <tbody>
      <tr><td><code>data-text-3d</code></td><td><code>""</code>, <code>"red"</code>, <code>"gold"</code>, <code>"green"</code>, <code>"purple"</code>, <code>"black"</code></td><td>Shadow color preset. Empty uses a dark default.</td></tr>
      <tr><td>(modifier) <code>deep</code></td><td>space-separated</td><td>Doubles shadow angle to 2px for a deeper extrusion (10 layers).</td></tr>
      <tr><td>(modifier) <code>animate</code></td><td>space-separated</td><td>Oscillates shadow direction left/right over 3 seconds.</td></tr>
    </tbody>
  </table>

  <h3>CSS Custom Properties</h3>
  <table class="props-table">
    <thead>
      <tr><th>Property</th><th>Default</th><th>Description</th></tr>
    </thead>
    <tbody>
      <tr><td><code>--vb-3d-color</code></td><td>Per preset</td><td>The extrusion color in OKLCH.</td></tr>
      <tr><td><code>--vb-3d-angle</code></td><td><code>1px</code></td><td>Shadow offset per layer. <code>deep</code> sets this to 2px.</td></tr>
    </tbody>
  </table>
</section>

<!-- Outline -->
<section id="outline">
  <h2>data-outline</h2>
  <p>Hollow outlined text with transparent fill using <code>-webkit-text-stroke</code>. Gracefully skipped in browsers without support via <code>@supports</code>.</p>

  <code-block language="html" show-lines label="Outline text">{{ outlineCode | escape }}</code-block>

  <h3>Attributes</h3>
  <table class="props-table">
    <thead>
      <tr><th>Attribute</th><th>Values</th><th>Description</th></tr>
    </thead>
    <tbody>
      <tr><td><code>data-outline</code></td><td><code>""</code> (1px), <code>"thick"</code> (2px), <code>"ultra"</code> (3px), <code>"glow"</code></td><td>Stroke width or glow mode.</td></tr>
    </tbody>
  </table>

  <h3>CSS Custom Properties</h3>
  <table class="props-table">
    <thead>
      <tr><th>Property</th><th>Default</th><th>Description</th></tr>
    </thead>
    <tbody>
      <tr><td><code>--vb-outline-width</code></td><td><code>1px</code></td><td>Stroke width.</td></tr>
      <tr><td><code>--vb-outline-color</code></td><td><code>var(--color-text)</code></td><td>Stroke color.</td></tr>
      <tr><td><code>--vb-outline-glow</code></td><td>Derived</td><td>Glow color when <code>"glow"</code> variant is active.</td></tr>
    </tbody>
  </table>
</section>

<!-- Blink -->
<section id="blink">
  <h2>data-blink</h2>
  <p>Text flashes on and off with a step animation, toggling between full and 50% opacity.</p>

  <code-block language="html" show-lines label="Blinking text">{{ blinkCode | escape }}</code-block>

  <h3>Attributes</h3>
  <table class="props-table">
    <thead>
      <tr><th>Attribute</th><th>Values</th><th>Description</th></tr>
    </thead>
    <tbody>
      <tr><td><code>data-blink</code></td><td><code>""</code> (1s), <code>"slow"</code> (2s), <code>"fast"</code> (0.4s)</td><td>Blink rate preset.</td></tr>
    </tbody>
  </table>

  <h3>CSS Custom Properties</h3>
  <table class="props-table">
    <thead>
      <tr><th>Property</th><th>Default</th><th>Description</th></tr>
    </thead>
    <tbody>
      <tr><td><code>--vb-blink-rate</code></td><td><code>1s</code></td><td>Duration of one blink cycle.</td></tr>
    </tbody>
  </table>
</section>

<!-- Retro Shadow -->
<section id="retro-shadow">
  <h2>data-retro-shadow</h2>
  <p>Hard-edged retro text shadows. Choose single, double, or long trailing shadows with optional color presets. Sets <code>font-weight: 900</code>.</p>

  <code-block language="html" show-lines label="Retro shadow">{{ shadowCode | escape }}</code-block>

  <h3>Color Variants</h3>
  <p>Space-separate the style and color:</p>
  <code-block language="html" show-lines label="Colored shadows">{{ shadowColorCode | escape }}</code-block>

  <h3>Attributes</h3>
  <table class="props-table">
    <thead>
      <tr><th>Attribute</th><th>Values</th><th>Description</th></tr>
    </thead>
    <tbody>
      <tr><td><code>data-retro-shadow</code></td><td><code>""</code>, <code>"double"</code>, <code>"long"</code></td><td>Shadow depth style.</td></tr>
      <tr><td>(color) <code>red</code>, <code>blue</code>, <code>gold</code>, <code>green</code></td><td>space-separated</td><td>Shadow color preset. Can combine with style.</td></tr>
    </tbody>
  </table>

  <h3>CSS Custom Properties</h3>
  <table class="props-table">
    <thead>
      <tr><th>Property</th><th>Default</th><th>Description</th></tr>
    </thead>
    <tbody>
      <tr><td><code>--vb-shadow-color</code></td><td><code>oklch(20% 0 0)</code></td><td>Shadow color.</td></tr>
      <tr><td><code>--vb-shadow-offset</code></td><td><code>3px</code></td><td>Base shadow offset distance.</td></tr>
    </tbody>
  </table>
</section>

