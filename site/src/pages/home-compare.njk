                <h3>Settings</h3>
                <accordion-wc>
                  <details name="settings-compare-js">
                    <summary>Appearance</summary>
                    <form class="stacked">
                      <label>Theme
                        <select id="demo-compare-js-theme" name="theme">
                          <option>Default</option>
                          <option>Ocean</option>
                          <option>Forest</option>
                        </select>
                      </label>
                      <label>
                        <input type="checkbox" id="demo-compare-js-dark" checked> Dark mode
                      </label>
                    </form>
                  </details>
                  <details name="settings-compare-js">
                    <summary>Keyboard Shortcuts</summary>
                    <dl>
                      <div><dt>Search</dt> <dd><kbd>Ctrl</kbd>+<kbd>K</kbd></dd></div>
                      <div><dt>Save</dt> <dd><kbd>Ctrl</kbd>+<kbd>S</kbd></dd></div>
                      <div><dt>Shortcuts</dt> <dd><kbd>Shift</kbd>+<kbd>?</kbd></dd></div>
                    </dl>
                  </details>
                  <details name="settings-compare-js">
                    <summary>Notifications</summary>
