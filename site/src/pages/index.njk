---
layout: layouts/base.njk
title: A Layered HTML Component System
description: "Build with native HTML elements, enhance progressively with CSS custom elements and JavaScript web components. Zero dependencies, no build step required."
dataPage: docs
currentSection: home
includeDocs: true
permalink: /
---

{% block extraHead %}
<style>
  /* Hero Section */
  .hero {
    padding-block: var(--size-2xl) var(--size-3xl);
    text-align: center;
  }

  .hero h1 {
    font-size: clamp(var(--font-size-2xl), 5vw, var(--font-size-4xl));
    margin-block-end: var(--size-s);
  }

  .hero .tagline {
    font-size: var(--font-size-lg);
    color: var(--color-text-muted);
    max-inline-size: 50ch;
    margin-inline: auto;
    margin-block-end: var(--size-xl);
  }

  .hero-demo {
    margin-block: var(--size-xl);
    max-inline-size: var(--content-wide);
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--size-l);
    align-items: stretch;
  }

  .hero-demo code-block {
    margin: 0;
    text-align: start;
    block-size: 100%;
  }

  .hero-demo browser-window {
    margin: 0;
    resize: none;
    text-align: start;
    block-size: 100%;
  }

  .demo-result {
    padding: var(--size-l);
  }

  .catchphrase {
    font-size: clamp(var(--font-size-lg), 3vw, var(--font-size-2xl));
    font-weight: 600;
    margin-block: var(--size-xl);
    color: var(--color-text);
  }

  .catchphrase .highlight {
    color: var(--color-interactive);
  }

  .catchphrase .muted {
    color: var(--color-text-muted);
  }

  @media (max-width: 900px) {
    .hero-demo,
    .pe-section .pe-panel {
      grid-template-columns: 1fr;
    }
  }

  /* Reset docs.css footer overrides for homepage sections */
  .hero footer,
  .pe-section footer {
    padding: 0;
    border-block-start: none;
    text-align: start;
    font-size: inherit;
  }

  /* Features Grid */
  .features-section {
    padding-block: var(--size-2xl);
    background: var(--color-surface-raised);
    margin-inline: calc(-1 * var(--size-l));
    padding-inline: var(--size-l);
  }

  .features-section h2 {
    text-align: center;
    margin-block-end: var(--size-xl);
  }

  .features-section ul,
  .quicknav-section ul {
    max-inline-size: var(--content-wide);
    margin-inline: auto;
    list-style: none;
    padding: 0;
  }

  /* Subgrid: align card headings/bodies across rows regardless of font */
  .features-section [data-layout="grid"] > li {
    display: grid;
    grid-row: span 2;
    grid-template-rows: subgrid;
  }

  .features-section [data-layout="grid"] > li > article {
    display: grid;
    grid-row: span 2;
    grid-template-rows: subgrid;
  }

  @supports not (grid-template-rows: subgrid) {
    .features-section [data-layout="grid"] > li {
      grid-row: auto;
    }
    .features-section [data-layout="grid"] > li > article {
      grid-row: auto;
    }
  }

  .features-section article {
    padding: var(--size-l);
  }

  .features-section article h3 {
    display: flex;
    align-items: center;
    gap: var(--size-s);
    margin-block-end: var(--size-xs);
  }

  .features-section article p {
    color: var(--color-text-muted);
    margin: 0;
  }

  /* Progressive Enhancement Demo */
  .pe-section {
    padding-block: var(--size-2xl);
    border-block-start: var(--border-width-thin) solid var(--color-border);
  }

  .pe-section h2 {
    text-align: center;
    margin-block-end: var(--size-s);
  }

  .pe-lead {
    text-align: center;
    color: var(--color-text-muted);
    max-inline-size: 55ch;
    margin-inline: auto;
    margin-block-end: var(--size-xl);
  }

  .pe-section .pe-panel {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--size-l);
    align-items: stretch;
  }

  .pe-panel code-block {
    margin: 0;
    max-block-size: 24rem;
    overflow: auto;
  }

  .pe-panel browser-window {
    margin: 0;
    resize: none;
    block-size: 100%;
  }

  .pe-caption {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    margin-block-start: var(--size-s);
    grid-column: 1 / -1;
  }

  .pe-meta {
    text-align: center;
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin-block-start: var(--size-m);
  }

  .pe-unstyled,
  .pe-unstyled *,
  .pe-unstyled *::before,
  .pe-unstyled *::after {
    all: revert;
  }

  .pe-unstyled {
    padding: var(--size-l);
  }

  /* Theme Showcase */
  .theme-section {
    padding-block: var(--size-2xl);
    border-block-start: var(--border-width-thin) solid var(--color-border);
  }

  .theme-section h2 {
    text-align: center;
    margin-block-end: var(--size-s);
  }

  .theme-lead {
    text-align: center;
    color: var(--color-text-muted);
    max-inline-size: 50ch;
    margin-inline: auto;
    margin-block-end: var(--size-xl);
  }

  /* Scope dark color-scheme to preview content only (not the theme select) */
  .theme-lab[data-theme~="terminal"] > :is(layout-card, .theme-lab-wide),
  .theme-lab[data-theme~="8bit"] > :is(layout-card, .theme-lab-wide) {
    color-scheme: dark;
  }

  /* Explicit default reset — re-assert VB base tokens so the preview
     is isolated from whatever theme the page carries on <html>. */
  .theme-lab[data-theme~="default"] {
    color-scheme: light dark;
    --hue-primary: 260;
    --hue-secondary: 200;
    --hue-accent: 30;
    --color-primary: oklch(50% 0.2 var(--hue-primary));
    --color-primary-hover: oklch(from var(--color-primary) calc(l - 0.08) calc(c + 0.02) h);
    --color-primary-subtle: oklch(from var(--color-primary) 0.95 0.03 h);
    --color-secondary: oklch(50% 0.08 var(--hue-secondary));
    --color-accent: oklch(65% 0.18 var(--hue-accent));
    --color-accent-hover: oklch(from var(--color-accent) calc(l - 0.08) c h);
    --color-interactive: var(--color-primary);
    --color-interactive-hover: var(--color-primary-hover);
    --color-background: light-dark(var(--color-white), var(--color-gray-950));
    --color-surface: light-dark(var(--color-white), var(--color-gray-900));
    --color-surface-raised: light-dark(var(--color-gray-50), var(--color-gray-800));
    --color-surface-sunken: light-dark(var(--color-gray-100), var(--color-gray-950));
    --color-text: light-dark(var(--color-gray-900), var(--color-gray-100));
    --color-text-muted: light-dark(var(--color-gray-600), var(--color-gray-400));
    --color-text-subtle: light-dark(var(--color-gray-500), var(--color-gray-500));
    --color-border: light-dark(var(--color-gray-200), var(--color-gray-700));
    --color-border-strong: light-dark(var(--color-gray-300), var(--color-gray-600));
    --color-border-subtle: light-dark(var(--color-gray-100), var(--color-gray-800));
    --font-sans: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    --font-mono: ui-monospace, "Cascadia Code", "Source Code Pro", Menlo, monospace;
    --radius-xs: 0.125rem;
    --radius-s: 0.25rem;
    --radius-m: 0.5rem;
    --radius-l: 0.75rem;
    --radius-xl: 1rem;
    --radius-2xl: 1.5rem;
    --shadow-xs: 0 1px 2px 0 hsl(0 0% 0% / 0.05);
    --shadow-sm: 0 1px 3px 0 hsl(0 0% 0% / 0.1), 0 1px 2px -1px hsl(0 0% 0% / 0.1);
    --shadow-md: 0 4px 6px -1px hsl(0 0% 0% / 0.1), 0 2px 4px -2px hsl(0 0% 0% / 0.1);
    --shadow-lg: 0 10px 15px -3px hsl(0 0% 0% / 0.1), 0 4px 6px -4px hsl(0 0% 0% / 0.1);
    --duration-instant: 50ms;
    --duration-fast: 100ms;
    --duration-normal: 200ms;
    --duration-slow: 300ms;
    --ease-default: cubic-bezier(0.4, 0, 0.2, 1);
    --ease-out: cubic-bezier(0, 0, 0.3, 1);
    --line-height-normal: 1.5;
    --line-height-tight: 1.25;
    --font-weight-normal: 400;
    --font-weight-bold: 700;
  }

  .theme-lab {
    max-inline-size: 32rem;
    margin-inline: auto;
  }

  .theme-lab figcaption {
    margin-block-end: var(--size-m);
  }

  .theme-lab-wide {
    display: none;
  }

  @media (min-width: 60rem) {
    .theme-lab {
      max-inline-size: 56rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--size-l);
    }

    .theme-lab figcaption {
      grid-column: 1 / -1;
    }

    .theme-lab-wide {
      display: flex;
      flex-direction: column;
      gap: var(--size-m);
    }
  }

  /* Demo result content styling */
  .demo-result h1 {
    margin: 0;
  }

  .demo-result p {
    margin: 0;
    color: var(--color-text-muted);
  }

  /* Stats Bar */
  .stats-bar {
    padding: var(--size-l);
    margin-block: var(--size-xl);
  }

  .stat {
    display: flex;
    flex-direction: column-reverse;
    margin: 0;
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: var(--font-size-3xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-interactive);
    line-height: 1;
  }

  .stat-label {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  /* Quick Navigation */
  .quicknav-section {
    padding-block: var(--size-2xl);
    border-block-start: var(--border-width-thin) solid var(--color-border);
  }

  .quicknav-section h2 {
    text-align: center;
    margin-block-end: var(--size-xl);
  }

  .quicknav-section a {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--size-xs);
    padding: var(--size-l);
    background: var(--color-surface);
    border: var(--border-width-thin) solid var(--color-border);
    border-radius: var(--radius-m);
    text-decoration: none;
    color: var(--color-text);
    text-align: center;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .quicknav-section a:hover {
    border-color: var(--color-interactive);
    box-shadow: 0 4px 12px oklch(0% 0 0 / 0.1);
  }

  .quicknav-section a span {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .quicknav-section [data-layout="grid"] > li {
    display: grid;
    grid-row: span 3;
    grid-template-rows: subgrid;
  }

  .quicknav-section [data-layout="grid"] > li > a {
    display: grid;
    grid-row: span 3;
    grid-template-rows: subgrid;
  }

  @supports not (grid-template-rows: subgrid) {
    .quicknav-section [data-layout="grid"] > li {
      grid-row: auto;
    }
  }
</style>
{% endblock %}

{% block pageContent %}
<main data-pagefind-body>
  <!-- Hero Section -->
  <section class="hero">
    <h1 data-gradient-text data-gradient-text-animate>Vanilla Breeze</h1>
    <p class="tagline">A layered HTML component system. Build with native HTML, enhance with CSS, add interactivity with JavaScript - each layer optional.</p>

    <figure class="hero-demo">
      <code-block language="html" label="Write this...">&lt;section data-layout="stack"&gt;
  &lt;h1&gt;Dashboard&lt;/h1&gt;

  &lt;nav data-layout="cluster"&gt;
    &lt;button&gt;New Project&lt;/button&gt;
    &lt;button class="secondary"&gt;Import&lt;/button&gt;
  &lt;/nav&gt;

  &lt;table&gt;
    &lt;thead&gt;
      &lt;tr&gt;&lt;th&gt;Project&lt;/th&gt;&lt;th&gt;Tasks&lt;/th&gt;&lt;/tr&gt;
    &lt;/thead&gt;
    &lt;tbody&gt;
      &lt;tr&gt;&lt;td&gt;Website Redesign&lt;/td&gt;&lt;td&gt;12&lt;/td&gt;&lt;/tr&gt;
      &lt;tr&gt;&lt;td&gt;Mobile App&lt;/td&gt;&lt;td&gt;8&lt;/td&gt;&lt;/tr&gt;
    &lt;/tbody&gt;
  &lt;/table&gt;

  &lt;details&gt;
    &lt;summary&gt;Filters&lt;/summary&gt;
    &lt;form class="stacked"&gt;
      &lt;label&gt;Status
        &lt;select&gt;
          &lt;option&gt;All&lt;/option&gt;
          &lt;option&gt;Active&lt;/option&gt;
        &lt;/select&gt;
      &lt;/label&gt;
      &lt;button&gt;Apply&lt;/button&gt;
    &lt;/form&gt;
  &lt;/details&gt;
&lt;/section&gt;</code-block>
      <browser-window url="...get this">
        <output class="demo-result">
          <section data-layout="stack">
            <h1>Dashboard</h1>
            <nav data-layout="cluster">
              <button type="button">New Project</button>
              <button type="button" class="secondary">Import</button>
            </nav>
            <table>
              <thead>
                <tr><th>Project</th><th>Tasks</th></tr>
              </thead>
              <tbody>
                <tr><td>Website Redesign</td><td>12</td></tr>
                <tr><td>Mobile App</td><td>8</td></tr>
              </tbody>
            </table>
            <details>
              <summary>Filters</summary>
              <form class="stacked">
                <label>Status
                  <select id="demo-hero-status" name="status">
                    <option>All</option>
                    <option>Active</option>
                  </select>
                </label>
                <button type="button">Apply</button>
              </form>
            </details>
          </section>
        </output>
      </browser-window>
    </figure>

    <p class="catchphrase">
      <span class="highlight" data-shimmer>Native HTML</span>
      <span class="muted">&gt;</span>
      <code>&lt;div&gt;</code> Soup
    </p>

    <footer data-layout="cluster" data-layout-justify="center" data-layout-gap="m">
      <a href="/docs/quick-start/" class="button">Get Started</a>
      <a href="/docs/examples/kitchen-sink/" class="button secondary">View Examples</a>
      <a href="https://github.com/profpowell/vanilla-breeze" class="button secondary">
        <icon-wc name="github" size="sm"></icon-wc>
        GitHub
      </a>
    </footer>
  </section>

  <!-- Stats -->
  <dl data-layout="cluster" class="stats-bar" data-layout-justify="center" data-layout-gap="2xl">
    <div class="stat">
      <dt class="stat-label">Native Elements</dt>
      <dd class="stat-number"><data value="114" data-ticker>114</data></dd>
    </div>
    <div class="stat">
      <dt class="stat-label">Custom Elements</dt>
      <dd class="stat-number"><data value="21" data-ticker>21</data></dd>
    </div>
    <div class="stat">
      <dt class="stat-label">Web Components</dt>
      <dd class="stat-number"><data value="30" data-ticker>30</data></dd>
    </div>
    <div class="stat">
      <dt class="stat-label">Dependencies</dt>
      <dd class="stat-number"><data value="0" data-ticker data-ticker-start="99">0</data></dd>
    </div>
  </dl>

  <!-- Progressive Enhancement Demo -->
  <section class="pe-section">
    <h2>Progressive Enhancement in Action</h2>
    <p class="pe-lead">The same HTML, enhanced layer by layer. Each layer is optional — the previous one always works on its own.</p>

    <tab-set>
      <details name="pe-demo" open>
        <summary>1. HTML</summary>
        <figure class="pe-panel">
          <code-block language="html" label="Source HTML">&lt;section data-layout="stack"&gt;
  &lt;h3&gt;Settings&lt;/h3&gt;

  &lt;details name="settings"&gt;
    &lt;summary&gt;Appearance&lt;/summary&gt;
    &lt;form class="stacked"&gt;
      &lt;label&gt;Theme
        &lt;select&gt;
          &lt;option&gt;Default&lt;/option&gt;
          &lt;option&gt;Ocean&lt;/option&gt;
          &lt;option&gt;Forest&lt;/option&gt;
        &lt;/select&gt;
      &lt;/label&gt;
      &lt;label&gt;
        &lt;input type="checkbox" checked&gt; Dark mode
      &lt;/label&gt;
    &lt;/form&gt;
  &lt;/details&gt;

  &lt;details name="settings"&gt;
    &lt;summary&gt;Keyboard Shortcuts&lt;/summary&gt;
    &lt;dl&gt;
      &lt;div&gt;&lt;dt&gt;Search&lt;/dt&gt;    &lt;dd&gt;&lt;kbd&gt;Ctrl&lt;/kbd&gt;+&lt;kbd&gt;K&lt;/kbd&gt;&lt;/dd&gt;&lt;/div&gt;
      &lt;div&gt;&lt;dt&gt;Save&lt;/dt&gt;      &lt;dd&gt;&lt;kbd&gt;Ctrl&lt;/kbd&gt;+&lt;kbd&gt;S&lt;/kbd&gt;&lt;/dd&gt;&lt;/div&gt;
      &lt;div&gt;&lt;dt&gt;Shortcuts&lt;/dt&gt; &lt;dd&gt;&lt;kbd&gt;Shift&lt;/kbd&gt;+&lt;kbd&gt;?&lt;/kbd&gt;&lt;/dd&gt;&lt;/div&gt;
    &lt;/dl&gt;
  &lt;/details&gt;

  &lt;details name="settings"&gt;
    &lt;summary&gt;Notifications&lt;/summary&gt;
    &lt;label&gt;&lt;input type="checkbox" checked&gt; Email notifications&lt;/label&gt;
  &lt;/details&gt;

  &lt;footer data-layout="cluster" data-layout-gap="s"&gt;
    &lt;button&gt;Save Changes&lt;/button&gt;
    &lt;button class="secondary" popovertarget="confirm-reset"&gt;Reset&lt;/button&gt;
  &lt;/footer&gt;

  &lt;div id="confirm-reset" popover&gt;
    &lt;p&gt;Reset all settings to defaults?&lt;/p&gt;
    &lt;footer data-layout="cluster" data-layout-gap="s"&gt;
      &lt;button popovertarget="confirm-reset"&gt;Cancel&lt;/button&gt;
      &lt;button class="ghost"&gt;Confirm&lt;/button&gt;
    &lt;/footer&gt;
  &lt;/div&gt;
&lt;/section&gt;</code-block>
          <browser-window url="settings.html">
            <output class="pe-unstyled">
              <section>
                <h3>Settings</h3>
                <details name="settings-html">
                  <summary>Appearance</summary>
                  <form class="stacked">
                    <label>Theme
                      <select id="demo-html-theme" name="theme">
                        <option>Default</option>
                        <option>Ocean</option>
                        <option>Forest</option>
                      </select>
                    </label>
                    <label>
                      <input type="checkbox" id="demo-html-dark" checked> Dark mode
                    </label>
                  </form>
                </details>
                <details name="settings-html">
                  <summary>Keyboard Shortcuts</summary>
                  <dl>
                    <div><dt>Search</dt> <dd><kbd>Ctrl</kbd>+<kbd>K</kbd></dd></div>
                    <div><dt>Save</dt> <dd><kbd>Ctrl</kbd>+<kbd>S</kbd></dd></div>
                    <div><dt>Shortcuts</dt> <dd><kbd>Shift</kbd>+<kbd>?</kbd></dd></div>
                  </dl>
                </details>
                <details name="settings-html">
                  <summary>Notifications</summary>
                  <label><input type="checkbox" id="demo-html-email" checked> Email notifications</label>
                </details>
                <footer>
                  <button type="button">Save Changes</button>
                  <button type="button" popovertarget="confirm-reset-html">Reset</button>
                </footer>
                <div id="confirm-reset-html" popover>
                  <p>Reset all settings to defaults?</p>
                  <footer>
                    <button type="button" popovertarget="confirm-reset-html">Cancel</button>
                    <button type="button">Confirm</button>
                  </footer>
                </div>
              </section>
            </output>
          </browser-window>
          <figcaption class="pe-caption">Native HTML that works in any browser. <code>&lt;details&gt;</code> discloses, <code>popovertarget</code> opens popovers, <code>&lt;form&gt;</code> submits — zero CSS or JS needed.</figcaption>
        </figure>
      </details>

      <details name="pe-demo">
        <summary>2. + CSS</summary>
        <figure class="pe-panel">
          <code-block language="html" label="Add one stylesheet">&lt;link rel="stylesheet" href="vanilla-breeze.css"&gt;</code-block>
          <browser-window url="settings.html">
            <output>
              <section data-layout="stack">
                <h3>Settings</h3>
                <details name="settings-css">
                  <summary>Appearance</summary>
                  <form class="stacked">
                    <label>Theme
                      <select id="demo-css-theme" name="theme">
                        <option>Default</option>
                        <option>Ocean</option>
                        <option>Forest</option>
                      </select>
                    </label>
                    <label>
                      <input type="checkbox" id="demo-css-dark" checked> Dark mode
                    </label>
                  </form>
                </details>
                <details name="settings-css">
                  <summary>Keyboard Shortcuts</summary>
                  <dl>
                    <div><dt>Search</dt> <dd><kbd>Ctrl</kbd>+<kbd>K</kbd></dd></div>
                    <div><dt>Save</dt> <dd><kbd>Ctrl</kbd>+<kbd>S</kbd></dd></div>
                    <div><dt>Shortcuts</dt> <dd><kbd>Shift</kbd>+<kbd>?</kbd></dd></div>
                  </dl>
                </details>
                <details name="settings-css">
                  <summary>Notifications</summary>
                  <label><input type="checkbox" id="demo-css-email" checked> Email notifications</label>
                </details>
                <footer data-layout="cluster" data-layout-gap="s">
                  <button type="button">Save Changes</button>
                  <button type="button" class="secondary" popovertarget="confirm-reset-css">Reset</button>
                </footer>
                <div id="confirm-reset-css" popover>
                  <p>Reset all settings to defaults?</p>
                  <footer data-layout="cluster" data-layout-gap="s">
                    <button type="button" popovertarget="confirm-reset-css">Cancel</button>
                    <button type="button" class="ghost">Confirm</button>
                  </footer>
                </div>
              </section>
            </output>
          </browser-window>
          <figcaption class="pe-caption">One stylesheet adds design tokens, layout attributes, <code>&lt;kbd&gt;</code> keycap styling, and 30+ themes. No build step.</figcaption>
        </figure>
      </details>

      <details name="pe-demo">
        <summary>3. + JavaScript</summary>
        <figure class="pe-panel">
          <code-block language="html" label="Add one script">&lt;script type="module" src="vanilla-breeze.js"&gt;&lt;/script&gt;</code-block>
          <browser-window url="settings.html">
            <output>
              <section data-layout="stack">
                <h3>Settings</h3>
                <accordion-wc>
                  <details name="settings-js">
                    <summary>Appearance</summary>
                    <form class="stacked">
                      <label>Theme
                        <select id="demo-js-theme" name="theme">
                          <option>Default</option>
                          <option>Ocean</option>
                          <option>Forest</option>
                        </select>
                      </label>
                      <label>
                        <input type="checkbox" id="demo-js-dark" checked> Dark mode
                      </label>
                    </form>
                  </details>
                  <details name="settings-js">
                    <summary>Keyboard Shortcuts</summary>
                    <dl>
                      <div><dt>Search</dt> <dd><kbd>Ctrl</kbd>+<kbd>K</kbd></dd></div>
                      <div><dt>Save</dt> <dd><kbd>Ctrl</kbd>+<kbd>S</kbd></dd></div>
                      <div><dt>Shortcuts</dt> <dd><kbd>Shift</kbd>+<kbd>?</kbd></dd></div>
                    </dl>
                  </details>
                  <details name="settings-js">
                    <summary>Notifications</summary>
                    <label><input type="checkbox" id="demo-js-email" checked> Email notifications</label>
                  </details>
                </accordion-wc>
                <footer data-layout="cluster" data-layout-gap="s">
                  <button type="button">Save Changes</button>
                  <button type="button" class="secondary" popovertarget="confirm-reset-js">Reset</button>
                </footer>
