  <!-- Theme Lab -->
  <section class="theme-section">
    <h2 data-blur-reveal>One Attribute, 30+ Themes</h2>
    <p class="theme-lead">Pick a theme. Watch everything transform.</p>

    <figure class="theme-lab" id="theme-lab-preview" data-theme="default">
      <figcaption>
        <label>Theme
          <select id="theme-lab-select">
            <option value="default">Default</option>
            <option value="swiss">Swiss</option>
            <option value="organic">Organic</option>
            <option value="brutalist">Brutalist</option>
            <option value="kawaii">Kawaii</option>
            <option value="terminal">Terminal (Dark)</option>
            <option value="8bit">8‑bit (Dark)</option>
          </select>
        </label>
      </figcaption>

      <layout-card data-variant="outlined">
        <header><h3>Sample Card</h3></header>
        <section data-layout="stack" data-layout-gap="s">
          <p>See how themes transform typography, colors, and components.</p>
          <label>Name <input type="text" value="Jane Doe"></label>
          <progress value="70" max="100">70%</progress>
          <p><kbd>Ctrl</kbd>+<kbd>S</kbd> to save</p>
        </section>
        <footer data-layout="cluster" data-layout-gap="xs">
          <button type="button" class="small">Save</button>
          <button type="button" class="small secondary">Cancel</button>
          <button type="button" class="small ghost">Reset</button>
        </footer>
      </layout-card>

      <aside class="theme-lab-wide" data-layout="stack" data-layout-gap="m">
        <details open>
          <summary>Settings</summary>
          <form class="stacked">
            <label>Role
              <select id="theme-lab-role">
                <option>Admin</option>
                <option>Editor</option>
                <option>Viewer</option>
              </select>
            </label>
            <label><input type="checkbox" checked> Email notifications</label>
          </form>
        </details>
        <table>
          <thead><tr><th>Shortcut</th><th>Action</th></tr></thead>
          <tbody>
            <tr><td><kbd>Ctrl</kbd>+<kbd>S</kbd></td><td>Save</td></tr>
            <tr><td><kbd>Ctrl</kbd>+<kbd>K</kbd></td><td>Search</td></tr>
            <tr><td><kbd>Ctrl</kbd>+<kbd>Z</kbd></td><td>Undo</td></tr>
          </tbody>
        </table>
      </aside>
    </figure>

    <footer data-layout="cluster" data-layout-justify="center">
      <a href="/docs/themes/" class="button secondary">Browse All Themes</a>
    </footer>
  </section>

  <script type="module">
    const select = document.querySelector('#theme-lab-select');
    const preview = document.querySelector('#theme-lab-preview');
    if (select && preview) {
      // Import theme loader to ensure CSS is available before switching
      const base = document.querySelector('script[src*="main"]')?.src.replace(/\/[^/]+$/, '')
        || '/src';
      let ensureThemeLoaded;
      try {
        const loader = await import(`${base}/lib/theme-loader.js`);
        ensureThemeLoaded = loader.ensureThemeLoaded;
      } catch {
        // Fallback: theme CSS may already be loaded via CDN
        ensureThemeLoaded = () => Promise.resolve();
      }

      select.addEventListener('change', async () => {
        await ensureThemeLoaded(select.value);
        preview.dataset.theme = select.value;
      });
    }
  </script>

