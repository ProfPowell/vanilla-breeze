{% set basicCode %}<type-specimen
  font-family="Georgia"
  label="Georgia"
  show-characters
  show-weights>
</type-specimen>{% endset %}

{% set scaleCode %}<type-specimen
  font-family="system-ui"
  label="System UI"
  show-scale>
</type-specimen>{% endset %}

{% set fullCode %}<type-specimen
  font-family="system-ui"
  label="System UI"
  show-characters
  show-weights
  show-scale
  weights="300,400,500,600,700">
</type-specimen>{% endset %}

{% set customCode %}<type-specimen
  font-family="'Courier New', monospace"
  label="Courier New"
  sample="Pack my box with five dozen liquor jugs"
  show-characters
  weights="400,700">
</type-specimen>{% endset %}

<section>
  <h2>Overview</h2>
  <p>The <code>&lt;type-specimen&gt;</code> component displays a font specimen for exploring typefaces. It renders an editable sample, a character grid, a weight scale, and the VB 9-step type scale.</p>

  <div class="example">
    <type-specimen font-family="Georgia" label="Georgia" show-characters show-weights></type-specimen>
  </div>

  <code-block language="html" show-lines label="Basic specimen">{{ basicCode | escape }}</code-block>
</section>

<section>
  <h2>Attributes</h2>
  <table class="props-table">
    <thead>
      <tr>
        <th>Attribute</th>
        <th>Type</th>
        <th>Default</th>
        <th>Description</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><code>font-family</code></td>
        <td>string</td>
        <td><code>system-ui</code></td>
        <td>CSS <code>font-family</code> value.</td>
      </tr>
      <tr>
        <td><code>label</code></td>
        <td>string</td>
        <td>Derived from font-family</td>
        <td>Display name for the font.</td>
      </tr>
      <tr>
        <td><code>sample</code></td>
        <td>string</td>
        <td>The quick brown fox&hellip;</td>
        <td>Custom sample text.</td>
      </tr>
      <tr>
        <td><code>show-scale</code></td>
        <td>boolean</td>
        <td>&mdash;</td>
        <td>Show VB type scale (xs&ndash;5xl).</td>
      </tr>
      <tr>
        <td><code>show-weights</code></td>
        <td>boolean</td>
        <td>&mdash;</td>
        <td>Show weight scale with &ldquo;Aa&rdquo; samples.</td>
      </tr>
      <tr>
        <td><code>show-characters</code></td>
        <td>boolean</td>
        <td>&mdash;</td>
        <td>Show uppercase, lowercase, digit, and punctuation grids.</td>
      </tr>
      <tr>
        <td><code>weights</code></td>
        <td>string</td>
        <td><code>300,400,500,600,700</code></td>
        <td>Comma-separated font weights to display in the weight scale.</td>
      </tr>
    </tbody>
  </table>
</section>

<section>
  <h2>Features</h2>

  <h3>Character Grid</h3>
  <p>Shows uppercase, lowercase, digits, and punctuation in the specified font.</p>

  <h3>Weight Scale</h3>
  <p>Renders &ldquo;Aa&rdquo; at each specified weight for quick comparison.</p>

  <h3>VB Type Scale</h3>
  <p>Displays the 9-step VB type scale from <code>xs</code> to <code>5xl</code>.</p>

  <div class="example">
    <type-specimen font-family="system-ui" label="System UI" show-scale></type-specimen>
  </div>
  <code-block language="html" show-lines label="Type scale only">{{ scaleCode | escape }}</code-block>

  <h3>Editable Sample</h3>
  <p>The large sample text is <code>contenteditable</code> &mdash; click it and type your own text to preview the font.</p>
</section>

<section>
  <h2>Full Specimen</h2>
  <p>Enable all features at once for a comprehensive view.</p>

  <div class="example">
    <type-specimen font-family="system-ui" label="System UI" show-characters show-weights show-scale weights="300,400,500,600,700"></type-specimen>
  </div>
  <code-block language="html" show-lines label="Full specimen">{{ fullCode | escape }}</code-block>
</section>

<section>
  <h2>Custom Sample Text</h2>
  <div class="example">
    <type-specimen font-family="'Courier New', monospace" label="Courier New" sample="Pack my box with five dozen liquor jugs" show-characters weights="400,700"></type-specimen>
  </div>
  <code-block language="html" show-lines label="Custom sample">{{ customCode | escape }}</code-block>
</section>

<section>
  <h2>Accessibility</h2>
  <ul>
    <li>The sample text uses <code>contenteditable="plaintext-only"</code> with <code>spellcheck="false"</code> to avoid intrusive browser features.</li>
    <li>All sections use semantic markup for screen reader navigation.</li>
  </ul>
</section>

