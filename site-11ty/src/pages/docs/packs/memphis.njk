    <tr><th>Effects CSS</th><td><code>packs/memphis.effects.css</code></td></tr>
    <tr><th>Effects JS</th><td><code>packs/memphis.effects.js</code></td></tr>
    <tr><th>Fonts</th><td>Boogaloo (display), Outfit (body), Space Mono (mono) &mdash; ~70KB total</td></tr>
  </tbody>
