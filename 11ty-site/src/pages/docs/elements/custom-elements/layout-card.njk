{% set cssImplementation %}layout-card {
  display: block;
  padding: var(--_padding, var(--size-m));
  background: var(--color-surface);
  border-radius: var(--radius-l);
  box-shadow: 0 1px 3px oklch(0% 0 0 / 0.1);
  container-type: inline-size;

  /* Smart grid mode via :has() */
  &:has(> :is(header, section, footer)) {
    display: grid;
    grid-template:
      "header" auto
      "content" 1fr
      "footer" auto / 1fr;
    overflow: hidden;
    padding: 0;
  }
}

/* Grid-mode child styles */
layout-card:has(> :is(header, section, footer)) {
  > header { grid-area: header; padding: var(--size-m) var(--size-l); }
  > section { grid-area: content; padding: var(--size-l); }
  > footer  { grid-area: footer; padding: var(--size-m) var(--size-l); }
}{% endset %}

