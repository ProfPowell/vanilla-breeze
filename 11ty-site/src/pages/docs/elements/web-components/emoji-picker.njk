{% set basicCode %}<textarea id="msg" rows="3"></textarea>
<emoji-picker for="msg">
  <button data-trigger type="button">😀</button>
</emoji-picker>{% endset %}

{% set customTriggerCode %}<emoji-picker for="comment">
  <button data-trigger type="button" aria-label="Add emoji">
    Add Emoji
  </button>
</emoji-picker>{% endset %}

{% set eventCode %}{% raw %}const picker = document.querySelector('emoji-picker');

picker.addEventListener('emoji-select', (e) => {
  console.log(e.detail.emoji);      // "🚀"
  console.log(e.detail.shortcode);  // "rocket"
  console.log(e.detail.name);       // "Rocket"
});{% endraw %}{% endset %}

{% set noTargetCode %}{% raw %}<!-- No "for" attribute — handle insertion yourself -->
<emoji-picker>
  <button data-trigger type="button">😀</button>
</emoji-picker>

<script>
document.querySelector('emoji-picker')
  .addEventListener('emoji-select', (e) => {
    // Insert wherever you want
    myEditor.insert(e.detail.emoji);
  });
</script>{% endraw %}{% endset %}

<section>
    <h2>Overview</h2>
    <p>The <code>&lt;emoji-picker&gt;</code> component provides an accessible popup for browsing, searching, and selecting emoji. It can insert directly into a target <code>input</code>, <code>textarea</code>, or <code>contenteditable</code> element, or dispatch events for custom handling.</p>

    <browser-window
      src="/docs/examples/demos/emoji-basic.html"
      url="https://vanilla-breeze.dev/emoji-picker"
      title="Emoji Picker Demo"
      shadow>
    </browser-window>

    <code-block language="html" show-lines label="Basic emoji picker">{{ basicCode | escape }}</code-block>

    <aside class="note">
      <strong>~200 curated emoji by default.</strong> A focused core subset organized into 9 categories. Load <a href="/docs/attributes/data-emoji/#extended-emoji-set"><code>emoji-extended.js</code></a> to add ~1,700 more (the full GitHub/Slack shortcode set). The same dataset powers the <a href="/docs/attributes/data-emoji/"><code>data-emoji</code></a> attribute for shortcode replacement.
    </aside>
  </section>

  <section>
    <h2>Attributes</h2>
    <table class="props-table">
      <thead>
        <tr>
          <th>Attribute</th>
          <th>Type</th>
          <th>Default</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>for</code></td>
          <td>string</td>
          <td>&mdash;</td>
