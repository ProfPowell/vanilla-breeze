<h1>Theme Lab</h1>
<p class="lead">Unified playground for theme identity &mdash; pick a theme, border style, icon set, and color mode, then preview components across six test surfaces.</p>

<!-- ===== Controls Toolbar ===== -->
<form id="lab-controls" class="lab-controls" aria-label="Theme controls">
  <label>
    Theme
    <select name="theme" id="lab-theme-select">
      <option value="">Default</option>
      <optgroup label="Extreme">
        {% for theme in themeRegistry %}{% if theme.category == 'extreme' %}
        <option value="{{ theme.id }}">{{ theme.name }}</option>
        {% endif %}{% endfor %}
      </optgroup>
    </select>
  </label>
  <label>
    Border Style
    <select name="border-style">
      <option value="clean">Clean (default)</option>
      <option value="sharp">Sharp</option>
      <option value="soft">Soft</option>
      <option value="sketch">Sketch</option>
      <option value="rough">Rough</option>
      <option value="marker">Marker</option>
      <option value="kawaii">Kawaii</option>
      <option value="pixel">Pixel</option>
      <option value="neon">Neon</option>
      <option value="double">Double</option>
      <option value="organic">Organic</option>
      <option value="bubbly">Bubbly</option>
    </select>
  </label>
  <label>
    Icon Set
    <select name="icon-set">
      <option value="lucide">Lucide (default)</option>
      <option value="phosphor">Phosphor</option>
      <option value="tabler">Tabler</option>
      <option value="bold">Bold</option>
      <option value="mage">Mage</option>
    </select>
  </label>
  <label>
    Color Mode
    <select name="color-mode">
      <option value="light">Light</option>
      <option value="dark">Dark</option>
    </select>
  </label>
  <button type="button" data-action="reset">Reset All</button>
  <p class="theme-character" id="lab-theme-character">The VB default theme</p>
</form>

<!-- ===== Surface Previews ===== -->
<nav class="surface-picker" aria-label="Surface picker">
  <button type="button" data-surface="typography-prose" aria-pressed="true">Typography</button>
  <button type="button" data-surface="forms-inputs">Forms</button>
  <button type="button" data-surface="navigation-layout">Navigation</button>
  <button type="button" data-surface="data-display">Data</button>
  <button type="button" data-surface="feedback-status">Feedback</button>
  <button type="button" data-surface="interactive-components">Interactive</button>
</nav>
<iframe class="surface-frame" id="surface-frame" title="Theme preview surface"></iframe>

<!-- Comparison Galleries -->
<details class="gallery-section">
  <summary>Border Style Gallery</summary>
