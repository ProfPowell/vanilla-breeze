{% block extraScripts %}
<script type="module">
  // ========================================
  // Theme CSS Loader (for vignettes section)
  // ========================================

  const CDN_BASE = '/cdn';
  const loadedThemes = new Set();

  async function ensureThemeCSS(themeName) {
    if (!themeName || loadedThemes.has(themeName)) return;

    if (document.querySelector(`link[data-vb-theme="${themeName}"]`)) {
      loadedThemes.add(themeName);
      return;
    }

    loadedThemes.add(themeName);

    return new Promise((resolve, reject) => {
      const link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = `${CDN_BASE}/themes/${themeName}.css`;
      link.setAttribute('data-vb-theme', themeName);
      link.onload = resolve;
      link.onerror = () => {
        link.remove();
        loadedThemes.delete(themeName);
        reject(new Error(`Failed to load theme: ${themeName}`));
      };
      document.head.appendChild(link);
    });
  }

  // ========================================
  // Configuration
  // ========================================

  // Theme hints from registry (border + icon set recommendations)
  const THEME_HINTS = Object.fromEntries(
    {{ themeRegistry | dump | safe }}
      .filter(t => t.category === 'extreme' && t.hints)
      .map(t => [t.id, { border: t.hints.borderStyle || 'clean', icons: t.hints.iconSet || 'lucide' }])
  );

  // Theme character descriptions
  const THEME_CHARS = Object.fromEntries(
    {{ themeRegistry | dump | safe }}
      .filter(t => t.category === 'extreme')
      .map(t => [t.id, t.character || ''])
  );

  // ========================================
  // DOM refs
  // ========================================

  const form            = document.getElementById('lab-controls');
  const themeSelect     = form.querySelector('[name="theme"]');
  const borderSelect    = form.querySelector('[name="border-style"]');
  const iconSelect      = form.querySelector('[name="icon-set"]');
  const modeSelect      = form.querySelector('[name="color-mode"]');
  const themeCharacter  = document.getElementById('lab-theme-character');

  // ========================================
  // Surface iframe management
  // ========================================

  const SURFACE_BASE = '/docs/tools/theme-lab/surfaces/';
  const frame = document.getElementById('surface-frame');
  const pickerButtons = document.querySelectorAll('.surface-picker button');
  let activeSurface = 'typography-prose';

  function buildSurfaceUrl(surface) {
    const params = new URLSearchParams();
    if (themeSelect.value) params.set('theme', themeSelect.value);
    params.set('border', borderSelect.value);
    params.set('mode', modeSelect.value);
    params.set('icons', iconSelect.value);
    return `${SURFACE_BASE}${surface}.html?${params}`;
  }

  function loadSurface(surface) {
    activeSurface = surface;
    frame.style.height = '';
    frame.src = buildSurfaceUrl(surface);
    pickerButtons.forEach(btn => {
      btn.setAttribute('aria-pressed', btn.dataset.surface === surface);
    });
  }

  function reloadSurface() {
    frame.src = buildSurfaceUrl(activeSurface);
  }

  // Surface picker button clicks
  pickerButtons.forEach(btn => {
    btn.addEventListener('click', () => loadSurface(btn.dataset.surface));
  });

  // Listen for surface height reports
  window.addEventListener('message', (e) => {
    if (e.data?.type === 'surface-height' && e.source === frame.contentWindow) {
      frame.style.height = e.data.height + 'px';
    }
  });

  // ========================================
  // Control Handlers
  // ========================================

  // Theme picker — loads CSS for vignettes and auto-sets border + icons
  themeSelect.addEventListener('change', async () => {
    const theme = themeSelect.value;

    if (theme) {
      try { await ensureThemeCSS(theme); } catch { /* continue without CSS */ }
    }

    // Show theme character description
    themeCharacter.textContent = THEME_CHARS[theme] || 'The VB default theme';

    // Auto-hint border + icons from registry
    const hints = THEME_HINTS[theme];
    if (hints) {
      borderSelect.value = hints.border;
      iconSelect.value = hints.icons;
    } else {
      borderSelect.value = 'clean';
      iconSelect.value = 'lucide';
    }

    reloadSurface();
  });

  // Border style
  borderSelect.addEventListener('change', () => {
    reloadSurface();
  });

  // Icon set
  iconSelect.addEventListener('change', () => {
    reloadSurface();
  });

  // Color mode
  modeSelect.addEventListener('change', () => {
    reloadSurface();
  });

  // Reset
  document.querySelector('[data-action="reset"]').addEventListener('click', () => {
    themeSelect.value = '';
    borderSelect.value = 'clean';
    iconSelect.value = 'lucide';
    modeSelect.value = 'light';
    themeCharacter.textContent = 'The VB default theme';

    reloadSurface();
  });

  // ========================================
  // Vignette theme preloading
  // ========================================

  const vignettesSection = document.getElementById('vignettes-section');
  let vignettesLoaded = false;

  vignettesSection.addEventListener('toggle', async () => {
    if (!vignettesSection.open || vignettesLoaded) return;
    vignettesLoaded = true;

    const vignetteThemes = [...vignettesSection.querySelectorAll('[data-theme]')]
      .map(el => el.dataset.theme)
      .filter(Boolean);

    await Promise.allSettled(vignetteThemes.map(t => ensureThemeCSS(t)));
  });

  // ========================================
  // Open in Composer
  // ========================================

  document.querySelectorAll('.open-in-composer').forEach(btn => {
    btn.addEventListener('click', () => {
      const themeId = btn.dataset.composerTheme;
      localStorage.setItem('vb-composer-load-theme', themeId);
      window.location.href = '/docs/tools/theme-composer/';
    });
  });

  // ========================================
  // Initial render — load first surface
  // ========================================

  loadSurface(activeSurface);
</script>
{% endblock %}
