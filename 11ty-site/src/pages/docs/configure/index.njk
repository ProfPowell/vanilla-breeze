{% block extraHead %}
<style>
  .configurator-layout {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: var(--size-l, 1.5rem);
    align-items: start;
  }

  @media (max-width: 860px) {
    .configurator-layout { grid-template-columns: 1fr; }
  }

  .controls {
    position: sticky;
    top: var(--size-m, 1rem);
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--color-border, #ddd);
    border-radius: var(--radius-m, 0.5rem);
    background: var(--color-surface, #fff);
    max-height: calc(100vh - 2rem);
    overflow-y: auto;
  }

  .controls details {
    border-block-end: 1px solid var(--color-border-subtle, #eee);
  }

  .controls details:last-of-type {
    border-block-end: none;
  }

  .controls summary {
    padding: var(--size-s, 0.75rem) var(--size-m, 1rem);
    font-weight: 700;
    font-size: var(--font-size-sm, 0.875rem);
    cursor: pointer;
    user-select: none;
  }

  /* Reset fieldset inside details */
  .detail-body {
    border: none;
    margin: 0;
    padding: 0 var(--size-m, 1rem) var(--size-m, 1rem);
    display: flex;
    flex-direction: column;
    gap: var(--size-s, 0.75rem);
  }

  .detail-body > label:not(.toggle-row) {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-size: var(--font-size-sm, 0.875rem);
    font-weight: 500;
  }

  .detail-body select {
    padding: 0.375rem 0.5rem;
    border: 1px solid var(--color-border, #ddd);
    border-radius: var(--radius-s, 0.25rem);
    font: inherit;
    font-size: var(--font-size-sm, 0.875rem);
    background: var(--color-surface, #fff);
    color: var(--color-text, #222);
  }

  .detail-body select[multiple] {
    min-height: 5.5rem;
  }

  .toggle-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: var(--size-s, 0.75rem);
    font-size: var(--font-size-sm, 0.875rem);
    font-weight: 400;
    cursor: pointer;
  }

  .toggle-row small {
    display: block;
    font-size: var(--font-size-xs, 0.75rem);
    color: var(--color-text-muted, #666);
  }

  .size-badge {
    display: inline-block;
    font-family: var(--font-mono, monospace);
    font-size: var(--font-size-xs, 0.75rem);
    font-weight: 700;
    padding: var(--size-3xs, 2px) var(--size-2xs, 4px);
    background: var(--color-surface-alt, oklch(95% 0 0));
    border-radius: var(--radius-s, 0.25rem);
    color: var(--color-text-muted, #666);
    min-width: 4.5em;
    text-align: center;
  }

  .output-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--size-s, 0.75rem);
    margin-block-end: var(--size-s, 0.75rem);
  }

  .output-header h2 {
    margin: 0;
  }
</style>
{% endblock %}

<h1>Bundle Configurator</h1>
<p class="lead">Select the bundles you need and get a ready-to-paste HTML snippet.</p>

<section class="configurator-layout">
  <form id="vb-configurator" class="controls" aria-label="Bundle configurator">

    <details open name="configurator">
      <summary>CSS</summary>
      <fieldset class="detail-body">
        <label>
          Bundle
          <select name="css-bundle">
            <option value="core">Core (base styles, layout)</option>
            <option value="full">Full (includes all themes)</option>
            <option value="none">None (bring your own)</option>
          </select>
        </label>
        <label>
          Theme
          <select id="vb-theme-select" name="theme" multiple>
            <option value="" selected>Base theme (default)</option>
          </select>
          <small>Hold Ctrl/Cmd to select multiple themes.</small>
        </label>
      </fieldset>
    </details>

    <details open name="configurator">
      <summary>JavaScript</summary>
      <fieldset class="detail-body">
        <label>
          Bundle
          <select name="js-bundle">
            <option value="core">Core (essential components)</option>
            <option value="core-extras">Core + Extras (all components)</option>
            <option value="full">Full (single bundle)</option>
            <option value="autoloader">Autoloader (on demand)</option>
            <option value="none">None (CSS only)</option>
          </select>
        </label>
      </fieldset>
    </details>

    <details name="configurator">
      <summary>Add-ons</summary>
      <fieldset class="detail-body">
        <label class="toggle-row">
          <span>Charts CSS<small>Data visualization</small></span>
          <input type="checkbox" data-switch="sm" name="addon-charts" />
        </label>
        <label class="toggle-row">
          <span>Dev CSS<small>Debug overlays</small></span>
          <input type="checkbox" data-switch="sm" name="addon-dev-css" />
        </label>
        <label class="toggle-row">
          <span>Dev JS<small>Content validation</small></span>
          <input type="checkbox" data-switch="sm" name="addon-dev-js" />
        </label>
      </fieldset>
    </details>

    <details name="configurator">
      <summary>Options</summary>
      <fieldset class="detail-body">
        <label class="toggle-row">
          <span>Service Worker<small>Offline caching</small></span>
          <input type="checkbox" data-switch="sm" name="enable-sw" />
        </label>
      </fieldset>
    </details>

  </form>

  <article>
    <header class="output-header">
      <h2>Your Snippet</h2>
      <span class="size-badge" id="vb-total-size">0 KB</span>
    </header>

    <code-block language="html" label="HTML head" id="vb-snippet-output">&lt;!-- Select bundles to generate --&gt;</code-block>
  </article>
</section>

<script type="module">
  const CDN_BASE = '/cdn';
  const form = document.getElementById('vb-configurator');
  const codeBlock = document.getElementById('vb-snippet-output');
  const sizeOutput = document.getElementById('vb-total-size');
  const themeSelect = document.getElementById('vb-theme-select');

  let themeManifest = {};
  let budgetReport = {};

  async function loadData() {
    try {
      const [themes, report] = await Promise.allSettled([
        fetch(`${CDN_BASE}/themes/manifest.json`).then(r => r.ok ? r.json() : {}),
        fetch(`${CDN_BASE}/budget-report.json`).then(r => r.ok ? r.json() : {}),
      ]);
      themeManifest = themes.status === 'fulfilled' ? themes.value : {};
      budgetReport = report.status === 'fulfilled' ? report.value : {};
    } catch { /* use defaults */ }

    const accents = ['ocean','forest','sunset','rose','lavender','coral','slate','emerald','amber','indigo'];
    const personality = ['modern','minimal','classic'];
    const sorted = Object.keys(themeManifest).sort((a, b) => a.localeCompare(b));

    const addGroup = (label, ids) => {
      const group = document.createElement('optgroup');
      group.label = label;
      for (const id of ids) {
        if (!themeManifest[id]) continue;
        const opt = document.createElement('option');
        opt.value = id;
        opt.textContent = id.charAt(0).toUpperCase() + id.slice(1).replace(/-/g, ' ');
        group.appendChild(opt);
      }
      if (group.children.length) themeSelect.appendChild(group);
    };

    addGroup('Accent Colors', accents);
    addGroup('Personality', personality);
    addGroup('Extreme', sorted.filter(id => !accents.includes(id) && !personality.includes(id)));

    updateSnippet();
  }

  function getSize(name) {
    return budgetReport.artifacts?.[name]?.gzip ?? 0;
  }

  function getSelectedThemes() {
    return Array.from(themeSelect.selectedOptions)
      .map(opt => opt.value)
      .filter(v => v !== '');
  }

  function updateSnippet() {
    const data = new FormData(form);
    const cssBundle = data.get('css-bundle');
    const jsBundle = data.get('js-bundle');
    const themes = getSelectedThemes();
    const chartsCss = data.get('addon-charts');
    const devCss = data.get('addon-dev-css');
    const devJs = data.get('addon-dev-js');
    const enableSW = data.get('enable-sw');

    const lines = [];
    let totalSize = 0;

    if (enableSW) {
      lines.push('<meta name="vb-service-worker" content="true">');
      lines.push('');
    }

    if (cssBundle === 'core') {
      lines.push(`<link rel="stylesheet" href="${CDN_BASE}/vanilla-breeze-core.css">`);
      totalSize += getSize('vanilla-breeze-core.css');
    } else if (cssBundle === 'full') {
      lines.push(`<link rel="stylesheet" href="${CDN_BASE}/vanilla-breeze.css">`);
      totalSize += getSize('vanilla-breeze.css');
    }

    // Theme links (only for core CSS — full already includes all themes)
    if (cssBundle !== 'full' && cssBundle !== 'none') {
      for (const theme of themes) {
        lines.push(`<link rel="stylesheet" href="${CDN_BASE}/themes/${theme}.css">`);
        totalSize += getSize(`themes/${theme}.css`);
      }
    }

    if (chartsCss) {
      lines.push(`<link rel="stylesheet" href="${CDN_BASE}/vanilla-breeze-charts.css">`);
      totalSize += getSize('vanilla-breeze-charts.css');
    }
    if (devCss) {
      lines.push(`<link rel="stylesheet" href="${CDN_BASE}/vanilla-breeze-dev.css">`);
      totalSize += getSize('vanilla-breeze-dev.css');
    }

    // Blank line between CSS and JS
    const hasJS = jsBundle !== 'none' || devJs;
    if (lines.length && hasJS) lines.push('');

    if (jsBundle === 'core') {
      lines.push(`<script type="module" src="${CDN_BASE}/vanilla-breeze-core.js"><\/script>`);
      totalSize += getSize('vanilla-breeze-core.js');
    } else if (jsBundle === 'core-extras') {
      lines.push(`<script type="module" src="${CDN_BASE}/vanilla-breeze-core.js"><\/script>`);
      lines.push(`<script type="module" src="${CDN_BASE}/vanilla-breeze-extras.js"><\/script>`);
      totalSize += getSize('vanilla-breeze-core.js');
      totalSize += getSize('vanilla-breeze-extras.js');
    } else if (jsBundle === 'full') {
      lines.push(`<script type="module" src="${CDN_BASE}/vanilla-breeze.js"><\/script>`);
      totalSize += getSize('vanilla-breeze.js');
    } else if (jsBundle === 'autoloader') {
      lines.push(`<script type="module" src="${CDN_BASE}/vanilla-breeze-autoload.js"><\/script>`);
      totalSize += getSize('vanilla-breeze-autoload.js');
    }

    if (devJs) {
      lines.push(`<script type="module" src="${CDN_BASE}/vanilla-breeze-dev.js"><\/script>`);
      totalSize += getSize('vanilla-breeze-dev.js');
    }

    const snippet = lines.join('\n').trim();

    // Use setCode() API for live update of code-block
    if (typeof codeBlock.setCode === 'function') {
      codeBlock.setCode(snippet || '<!-- Select at least one bundle -->');
    } else {
      // Fallback: replace element
      codeBlock.textContent = snippet || '<!-- Select at least one bundle -->';
    }

    sizeOutput.textContent = totalSize > 0 ? `${(totalSize / 1024).toFixed(1)} KB gzip` : '0 KB';
  }

  form.addEventListener('change', () => {
    const cssBundle = new FormData(form).get('css-bundle');
    const isDisabled = cssBundle === 'full' || cssBundle === 'none';
    themeSelect.disabled = isDisabled;
    if (isDisabled) {
      // Deselect all themes, reselect base
      for (const opt of themeSelect.options) opt.selected = (opt.value === '');
    }
    updateSnippet();
  });

  loadData();
</script>
