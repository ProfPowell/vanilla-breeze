node_modules/

# Build artifacts (keep dist/cdn/ for GitHub installs)
dist/*
!dist/cdn/

# OS files
.DS_Store
*.log

# Cook build output
site/dist/
site/node_modules/

# Generated topic pages (rebuilt by site/plugins/generate-topics.js each build)
site/src/pages/topics/

# Legacy 11ty (archived)
site-11ty/_site/
site-11ty/node_modules/

# Debug screenshots (root-level PNGs)
/*.png

# Build output
_site/

# Playwright test output (not committed)
tests/visual/results/
tests/visual/test-results/
test-results/
playwright-report/

# Element visual test output (generated, not committed)
tests/element-visual/fixtures/generated/
tests/element-visual/gallery/gallery.html
tests/element-visual/results/

# Old/deprecated
zz-old/
.playwright-mcp/
.idea/

# Cloudflare Wrangler local state (local SQLite DB, dev config)
.wrangler/

# JetBrains Junie AI assistant — per-developer tool memory, not shared
.junie/

# Claude Code per-agent worktrees and scheduled task locks (local only)
.claude/worktrees/
.claude/scheduled_tasks.lock
admin/.claude/

# VB signing keys — only commit *.public.jwk; never *.private.jwk
.vb-keys/*.private.jwk

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
